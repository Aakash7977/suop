# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
apps/backend/coverage/
apps/backend/coverage/**

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
# Default: ignore all .env files (contain runtime values)
# Exceptions: explicitly track templates and dev defaults (no secrets)
.env*
!.env.production.example
!.env.example
# Note: apps/backend/.env, apps/backend/.env.test, apps/backend/prisma/.env
# are explicitly tracked because they contain only dev/test defaults.
# Use `git add -f` to force-add if needed.

# vercel
.vercel


# typescript
*.tsbuildinfo
next-env.d.ts
local-*
.claude
.z-ai-config
*.log
dev.log
dev.out.log
test
prompt

server.log

# Skills directory
/skills/

# Runtime uploads — never commit user-uploaded files
# These are runtime artifacts (COA, evidence photos, documents) that
# belong in object storage (S3) or a persistent volume, NOT in git.
apps/backend/uploads/
apps/backend/uploads/**
# Keep the .gitkeep so the directory structure is preserved
!apps/backend/uploads/.gitkeep

# PostgreSQL data directory — runtime state, never commit
# (this is the PGlite/Postgres data dir used in development)
apps/backend/db/

# Build output
apps/backend/dist/
dist/