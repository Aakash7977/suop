# ════════════════════════════════════════════════════════════════════════════
# SUOP ERP v1.0 — Environment Variables Example
# ════════════════════════════════════════════════════════════════════════════
# Copy this file to .env (development) or .env.prod (production) and fill in
# the values. All variables are validated by Zod at startup — the application
# will refuse to start if any required variable is missing or invalid.
#
# Per RC1 Fix Pack 1 §6: All env vars validated via Zod; startup fails on
# missing/invalid values; no silent fallbacks.

# ─── Runtime ─────────────────────────────────────────────────────────────────
# Application environment profile
NODE_ENV=development
# Allowed values: development | staging | production | test
# - development: verbose logging, hot reload, relaxed security checks
# - staging: production-like but with debug logging
# - production: minimal logging, strict security, no debug endpoints
# - test: used by vitest; relaxes timeouts and external dependencies

# HTTP port the backend listens on
PORT=3030
# Range: 1-65535. Default: 3030. Avoid privileged ports (<1024) in production.

# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string. Must start with postgresql:// or postgres://
DATABASE_URL=postgresql://suop:suop_dev_password@localhost:5432/suop_dev?schema=public

# Prisma connection pool size (max simultaneous DB connections)
DATABASE_POOL_SIZE=10
# Range: 1-100. Default: 10. Increase for high-traffic deployments.

# Statement timeout (ms) — queries that exceed this are aborted
DATABASE_STATEMENT_TIMEOUT_MS=30000
# Default: 30000 (30 seconds). Set lower for latency-sensitive apps.

# Log all SQL queries to console (development only)
DATABASE_LOG_QUERIES=false
# Set to true only in development — has performance impact in production.

# ─── Redis ───────────────────────────────────────────────────────────────────
# Redis connection string. Must start with redis:// or rediss:// (TLS)
REDIS_URL=redis://localhost:6379
# Used for: rate limiting, session cache, queue backend, pub/sub events.

# ─── JWT / Authentication ────────────────────────────────────────────────────
# JWT signing secret — MUST be at least 32 characters (256 bits minimum)
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
# Generate with: openssl rand -base64 48

# JWT issuer claim (identifies this service)
JWT_ISSUER=suop-erp

# JWT audience claim (identifies the intended consumer)
JWT_AUDIENCE=suop-frontend

# Access token TTL (minutes) — short-lived for security
JWT_ACCESS_TTL_MIN=15
# Range: 1-60. Default: 15. Keep short to limit token theft window.

# Refresh token TTL (days) — long-lived, allows user to stay logged in
JWT_REFRESH_TTL_DAYS=30
# Range: 1-365. Default: 30. Balance UX vs security.

# ─── File Storage (S3-compatible) ────────────────────────────────────────────
# S3 endpoint URL. For AWS S3, use https://s3.<region>.amazonaws.com
# For MinIO (dev), use http://localhost:9000
S3_ENDPOINT=http://localhost:9000

# S3 bucket name (must already exist)
S3_BUCKET=suop-uploads

# S3 access key (IAM user access key ID for AWS, minioadmin for MinIO dev)
S3_ACCESS_KEY=minioadmin

# S3 secret key (IAM user secret access key for AWS, minioadmin for MinIO dev)
S3_SECRET_KEY=minioadmin

# S3 region (AWS region for the bucket)
S3_REGION=ap-south-1

# Use path-style addressing (required for MinIO; false for AWS S3)
S3_FORCE_PATH_STYLE=true

# ─── Email (SMTP) ────────────────────────────────────────────────────────────
# SMTP server hostname
SMTP_HOST=localhost

# SMTP server port (587 for TLS, 465 for SSL, 1025 for MailHog dev)
SMTP_PORT=1025

# SMTP username (leave empty for no-auth dev servers like MailHog)
SMTP_USER=

# SMTP password (leave empty for no-auth dev servers)
SMTP_PASS=

# From: address for outgoing emails
SMTP_FROM=no-reply@sudhamrit.com

# ─── Observability ───────────────────────────────────────────────────────────
# Sentry DSN for error tracking (optional — leave empty to disable)
SENTRY_DSN=

# Log level: fatal | error | warn | info | debug | trace
LOG_LEVEL=info
# Default: info. Use debug/trace only in development.

# ─── Feature Flags (env-level defaults; per-tenant overrides in DB) ──────────
# New recall engine (Phase 2)
FEATURE_NEW_RECALL_ENGINE=false

# WebSocket real-time notifications
FEATURE_WEBSOCKET_NOTIFICATIONS=false

# AI-powered predictive quality (Phase 2)
FEATURE_AI_PREDICTIVE_QUALITY=false

# ─── RC1 Fix Pack 2: Security ──────────────────────────────────────────────────
# CORS allowed origins (comma-separated, supports wildcards)
# Example: https://app.sudhamrit.com,https://admin.sudhamrit.com,https://*.sudhamrit.com
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Field-level encryption key (AES-256). MUST be set in production.
# Generate with: openssl rand -base64 48
# If not set, derived from JWT_SECRET (NOT recommended for production)
FIELD_ENCRYPTION_KEY=

# ClamAV virus scanner (optional — for file upload scanning)
# Leave empty to skip virus scanning (defense-in-depth still applies via MIME/extension checks)
CLAMAV_HOST=
CLAMAV_PORT=3310

# Body size limits (bytes)
MAX_BODY_BYTES=1048576
MAX_UPLOAD_BYTES=52428800

# Request timeout (ms)
REQUEST_TIMEOUT_MS=30000

# ─── RC1 Fix Pack 2: Performance ───────────────────────────────────────────────
# Cache TTLs (seconds) — overridable per-call
CACHE_TTL_PERMISSIONS=300
CACHE_TTL_CONFIG=60
CACHE_TTL_MASTER_DATA=600
CACHE_TTL_DASHBOARD=30
CACHE_TTL_ANALYTICS=300

# Background job worker
JOB_WORKER_ENABLED=false
JOB_WORKER_POLL_MS=1000
JOB_MAX_CONCURRENT=10

# ─── RC1 Fix Pack 2: Observability ─────────────────────────────────────────────
# OpenTelemetry exporter (optional — leave empty to disable tracing export)
# Example: http://otel-collector.observability.svc.cluster.local:4318
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=suop-backend
OTEL_SERVICE_VERSION=1.0.0-rc1

# ─── Build Metadata (injected by CI/CD — do not set manually) ───────────────
# APP_VERSION=1.0.0-rc1
# GIT_COMMIT=abc123
# BUILD_DATE=2026-07-12T10:00:00Z
# BUILD_HOST=ci-runner
