# SUOP ERP Environment Configuration
# ==================================
# For LOCAL development without Supabase, just use Demo Mode (no setup needed).
# The app works fully in Demo Mode without any database or auth backend.

# --- Database (PostgreSQL) ---
# Option A: Docker PostgreSQL (run: docker-compose up -d postgres)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/suop?schema=public"

# Option B: Supabase (replace with your project URL)
# DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres?schema=public"

# Option C: No database (Demo Mode works without DB)
# Just leave DATABASE_URL as-is and use Demo Mode in the UI

# --- Supabase Auth (Optional - Demo Mode works without this) ---
# Get these from: Supabase Dashboard → Settings → API
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- Backend (Optional) ---
# The Bun backend runs on port 3030. The frontend works without it in Demo Mode.
