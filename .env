# SUOP — Environment Configuration
# Sprint 1: Platform Foundation

# ─── Database ──────────────────────────────────────────
DATABASE_URL="postgresql://suop:suop_password@localhost:5432/suop?schema=public"

# ─── Redis ─────────────────────────────────────────────
REDIS_HOST="localhost"
REDIS_PORT="6379"

# ─── RabbitMQ ──────────────────────────────────────────
RABBITMQ_HOST="localhost"
RABBITMQ_PORT="5672"
RABBITMQ_USER="suop"
RABBITMQ_PASSWORD="suop_password"

# ─── Object Storage (MinIO) ───────────────────────────
MINIO_HOST="localhost"
MINIO_PORT="9000"
MINIO_ACCESS_KEY="suop"
MINIO_SECRET_KEY="suop_password"

# ─── Search (OpenSearch) ──────────────────────────────
OPENSEARCH_HOST="localhost"
OPENSEARCH_PORT="9200"

# ─── Backend API ───────────────────────────────────────
BACKEND_PORT="3030"
BACKEND_URL="http://localhost:3030"

# ─── Frontend ─────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:3030"
NEXT_PUBLIC_APP_NAME="SUOP Admin"
NEXT_PUBLIC_APP_VERSION="1.0.0"

# ─── JWT ───────────────────────────────────────────────
JWT_SECRET="suop-dev-secret-change-in-production"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# ─── Environment ───────────────────────────────────────
NODE_ENV="development"
