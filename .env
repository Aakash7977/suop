# SUOP ERP Environment Configuration
# ==================================

# --- Database (PostgreSQL) ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/suop?schema=public"

# --- Supabase Auth ---
# To enable real Supabase auth, uncomment and set these:
# Get from: Supabase Dashboard → Settings → API → Project URL + anon public key
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Without these set:
# - Demo Mode works (click "Explore Demo Mode")
# - Login with any email/password works (local fallback auth)
# With these set:
# - Real Supabase authentication is used
