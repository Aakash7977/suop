{
  "expo": {
    "name": "SUOP Execution",
    "slug": "suop-execution-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#0f172a",
      "resizeMode": "contain",
      "imageWidth": 100
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sudhamrit.suop.app"
    },
    "android": {
      "package": "com.sudhamrit.suop.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.VIBRATE",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "eas": { "projectId": "suop-execution-app" }
    }
  }
}
