# ─────────────────────────────────────────────────────────────────────────────
# SUOP Backend — Production Environment Template
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.production and fill in real values.
# NEVER commit .env.production to git. Use a secrets manager (Vault, AWS SSM,
# Kubernetes secrets) to inject these at deploy time.
#
# This template documents every variable the backend reads. Any variable
# missing at boot will cause the application to refuse to start (no silent
# fallbacks — see config/env.ts).
# ─────────────────────────────────────────────────────────────────────────────

# ─── Runtime ─────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3030

# ─── Database ────────────────────────────────────────────────────────────────
# Replace with managed PostgreSQL (RDS, Cloud SQL, Supabase, etc.)
DATABASE_URL=postgresql://USER:PASSWORD@prod-db-host:5432/suop_prod
DATABASE_POOL_SIZE=20
DATABASE_STATEMENT_TIMEOUT_MS=30000
DATABASE_LOG_QUERIES=false

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://prod-redis-host:6379

# ─── JWT / Auth ──────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=__REPLACE_WITH_RANDOM_32_PLUS_CHAR_SECRET__
JWT_ISSUER=suop-erp
JWT_AUDIENCE=suop-frontend
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=30

# ─── Password Hashing Pepper ─────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
# NEVER rotate without coordinating password rehash on next user login.
PASSWORD_PEPPER=__REPLACE_WITH_RANDOM_32_PLUS_CHAR_PEPPER__

# ─── Object Storage ──────────────────────────────────────────────────────────
S3_ENDPOINT=https://s3.ap-south-1.amazonaws.com
S3_BUCKET=suop-prod-ACCOUNTID
S3_ACCESS_KEY=__REPLACE__
S3_SECRET_KEY=__REPLACE__
S3_REGION=ap-south-1
S3_FORCE_PATH_STYLE=false

# ─── Email ───────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=__REPLACE_WITH_SENDGRID_API_KEY__
SMTP_FROM=noreply@sudhamrit.com

# ─── Observability ───────────────────────────────────────────────────────────
SENTRY_DSN=__REPLACE_WITH_SENTRY_DSN__
LOG_LEVEL=info

# ─── Feature Flags ───────────────────────────────────────────────────────────
FEATURE_NEW_RECALL_ENGINE=false
FEATURE_WEBSOCKET_NOTIFICATIONS=false
FEATURE_AI_PREDICTIVE_QUALITY=false
