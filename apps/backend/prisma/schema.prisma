  freightAmount    Decimal?  @map("freight_amount") @db.Decimal(14, 2)
  freightPaidBy    String?   @default("CUSTOMER") @map("freight_paid_by")
  shippingLabelUrl String?   @map("shipping_label_url")
  trackingNumber   String?   @map("tracking_number")
  dispatchedBy     String?   @map("dispatched_by") @db.Uuid
  dispatchedByName String?   @map("dispatched_by_name")
  dispatchedAt     DateTime? @map("dispatched_at") @db.Timestamp(3)
  status           String    @default("CREATED")
  version          Int       @default(0)
  remarks          String?
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt        DateTime  @default(now()) @map("updated_at") @db.Timestamp(3)
  deletedAt        DateTime? @map("deleted_at") @db.Timestamp(3)
  createdBy        String?   @map("created_by") @db.Uuid
  updatedBy        String?   @map("updated_by") @db.Uuid

  @@unique([tenantId, shipmentNumber])
  @@index([tenantId])
  @@map("shipments")
}

