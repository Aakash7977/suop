// ════════════════════════════════════════════════════════════════════════════
// SUOP ERP v1.0 — Foundation Schema
// ════════════════════════════════════════════════════════════════════════════
// This schema defines ONLY the foundation tables needed by Phase 0.
// Business module tables (Organization, Product, Supplier, PO, etc.) will be
// added in Phase 1+ via separate migrations.
//
// All tables follow the reserved columns pattern:
//   id (UUID v7), tenant_id, version, created_at/by, updated_at/by, deleted_at/by
// ════════════════════════════════════════════════════════════════════════════

generator client {
  provider = "prisma-client-js"
  output = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

// ─── Audit Logs (append-only, immutable) ────────────────────────────────────
// Per Phase 0 Architecture §11: every mutation creates an immutable audit log.
model AuditLog {
  id String @id @default(uuid()) @db.Uuid
  tenantId String @map("tenant_id") @db.Uuid
  timestamp DateTime @default(now())
  // Actor
  actorType String @map("actor_type") // USER, SYSTEM, API_KEY, JOB
  actorId String? @map("actor_id") @db.Uuid
  actorName String? @map("actor_name")
  actorRole String? @map("actor_role")
  ipAddress String? @map("ip_address")
  userAgent String? @map("user_agent")
  correlationId String @map("correlation_id")
  // Action
  action String // CREATE, UPDATE, DELETE, APPROVE, TRANSITION, LOGIN, etc.
  severity String @default("INFO") // INFO, WARN, CRITICAL
  // Entity
  entityType String @map("entity_type")
  entityId String? @map("entity_id") @db.Uuid
  entityCode String? @map("entity_code")
  // Change
  before Json?
  after Json?
  diff Json?
  // Context
  reason String?
  metadata Json?
  // Reserved columns
  createdAt DateTime @default(now()) @map("created_at")
  createdBy String? @map("created_by") @db.Uuid

  @@index([tenantId, entityType, entityId], map: "idx_audit_tenant_entity")
  @@index([tenantId, action], map: "idx_audit_tenant_action")
  @@index([tenantId, severity], map: "idx_audit_tenant_severity")
  @@index([correlationId], map: "idx_audit_correlation")
  @@index([timestamp], map: "idx_audit_timestamp")
  @@map("audit_logs")
}

// ─── Event Outbox (durable domain event delivery) ───────────────────────────
// Per Phase 0 Architecture §18: outbox pattern guarantees at-least-once
// event delivery even if the event bus is temporarily unavailable.
model EventOutbox {
  id String @id @default(uuid()) @db.Uuid
  tenantId String @map("tenant_id") @db.Uuid
  eventName String @map("event_name")
  payload Json
  // Publishing state
  status String @default("PENDING") // PENDING, PUBLISHED, FAILED
  publishedAt DateTime? @map("published_at")
  retryCount Int @default(0) @map("retry_count")
  lastError String? @map("last_error")
  // Context
  correlationId String @map("correlation_id")
  actorId String? @map("actor_id") @db.Uuid
  // Metadata
  createdAt DateTime @default(now()) @map("created_at")

  @@index([status, createdAt], map: "idx_outbox_status_created")
  @@index([tenantId], map: "idx_outbox_tenant")
  @@map("event_outbox")
}

// ─── Notification Outbox (durable notification delivery) ────────────────────
model NotificationOutbox {
  id String @id @default(uuid()) @db.Uuid
  tenantId String @map("tenant_id") @db.Uuid
  // Recipient
  userId String? @map("user_id") @db.Uuid
  recipientEmail String? @map("recipient_email")
  recipientPhone String? @map("recipient_phone")
  // Content
  channel String // IN_APP, EMAIL, SMS, WHATSAPP
  subject String?
  body String
  templateId String? @map("template_id")
  templateData Json?
  // Delivery
  status String @default("PENDING") // PENDING, SENT, DELIVERED, FAILED
  sentAt DateTime? @map("sent_at")
  deliveredAt DateTime? @map("delivered_at")
  retryCount Int @default(0) @map("retry_count")
  lastError String? @map("last_error")
  // Context
  correlationId String @map("correlation_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([status, createdAt], map: "idx_notif_status_created")
  @@index([tenantId, userId], map: "idx_notif_tenant_user")
  @@map("notification_outbox")
}

// ─── Refresh Tokens ─────────────────────────────────────────────────────────
// Per Phase 0 Architecture §3.6: refresh tokens stored hashed in DB.
model RefreshToken {
  id String @id @default(uuid()) @db.Uuid
  tenantId String @map("tenant_id") @db.Uuid
  userId String @map("user_id") @db.Uuid
  // Token hash (SHA-256 of the raw token; raw token never stored)
  tokenHash String @unique @map("token_hash")
  // Device info
  deviceFingerprint String? @map("device_fingerprint")
  deviceName String? @map("device_name")
  ipAddress String? @map("ip_address")
  userAgent String? @map("user_agent")
  // Lifecycle
  issuedAt DateTime @default(now()) @map("issued_at")
  expiresAt DateTime @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  revokedReason String? @map("revoked_reason")
  // Rotation chain (for replay detection)
  previousTokenHash String? @map("previous_token_hash")
  // Audit
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId], map: "idx_refresh_user")
  @@index([tokenHash], map: "idx_refresh_token_hash")
  @@index([expiresAt], map: "idx_refresh_expires")
  @@map("refresh_tokens")
}

// ─── Idempotency Keys ───────────────────────────────────────────────────────
// Per API Standards §9: idempotency key store for safe retries.
model IdempotencyKey {
  id String @id @default(uuid()) @db.Uuid
  tenantId String @map("tenant_id") @db.Uuid
  key String
  requestHash String @map("request_hash")
  // Response
  responseStatus Int
  responseBody Json @map("response_body")
  // Metadata
  createdAt DateTime @default(now()) @map("created_at")
  expiresAt DateTime @map("expires_at")

  @@unique([tenantId, key], map: "uq_idempotency_tenant_key")
  @@index([expiresAt], map: "idx_idempotency_expires")
  @@map("idempotency_keys")
}

// ─── Feature Flags (per-tenant overrides; env vars are defaults) ────────────
model FeatureFlag {
  id String @id @default(uuid()) @db.Uuid
  tenantId String @map("tenant_id") @db.Uuid
  flagName String @map("flag_name")
  value Json // boolean or string[] (tenant allowlist)
  description String?
  // Audit
  updatedBy String? @map("updated_by") @db.Uuid
  updatedAt DateTime @updatedAt @map("updated_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([tenantId, flagName], map: "uq_feature_flag_tenant_name")
  @@map("feature_flags")
}

// ─── Background Jobs ────────────────────────────────────────────────────────
model BackgroundJob {
  id String @id @default(uuid()) @db.Uuid
  tenantId String @map("tenant_id") @db.Uuid
  jobName String @map("job_name")
  payload Json
  // Scheduling
  scheduledFor DateTime @default(now()) @map("scheduled_for")
  // Execution
  status String @default("PENDING") // PENDING, RUNNING, COMPLETED, FAILED, DEAD_LETTER
  attempts Int @default(0)
  maxRetries Int @default(3) @map("max_retries")
  // Result
  result Json?
  lastError String? @map("last_error")
  // Timestamps
  startedAt DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status, scheduledFor], map: "idx_jobs_status_scheduled")
  @@index([tenantId, jobName], map: "idx_jobs_tenant_name")
  @@map("background_jobs")
}

// ─── File Uploads ───────────────────────────────────────────────────────────
model FileUpload {
  id String @id @default(uuid()) @db.Uuid
  tenantId String @map("tenant_id") @db.Uuid
  filename String
  mimeType String @map("mime_type")
  sizeBytes Int @map("size_bytes")
  checksum String
  // Storage
  storageKey String @map("storage_key")
  storageDriver String @map("storage_driver") // local, s3
  // Context
  category String // COA, EVIDENCE, CALIBRATION_CERT, etc.
  linkedEntityType String? @map("linked_entity_type")
  linkedEntityId String? @map("linked_entity_id") @db.Uuid
  // Audit
  uploadedBy String? @map("uploaded_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId, category], map: "idx_files_tenant_category")
  @@index([tenantId, linkedEntityType, linkedEntityId], map: "idx_files_tenant_entity")
  @@map("file_uploads")
}

// ════════════════════════════════════════════════════════════════════════════
// PHASE 9 — SUPPLIER QUOTATION & BID EVALUATION
// ════════════════════════════════════════════════════════════════════════════

// ─── Supplier Quotations ────────────────────────────────────────────────────
model SupplierQuotation {
  id String @id @default(uuid()) @db.Uuid
  tenantId String @map("tenant_id") @db.Uuid
  quotationNumber String @map("quotation_number")

  // ─── References ───
  rfqId String @map("rfq_id") @db.Uuid
  rfqNumber String @map("rfq_number")
  supplierId String @map("supplier_id") @db.Uuid
  supplierCode String @map("supplier_code")
  supplierName String @map("supplier_name")

  // ─── Details ───
  quotationDate DateTime @default(now()) @map("quotation_date")
  validityDate DateTime @map("validity_date")
  currency String @default("INR")
  paymentTerms String @default("NET30") @map("payment_terms")
  deliveryTerms String? @map("delivery_terms")
  leadTimeDays Int? @map("lead_time_days")
  taxPercent Decimal? @map("tax_percent") @db.Decimal(5, 2)
  discountPercent Decimal? @map("discount_percent") @db.Decimal(5, 2)
  freightAmount Decimal? @map("freight_amount") @db.Decimal(14, 2)
  insuranceAmount Decimal? @map("insurance_amount") @db.Decimal(14, 2)
  warrantyTerms String? @map("warranty_terms")

  // ─── Totals ───
  subtotal Decimal @default(0) @db.Decimal(14, 2)
  taxAmount Decimal @default(0) @map("tax_amount") @db.Decimal(14, 2)
  discountAmount Decimal @default(0) @map("discount_amount") @db.Decimal(14, 2)
  grandTotal Decimal @default(0) @map("grand_total") @db.Decimal(14, 2)

  // ─── Evaluation ───
  technicalScore Decimal? @map("technical_score") @db.Decimal(5, 2)
  commercialScore Decimal? @map("commercial_score") @db.Decimal(5, 2)
  overallScore Decimal? @map("overall_score") @db.Decimal(5, 2)
  rank Int?
  isLowestPrice Boolean @default(false) @map("is_lowest_price")
  isBestValue Boolean @default(false) @map("is_best_value")
  recommendationNotes String? @map("recommendation_notes")

  // ─── Revision ───
  revisionNo Int @default(0) @map("revision_no")
  parentQuotationId String? @map("parent_quotation_id") @db.Uuid

  // ─── Status ───
  status String @default("DRAFT") @map("status")
  rejectionReason String? @map("rejection_reason")

  // ─── Remarks ───
  remarks String?
  attachments String[]

  // ─── Reserved ───
  version Int @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String? @map("created_by") @db.Uuid
  updatedBy String? @map("updated_by") @db.Uuid

  lines SupplierQuotationLine[]

  @@unique([tenantId, quotationNumber], map: "uq_quot_tenant_number")
  @@index([tenantId, status], map: "idx_quot_tenant_status")
  @@index([tenantId, rfqId], map: "idx_quot_tenant_rfq")
  @@index([tenantId, supplierId], map: "idx_quot_tenant_supplier")
  @@index([tenantId, rfqId, status], map: "idx_quot_tenant_rfq_status")
  @@map("supplier_quotations")
}

// ─── Quotation Lines ────────────────────────────────────────────────────────
model SupplierQuotationLine {
  id String @id @default(uuid()) @db.Uuid
  tenantId String @map("tenant_id") @db.Uuid
  quotationId String @map("quotation_id") @db.Uuid
  lineNo Int @map("line_no")

  productId String @map("product_id") @db.Uuid
  productSku String @map("product_sku")
  productName String @map("product_name")
  rfqLineId String? @map("rfq_line_id") @db.Uuid

  quotedQty Decimal @map("quoted_qty") @db.Decimal(14, 3)
  uomId String @map("uom_id") @db.Uuid
  uomCode String @map("uom_code")
  unitPrice Decimal @map("unit_price") @db.Decimal(14, 4)
  lineTotal Decimal @map("line_total") @db.Decimal(14, 2)
  currency String @default("INR")

  moq Decimal? @map("moq") @db.Decimal(14, 3)
  leadTimeDays Int? @map("lead_time_days")
  discountPercent Decimal? @map("discount_percent") @db.Decimal(5, 2)
  remarks String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  quotation SupplierQuotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  @@index([tenantId, quotationId], map: "idx_quot_line_tenant_quot")
  @@index([tenantId, productId], map: "idx_quot_line_tenant_product")
  @@map("supplier_quotation_lines")
}

// ════════════════════════════════════════════════════════════════════════════
// Phase 10: Purchase Order Management (12 entities)
// ════════════════════════════════════════════════════════════════════════════

model PurchaseOrder {
  id String @id @default(uuid()) @db.Uuid
  tenantId String @map("tenant_id") @db.Uuid
  poNumber String @map("po_number")
  poType String @default("STANDARD") @map("po_type")
  poDate DateTime @default(now()) @map("po_date")
  revisionNo Int @default(0) @map("revision_no")

  rfqId String? @map("rfq_id") @db.Uuid
  rfqNumber String? @map("rfq_number")
  quotationId String? @map("quotation_id") @db.Uuid
  quotationNumber String? @map("quotation_number")
  prId String? @map("pr_id") @db.Uuid
  prNumber String? @map("pr_number")
  supplierId String @map("supplier_id") @db.Uuid
  supplierCode String @map("supplier_code")
  supplierName String @map("supplier_name")
  supplierGstin String? @map("supplier_gstin")

  companyId String @map("company_id") @db.Uuid
  companyName String @map("company_name")
  plantId String @map("plant_id") @db.Uuid
  plantName String @map("plant_name")
  warehouseId String? @map("warehouse_id") @db.Uuid
  warehouseName String? @map("warehouse_name")
  departmentId String? @map("department_id") @db.Uuid
  costCenterId String? @map("cost_center_id") @db.Uuid

  buyerId String? @map("buyer_id") @db.Uuid
  buyerName String? @map("buyer_name")

  expectedDeliveryDate DateTime? @map("expected_delivery_date")
  deliveryTerms String? @map("delivery_terms")
  deliveryLocation String? @map("delivery_location")
  shippingAddress String? @map("shipping_address")
  billingAddress String? @map("billing_address")

  currency String @default("INR")
  exchangeRate Decimal @default(1) @map("exchange_rate") @db.Decimal(14, 6)
  subtotal Decimal @default(0) @db.Decimal(14, 2)
  discountPercent Decimal? @map("discount_percent") @db.Decimal(5, 2)
  discountAmount Decimal @default(0) @map("discount_amount") @db.Decimal(14, 2)
  taxAmount Decimal @default(0) @map("tax_amount") @db.Decimal(14, 2)
  freightAmount Decimal? @map("freight_amount") @db.Decimal(14, 2)
  insuranceAmount Decimal? @map("insurance_amount") @db.Decimal(14, 2)
  otherCharges Decimal? @map("other_charges") @db.Decimal(14, 2)
  roundOff Decimal? @map("round_off") @db.Decimal(14, 2)
  grandTotal Decimal @default(0) @map("grand_total") @db.Decimal(14, 2)

  paymentTerms String @default("NET30") @map("payment_terms")
  paymentTermsDays Int @default(30) @map("payment_terms_days")
  creditPeriodDays Int @default(30) @map("credit_period_days")
  advancePercent Decimal? @map("advance_percent") @db.Decimal(5, 2)
  creditDays Int? @map("credit_days")

  supplierAckStatus String? @map("supplier_ack_status")
  supplierAckDate DateTime? @map("supplier_ack_date")
  supplierAckNotes String? @map("supplier_ack_notes")
  supplierAckCounterTotal Decimal? @map("supplier_ack_counter_total") @db.Decimal(14, 2)

  receivedQty Decimal? @map("received_qty") @db.Decimal(14, 3)
  receivedAmount Decimal? @map("received_amount") @db.Decimal(14, 2)
  pendingQty Decimal? @map("pending_qty") @db.Decimal(14, 3)
  pendingAmount Decimal? @map("pending_amount") @db.Decimal(14, 2)
  isPartiallyReceived Boolean @default(false) @map("is_partially_received")
  isFullyReceived Boolean @default(false) @map("is_fully_received")
  lastReceiptDate DateTime? @map("last_receipt_date")

  validityDate DateTime? @map("validity_date")
  expiryDate DateTime? @map("expiry_date")

  status String @default("DRAFT")
  rejectionReason String? @map("rejection_reason")
  cancelReason String? @map("cancel_reason")
  revisionReason String? @map("revision_reason")
  approvalNotes String? @map("approval_notes")

  remarks String?
  internalNotes String? @map("internal_notes")
  supplierNotes String? @map("supplier_notes")
  attachmentCount Int @default(0) @map("attachment_count")

  version Int @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String? @map("created_by") @db.Uuid
  updatedBy String? @map("updated_by") @db.Uuid

  @@unique([tenantId, poNumber], map: "uq_po_tenant_number")
  @@index([tenantId, status], map: "idx_po_tenant_status")
  @@index([tenantId, supplierId], map: "idx_po_tenant_supplier")
  @@index([tenantId, plantId], map: "idx_po_tenant_plant")
  @@index([tenantId, poDate], map: "idx_po_tenant_date")
  @@index([tenantId, poType], map: "idx_po_tenant_type")
  @@index([tenantId, quotationId], map: "idx_po_tenant_quotation")
  @@index([tenantId, rfqId], map: "idx_po_tenant_rfq")
  @@index([tenantId, prId], map: "idx_po_tenant_pr")
  @@index([tenantId, expectedDeliveryDate], map: "idx_po_tenant_expected_delivery")
  @@index([tenantId, supplierAckStatus], map: "idx_po_tenant_ack_status")
  @@map("purchase_orders")
}

model PurchaseOrderLine {
  id String @id @default(uuid()) @db.Uuid
  tenantId String @map("tenant_id") @db.Uuid
  poId String @map("po_id") @db.Uuid
  lineNo Int @map("line_no")
  productId String @map("product_id") @db.Uuid
  productSku String @map("product_sku")
  productName String @map("product_name")
  productDescription String? @map("product_description")
  categoryId String? @map("category_id") @db.Uuid
  categoryName String? @map("category_name")
  uomId String @map("uom_id") @db.Uuid
  uomCode String @map("uom_code")
  orderedQty Decimal @map("ordered_qty") @db.Decimal(14, 3)
  receivedQty Decimal? @map("received_qty") @db.Decimal(14, 3)
  pendingQty Decimal? @map("pending_qty") @db.Decimal(14, 3)
  rejectedQty Decimal? @map("rejected_qty") @db.Decimal(14, 3)
  unitPrice Decimal @map("unit_price") @db.Decimal(14, 4)
  basePrice Decimal? @map("base_price") @db.Decimal(14, 4)
  discountPercent Decimal? @map("discount_percent") @db.Decimal(5, 2)
  discountAmount Decimal? @map("discount_amount") @db.Decimal(14, 2)
  taxPercent Decimal? @map("tax_percent") @db.Decimal(5, 2)
  taxAmount Decimal? @map("tax_amount") @db.Decimal(14, 2)
  lineTotal Decimal @default(0) @map("line_total") @db.Decimal(14, 2)
  currency String @default("INR")
  expectedDeliveryDate DateTime? @map("expected_delivery_date")
  leadTimeDays Int? @map("lead_time_days")
  deliveryLocation String? @map("delivery_location")
  minOrderQty Decimal? @map("min_order_qty") @db.Decimal(14, 3)
  maxOrderQty Decimal? @map("max_order_qty") @db.Decimal(14, 3)
  moqViolated Boolean? @default(false) @map("moq_violated")
  rfqLineId String? @map("rfq_line_id") @db.Uuid
  quotationLineId String? @map("quotation_line_id") @db.Uuid
  prLineId String? @map("pr_line_id") @db.Uuid
  isRevised Boolean? @default(false) @map("is_revised")
  revisionNotes String? @map("revision_notes")
  remarks String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([poId], map: "idx_pol_po")
  @@index([productId], map: "idx_pol_product")
  @@index([tenantId, productId], map: "idx_pol_tenant_product")
  @@map("purchase_order_lines")
}

model PurchaseOrderTax {
  id String @id @default(uuid()) @db.Uuid
  tenantId String @map("tenant_id") @db.Uuid
  poId String @map("po_id") @db.Uuid
  poLineId String? @map("po_line_id") @db.Uuid
  taxType String @map("tax_type")
  taxName String @map("tax_name")
  taxPercent Decimal @map("tax_percent") @db.Decimal(5, 2)
  taxableAmount Decimal @map("taxable_amount") @db.Decimal(14, 2)
  taxAmount Decimal @map("tax_amount") @db.Decimal(14, 2)
  isRecoverable Boolean? @default(true) @map("is_recoverable")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([poId], map: "idx_pot_po")
  @@index([poLineId], map: "idx_pot_po_line")
  @@map("purchase_order_taxes")
}

model PurchaseOrderCharge {
  id String @id @default(uuid()) @db.Uuid
  tenantId String @map("tenant_id") @db.Uuid
  poId String @map("po_id") @db.Uuid
  chargeType String @map("charge_type")
  chargeName String @map("charge_name")
  amount Decimal @db.Decimal(14, 2)
  percent Decimal? @db.Decimal(5, 2)
  isTaxable Boolean? @default(false) @map("is_taxable")
  taxPercent Decimal? @default(0) @map("tax_percent") @db.Decimal(5, 2)
  taxAmount Decimal? @default(0) @map("tax_amount") @db.Decimal(14, 2)
  glAccount String? @map("gl_account")
  remarks String?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([poId], map: "idx_poc_po")
  @@map("purchase_order_charges")
}

model PurchaseOrderAttachment {
  id String @id @default(uuid()) @db.Uuid
  tenantId String @map("tenant_id") @db.Uuid
  poId String @map("po_id") @db.Uuid
  fileName String @map("file_name")
  fileType String @map("file_type")
  fileSize BigInt @map("file_size")
  fileUrl String @map("file_url")
  category String @default("GENERAL")
  uploadedBy String? @map("uploaded_by") @db.Uuid
  uploadedByName String? @map("uploaded_by_name")
  isSigned Boolean? @default(false) @map("is_signed")
  signedBy String? @map("signed_by") @db.Uuid
  signedAt DateTime? @map("signed_at")
  remarks String?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([poId], map: "idx_poa_po")
  @@map("purchase_order_attachments")
}

model PurchaseOrderTerm {
  id String @id @default(uuid()) @db.Uuid
