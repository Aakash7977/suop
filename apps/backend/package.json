{
  "name": "@suop/backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "src/main.ts",
  "scripts": {
    "dev": "bash scripts/start-dev.sh",
    "dev:raw": "bun --watch src/main.ts",
    "start": "bash scripts/start-dev.sh",
    "build": "bun build src/main.ts --target=bun --outdir dist",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prisma:validate": "unset DATABASE_URL && prisma validate",
    "prisma:format": "unset DATABASE_URL && prisma format",
    "prisma:generate": "unset DATABASE_URL && prisma generate",
    "prisma:migrate": "unset DATABASE_URL && prisma migrate dev",
    "prisma:studio": "unset DATABASE_URL && prisma studio"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.5.4",
    "@hono/zod-validator": "^0.8.0",
    "@prisma/client": "^6.11.1",
    "argon2": "^0.44.0",
    "hono": "^4.12.29",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "uuid": "^14.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/ioredis": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/uuid": "^11.0.0",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.16.0",
    "openapi-types": "^12.1.3",
    "prisma": "^6.11.1",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
