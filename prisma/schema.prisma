// ─── Epic 1: Cross Docking Engine ───────────────────────
model CrossDockOrder {
  id                  String   @id @default(uuid()) @db.Uuid
  crossDockNumber     String   @unique @map("cross_dock_number")
  // ─── Type ───
  crossDockType       String   @map("cross_dock_type") // PRE_DISTRIBUTIVE (supplier → outbound), POST_DISTRIBUTIVE (consolidation), OPPORTUNISTIC (auto-detected)
  // ─── Inbound ───
  inboundShipmentId   String?  @db.Uuid @map("inbound_shipment_id")
  inboundShipmentNumber String? @map("inbound_shipment_number")
  asnId               String?  @db.Uuid @map("asn_id")
  asnNumber           String?  @map("asn_number")
  supplierId          String?  @db.Uuid @map("supplier_id")
  supplierName        String?  @map("supplier_name")
  // ─── Outbound ───
  outboundOrderType   String   @map("outbound_order_type") // SALES_ORDER, TRANSFER_ORDER, RETAIL_REPLENISHMENT, RESTAURANT_REPLENISHMENT, DISTRIBUTOR_ORDER
  outboundOrderNumber String   @map("outbound_order_number")
  outboundOrderId     String?  @db.Uuid @map("outbound_order_id")
  partnerId           String?  @db.Uuid @map("partner_id")
  partnerName         String?  @map("partner_name")
  // ─── Scope ───
  warehouseId         String   @db.Uuid @map("warehouse_id")
  warehouseName       String   @map("warehouse_name")
  inboundDockId       String?  @db.Uuid @map("inbound_dock_id")
  inboundDockCode     String?  @map("inbound_dock_code")
  outboundDockId      String?  @db.Uuid @map("outbound_dock_id")
  outboundDockCode    String?  @map("outbound_dock_code")
  // ─── Rule Matched ───
  ruleId              String?  @db.Uuid @map("rule_id")
  ruleCode            String?  @map("rule_code")
  ruleName            String?  @map("rule_name")
  // ─── Priority ───
  priority            String   @default("NORMAL") // EMERGENCY, HIGH, NORMAL, LOW
  // ─── Schedule ───
  expectedInboundAt   DateTime? @map("expected_inbound_at")
  actualInboundAt     DateTime? @map("actual_inbound_at")
  expectedOutboundAt  DateTime? @map("expected_outbound_at")
  actualOutboundAt    DateTime? @map("actual_outbound_at")
  completedAt         DateTime? @map("completed_at")
  // ─── Status ───
  status              String   @default("PLANNED") // PLANNED, INBOUND_ARRIVED, CROSS_DOCK_IN_PROGRESS, OUTBOUND_LOADED, DISPATCHED, COMPLETED, CANCELLED, EXCEPTION
  // ─── Metrics ───
  totalLines          Int      @default(0) @map("total_lines")
  totalQty            Decimal  @db.Decimal(18, 4) @default(0) @map("total_qty")
  totalWeightKg       Decimal  @db.Decimal(12, 2) @default(0) @map("total_weight_kg")
  // ─── Storage Avoidance ───
  storageAvoided      Boolean  @default(true) @map("storage_avoided")
  handlingCostSaved   Decimal? @db.Decimal(10, 2) @map("handling_cost_saved")
  timeSavedMinutes    Int?     @map("time_saved_minutes")
  // ─── Audit ───
  createdById         String?  @db.Uuid @map("created_by_id")
  createdByName       String?  @map("created_by_name")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  tasks               CrossDockTask[]

  @@map("cross_dock_orders")
  @@index([warehouseId, status], map: "idx_cdo_wh_status")
  @@index([crossDockType, status], map: "idx_cdo_type_status")
  @@index([outboundOrderNumber], map: "idx_cdo_outbound")
  @@index([status, priority], map: "idx_cdo_status_priority")
}

model CrossDockTask {
  id                  String   @id @default(uuid()) @db.Uuid
  taskNumber          String   @unique @map("task_number")
  crossDockOrderId    String   @db.Uuid @map("cross_dock_order_id")
  crossDockNumber     String   @map("cross_dock_number")
  // ─── Product ───
  productId           String   @db.Uuid @map("product_id")
  productSku          String   @map("product_sku")
  productName         String   @map("product_name")
  batchId             String?  @db.Uuid @map("batch_id")
  batchNumber         String?  @map("batch_number")
  // ─── Qty ───
  plannedQty          Decimal  @db.Decimal(18, 4) @default(0) @map("planned_qty")
  actualQty           Decimal  @db.Decimal(18, 4) @default(0) @map("actual_qty")
  uom                 String   @map("uom")
  // ─── Movement ───
  fromDockCode        String   @map("from_dock_code")
  toDockCode          String   @map("to_dock_code")
  fromPalletId        String?  @db.Uuid @map("from_pallet_id")
  toPalletId          String?  @db.Uuid @map("to_pallet_id")
  // ─── Assignment ───
  assignedOperatorId  String?  @db.Uuid @map("assigned_operator_id")
  assignedOperatorName String? @map("assigned_operator_name")
  assignedEquipmentId String?  @db.Uuid @map("assigned_equipment_id")
  assignedEquipmentCode String? @map("assigned_equipment_code")
  // ─── Scan Verification ───
  inboundScanVerified Boolean  @default(false) @map("inbound_scan_verified")
  outboundScanVerified Boolean @default(false) @map("outbound_scan_verified")
  // ─── Status ───
  status              String   @default("OPEN") // OPEN, IN_PROGRESS, COMPLETED, SHORT, CANCELLED
  startedAt           DateTime? @map("started_at")
  completedAt         DateTime? @map("completed_at")
  durationSeconds     Int?     @map("duration_seconds")
  // ─── Audit ───
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  crossDockOrder      CrossDockOrder @relation(fields: [crossDockOrderId], references: [id], onDelete: Cascade)

  @@map("cross_dock_tasks")
  @@index([crossDockOrderId], map: "idx_cdt_cdo")
  @@index([status], map: "idx_cdt_status")
  @@index([assignedOperatorId, status], map: "idx_cdt_op_status")
}

// ─── Epic 2: Yard Management ────────────────────────────
model YardLocation {
  id                  String   @id @default(uuid()) @db.Uuid
