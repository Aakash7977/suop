  overheadCost        Decimal  @db.Decimal(14, 2) @default(0) @map("overhead_cost")
  // ─── Total ───
  totalPackagingCost  Decimal  @db.Decimal(14, 2) @default(0) @map("total_packaging_cost")
  // ─── Per Unit ───
