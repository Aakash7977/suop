  qtyDispatched       Decimal  @db.Decimal(18, 4) @default(0) @map("qty_dispatched")
  qtyReturned         Decimal  @db.Decimal(18, 4) @default(0) @map("qty_returned")
  qtyInTransit        Decimal  @db.Decimal(18, 4) @default(0) @map("qty_in_transit")
  qtyAtDistributor    Decimal  @db.Decimal(18, 4) @default(0) @map("qty_at_distributor")
  qtyAtRetail         Decimal  @db.Decimal(18, 4) @default(0) @map("qty_at_retail")
  // ─── Notifications ───
