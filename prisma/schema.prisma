// ─── Epic 1: Waste Classification Master ────────────────────────────────
model WasteCategory {
  id                  String   @id @default(uuid()) @db.Uuid
  categoryCode        String   @unique @map("category_code") // PROC, QUAL, PACK, MAT, UTIL, CLEAN, FOOD, HAZ, GEN
  categoryName        String   @map("category_name")
  // ─── Classification ───
  wasteType           String   @map("waste_type") // PROCESS_WASTE, QUALITY_WASTE, PACKAGING_WASTE, MATERIAL_WASTE, UTILITY_WASTE, CLEANING_WASTE, FOOD_WASTE, HAZARDOUS_WASTE, GENERAL_WASTE
  description         String?
  // ─── Handling ───
  defaultDisposition  String   @default("DISPOSE") @map("default_disposition") // REUSE, REWORK, SELL, DESTROY, DISPOSE, DONATE
  isRecoverable       Boolean  @default(false) @map("is_recoverable")
  isByProductSource   Boolean  @default(false) @map("is_by_product_source")
  // ─── Accounting ───
  costImpact          String   @default("MATERIAL_LOSS") @map("cost_impact") // MATERIAL_LOSS, LABOR_LOSS, MACHINE_LOSS, ENERGY_LOSS, PACKAGING_LOSS
  // ─── Status ───
  status              String   @default("ACTIVE")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  records             WasteRecord[]

  @@map("waste_categories")
  @@index([wasteType, status], map: "idx_wc45_type_status")
  @@index([defaultDisposition], map: "idx_wc45_disposition")
}

model WasteRecord {
  id                  String   @id @default(uuid()) @db.Uuid
  recordCode          String   @unique @map("record_code") // WR-2026-000001
  // ─── Links ───
  productionBatchNumber String?  @map("production_batch_number")
  productionOrderNumber String? @map("production_order_number")
  workOrderNumber     String?  @map("work_order_number")
  packagingOrderNumber String? @map("packaging_order_number")
  // ─── Product ───
  productId           String?  @db.Uuid @map("product_id")
  productSku          String?  @map("product_sku")
  productName         String?  @map("product_name")
  // ─── Category ───
  categoryId          String?  @db.Uuid @map("category_id")
  categoryCode        String   @map("category_code")
  categoryName        String   @map("category_name")
  wasteType           String   @map("waste_type")
  // ─── Specific Reason ───
  lossReason          String   @map("loss_reason") // COOKING_LOSS, MOISTURE_LOSS, BURNT_PRODUCT, BROKEN_PRODUCT, PACKAGING_DAMAGE, EXPIRED_MATERIAL, CLEANING_WASTE, SAMPLING_LOSS, REJECTED_BATCH, OPERATOR_ERROR, MACHINE_FAILURE, UTILITY_LOSS
  lossDescription     String?  @map("loss_description")
  // ─── Quantity ───
  inputQty            Decimal? @db.Decimal(14, 3) @map("input_qty")
  lostQty             Decimal  @db.Decimal(14, 3) @map("lost_qty")
  recoveredQty        Decimal  @db.Decimal(14, 3) @default(0) @map("recovered_qty")
  uom                 String   @default("KG") @map("uom")
  // ─── Cost ───
  materialCost        Decimal  @db.Decimal(14, 2) @default(0) @map("material_cost")
  laborCost           Decimal  @db.Decimal(14, 2) @default(0) @map("labor_cost")
  machineCost         Decimal  @db.Decimal(14, 2) @default(0) @map("machine_cost")
  energyCost          Decimal  @db.Decimal(14, 2) @default(0) @map("energy_cost")
  packagingCost       Decimal  @db.Decimal(14, 2) @default(0) @map("packaging_cost")
  totalWasteCost      Decimal  @db.Decimal(14, 2) @default(0) @map("total_waste_cost")
  // ─── Disposition ───
  disposition         String   @default("DISPOSE") @map("disposition") // REUSE, REWORK, SELL, DESTROY, DISPOSE, DONATE
  dispositionReason   String?  @map("disposition_reason")
  // ─── Location ───
  plantCode           String?  @map("plant_code")
  productionLineCode  String?  @map("production_line_code")
  workCenterCode      String?  @map("work_center_code")
  machineCode         String?  @map("machine_code")
  // ─── Operator ───
  operatorId          String?  @db.Uuid @map("operator_id")
  operatorName        String?  @map("operator_name")
  shiftCode           String?  @map("shift_code")
  // ─── Audit ───
  recordedAt          DateTime @default(now()) @map("recorded_at")
  createdById         String?  @db.Uuid @map("created_by_id")
  createdByName       String?  @map("created_by_name")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  category            WasteCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@map("waste_records")
  @@index([productionBatchNumber], map: "idx_wr45_batch")
  @@index([categoryCode, wasteType], map: "idx_wr45_category")
  @@index([lossReason], map: "idx_wr45_reason")
  @@index([disposition], map: "idx_wr45_disposition")
  @@index([recordedAt], map: "idx_wr45_time")
}

