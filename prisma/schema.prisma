// ═══════════════════════════════════════════════════════════
// SPRINT 21 — INVENTORY ANALYTICS, AI INSIGHTS & MISSION CONTROL
// Executive decision platform for inventory management
// ═══════════════════════════════════════════════════════════

// ─── Epic 2: Inventory KPIs ─────────────────────────────
model InventoryKPI {
  id              String   @id @default(uuid()) @db.Uuid
  kpiCode         String   @unique @map("kpi_code")
  kpiName         String   @map("kpi_name")
  description     String?
  // ─── Value ───
  kpiValue        Decimal  @db.Decimal(18, 4) @map("kpi_value")
  kpiUnit         String   @default("PERCENT") @map("kpi_unit") // PERCENT, COUNT, DAYS, RUPEES, RATIO
  previousValue   Decimal? @db.Decimal(18, 4) @map("previous_value")
  trendDirection  String?  @map("trend_direction") // UP, DOWN, STABLE
  trendPercent    Decimal? @db.Decimal(8, 2) @map("trend_percent")
  // ─── Target ───
  targetValue     Decimal? @db.Decimal(18, 4) @map("target_value")
  isOnTarget      Boolean? @map("is_on_target")
  // ─── Period ───
  periodType      String   @map("period_type") // DAILY, WEEKLY, MONTHLY, YEARLY
  periodDate      DateTime @map("period_date")
  // ─── Scope ───
  warehouseId     String?  @db.Uuid @map("warehouse_id")
  warehouseName   String?  @map("warehouse_name")
  // ─── Category ───
  kpiCategory     String   @map("kpi_category") // TURNOVER, ACCURACY, AVAILABILITY, UTILIZATION, QUALITY, FINANCIAL
  // ─── Audit ───
  calculatedAt    DateTime @default(now()) @map("calculated_at")
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("inventory_kpis")
  @@index([kpiCode, periodDate], map: "idx_ik_kpi_date")
  @@index([periodType, periodDate], map: "idx_ik_period_date")
  @@index([warehouseId], map: "idx_ik_warehouse")
  @@index([kpiCategory], map: "idx_ik_category")
}

// ─── Epic 3: Inventory Ageing ──────────────────────────
model InventoryAgeing {
  id              String   @id @default(uuid()) @db.Uuid
  // ─── Item ───
  productId       String   @db.Uuid @map("product_id")
  productName     String   @map("product_name")
  productCategoryId String? @db.Uuid @map("product_category_id")
  brandId         String?  @db.Uuid @map("brand_id")
  // ─── Scope ───
  warehouseId     String?  @db.Uuid @map("warehouse_id")
  warehouseName   String?  @map("warehouse_name")
  // ─── Age buckets ───
  qty0to30        Decimal  @db.Decimal(18, 4) @default(0) @map("qty_0_30")
  value0to30      Decimal  @db.Decimal(18, 2) @default(0) @map("value_0_30")
  qty31to60       Decimal  @db.Decimal(18, 4) @default(0) @map("qty_31_60")
  value31to60     Decimal  @db.Decimal(18, 2) @default(0) @map("value_31_60")
  qty61to90       Decimal  @db.Decimal(18, 4) @default(0) @map("qty_61_90")
  value61to90     Decimal  @db.Decimal(18, 2) @default(0) @map("value_61_90")
  qty91to180      Decimal  @db.Decimal(18, 4) @default(0) @map("qty_91_180")
  value91to180    Decimal  @db.Decimal(18, 2) @default(0) @map("value_91_180")
  qty181to365     Decimal  @db.Decimal(18, 4) @default(0) @map("qty_181_365")
  value181to365   Decimal  @db.Decimal(18, 2) @default(0) @map("value_181_365")
  qty365plus      Decimal  @db.Decimal(18, 4) @default(0) @map("qty_365_plus")
  value365plus    Decimal  @db.Decimal(18, 2) @default(0) @map("value_365_plus")
  // ─── Totals ───
  totalQty        Decimal  @db.Decimal(18, 4) @default(0) @map("total_qty")
  totalValue      Decimal  @db.Decimal(18, 2) @default(0) @map("total_value")
  avgDaysInStock  Int      @default(0) @map("avg_days_in_stock")
  // ─── Snapshot ───
  snapshotDate    DateTime @map("snapshot_date")
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("inventory_ageing")
  @@index([productId, warehouseId], map: "idx_iag_product_wh")
  @@index([warehouseId, snapshotDate], map: "idx_iag_wh_date")
  @@index([snapshotDate], map: "idx_iag_date")
}

// ─── Epic 4/5/6: ABC/XYZ/FSN Classification ────────────
model InventoryClassification {
  id              String   @id @default(uuid()) @db.Uuid
  productId       String   @db.Uuid @map("product_id")
  productName     String   @map("product_name")
  // ─── ABC ───
  abcClass        String   @map("abc_class") // A, B, C
  abcValuePercent Decimal  @db.Decimal(8, 2) @map("abc_value_percent") // % of total inventory value
  abcCumulativePercent Decimal @db.Decimal(8, 2) @map("abc_cumulative_percent")
  // ─── XYZ ───
  xyzClass        String   @map("xyz_class") // X (stable), Y (seasonal), Z (irregular)
  xyzDemandVariability Decimal @db.Decimal(8, 2) @map("xyz_demand_variability") // coefficient of variation
  // ─── FSN ───
  fsnClass        String   @map("fsn_class") // FAST_MOVING, SLOW_MOVING, NON_MOVING
  fsnDaysSinceLastMovement Int @map("fsn_days_since_last_movement")
  fsnTransactionCount Int   @map("fsn_transaction_count")
  // ─── Combined ───
  combinedClass   String   @map("combined_class") // e.g., AX, BY, CZ, AZ, etc.
  // ─── Scope ───
  warehouseId     String?  @db.Uuid @map("warehouse_id")
  warehouseName   String?  @map("warehouse_name")
  // ─── Period ───
  classificationDate DateTime @map("classification_date")
  periodType      String   @map("period_type") // MONTHLY, QUARTARTERLY, YEARLY
  // ─── Audit ───
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("inventory_classifications")
  @@index([productId, warehouseId], map: "idx_icl2_product_wh")
  @@index([abcClass], map: "idx_icl2_abc")
  @@index([xyzClass], map: "idx_icl2_xyz")
  @@index([fsnClass], map: "idx_icl2_fsn")
  @@index([combinedClass], map: "idx_icl2_combined")
  @@index([classificationDate], map: "idx_icl2_date")
}

// ─── Epic 7: Reorder Intelligence ──────────────────────
model ReorderRule {
  id              String   @id @default(uuid()) @db.Uuid
  productId       String   @db.Uuid @map("product_id")
  productName     String   @map("product_name")
  warehouseId     String?  @db.Uuid @map("warehouse_id")
  warehouseName   String?  @map("warehouse_name")
  // ─── Reorder parameters ───
  minStock        Decimal  @db.Decimal(18, 4) @map("min_stock")
  maxStock        Decimal  @db.Decimal(18, 4) @map("max_stock")
  safetyStock     Decimal  @db.Decimal(18, 4) @map("safety_stock")
  reorderPoint    Decimal  @db.Decimal(18, 4) @map("reorder_point")
  economicOrderQty Decimal? @db.Decimal(18, 4) @map("economic_order_qty")
  // ─── Lead time ───
  leadTimeDays    Int      @map("lead_time_days")
  supplierId      String?  @db.Uuid @map("supplier_id")
  supplierName    String?  @map("supplier_name")
  // ─── Consumption ───
  avgDailyConsumption Decimal @db.Decimal(18, 4) @default(0) @map("avg_daily_consumption")
  avgWeeklyConsumption Decimal @db.Decimal(18, 4) @default(0) @map("avg_weekly_consumption")
  avgMonthlyConsumption Decimal @db.Decimal(18, 4) @default(0) @map("avg_monthly_consumption")
  // ─── Current status ───
  currentStock    Decimal  @db.Decimal(18, 4) @default(0) @map("current_stock")
  availableStock  Decimal  @db.Decimal(18, 4) @default(0) @map("available_stock")
  inTransitQty    Decimal  @db.Decimal(18, 4) @default(0) @map("in_transit_qty")
  // ─── Reorder suggestion ───
  reorderRequired Boolean  @default(false) @map("reorder_required")
  suggestedQty    Decimal? @db.Decimal(18, 4) @map("suggested_qty")
  daysOfSupply    Int?     @map("days_of_supply") // how many days current stock will last
  urgencyLevel    String?  @map("urgency_level") // CRITICAL, HIGH, MEDIUM, LOW, OK
  // ─── Status ───
  status          String   @default("ACTIVE")
  lastCalculatedAt DateTime? @map("last_calculated_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("reorder_rules")
  @@index([productId, warehouseId], map: "idx_rr_product_wh")
  @@index([reorderRequired, urgencyLevel], map: "idx_rr_reorder_urgency")
  @@index([urgencyLevel], map: "idx_rr_urgency")
  @@index([status], map: "idx_rr_status")
}

// ─── Epic 1: Mission Control Snapshot ──────────────────
model MissionControlSnapshot {
  id              String   @id @default(uuid()) @db.Uuid
  snapshotDate    DateTime @map("snapshot_date")
  // ─── Overall ───
  totalInventoryValue Decimal @db.Decimal(18, 2) @map("total_inventory_value")
  totalProducts   Int      @map("total_products")
  totalWarehouses Int      @map("total_warehouses")
  totalBatches    Int      @map("total_batches")
  // ─── Today's activity ───
  todayTransactions Int    @map("today_transactions")
  todayReceipts   Int      @map("today_receipts")
  todayIssues     Int      @map("today_issues")
  todayTransfers  Int      @map("today_transfers")
  todayAdjustments Int     @map("today_adjustments")
  // ─── Pending ───
  pendingApprovals Int     @map("pending_approvals")
  pendingPutaway  Int      @map("pending_putaway")
  pendingPicking  Int      @map("pending_picking")
  pendingReceiving Int     @map("pending_receiving")
  // ─── Alerts ───
  expiredStock    Int      @map("expired_stock")
  nearExpiryStock Int      @map("near_expiry_stock")
  blockedBatches  Int      @map("blocked_batches")
  quarantinedStock Int     @map("quarantined_stock")
  deadStockItems  Int      @map("dead_stock_items")
  stockOutItems   Int      @map("stock_out_items")
  reorderRequired Int      @map("reorder_required")
  // ─── KPIs ───
  inventoryAccuracy Decimal @db.Decimal(5, 2) @map("inventory_accuracy")
  warehouseUtilization Decimal @db.Decimal(5, 2) @map("warehouse_utilization")
  stockAvailability Decimal @db.Decimal(5, 2) @map("stock_availability")
  orderFillRate   Decimal  @db.Decimal(5, 2) @map("order_fill_rate")
  inventoryTurnover Decimal @db.Decimal(8, 2) @map("inventory_turnover")
  // ─── Recalls ───
  activeRecalls   Int      @map("active_recalls")
  // ─── Audit ───
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("mission_control_snapshots")
  @@index([snapshotDate], map: "idx_mcs_date")
}

// ─── Epic 8: Executive Reports ─────────────────────────
model ExecutiveReport {
  id              String   @id @default(uuid()) @db.Uuid
  reportCode      String   @unique @map("report_code")
  reportName      String   @map("report_name")
  reportType      String   @map("report_type") // INVENTORY_VALUATION, STOCK_AGEING, ABC_REPORT, XYZ_REPORT, FSN_REPORT, DEAD_STOCK, NEAR_EXPIRY, WAREHOUSE_COMPARISON, INVENTORY_ACCURACY, COST_ANALYSIS
  description     String?
  // ─── Parameters ───
  parameters      Json     @default("{}")
  // ─── Format ───
  exportFormat    String   @default("PDF") @map("export_format") // PDF, EXCEL, CSV, POWERPOINT
  // ─── Result ───
  fileUrl         String?  @map("file_url")
  fileSizeBytes   Int?     @map("file_size_bytes")
  // ─── Status ───
  status          String   @default("PENDING") // PENDING, GENERATING, COMPLETED, FAILED, EXPIRED
  generatedAt     DateTime? @map("generated_at")
  // ─── Summary ───
  summaryData     Json?    @map("summary_data")
  // ─── Audit ───
  requestedById   String?  @db.Uuid @map("requested_by_id")
  requestedByName String?  @map("requested_by_name")
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("executive_reports")
  @@index([reportType, status], map: "idx_er_type_status")
  @@index([status], map: "idx_er_status")
  @@index([createdAt], map: "idx_er_date")
}

// ═══════════════════════════════════════════════════════════
// SPRINT 22 — WAREHOUSE FOUNDATION (PART 4 BEGINS)
// Multi-warehouse architecture, zones, capacity, temperature
// ═══════════════════════════════════════════════════════════

// ─── Epic 1: Warehouse Master ──────────────────────────
model WarehouseMaster {
  id              String   @id @default(uuid()) @db.Uuid
  warehouseCode   String   @unique @map("warehouse_code")
  warehouseName   String   @map("warehouse_name")
  description     String?
  // ─── Type ───
  warehouseType   String   @map("warehouse_type") // RAW_MATERIAL, FINISHED_GOODS, PACKAGING, COLD_STORAGE, DEEP_FREEZE, RETURNS, TRANSIT, QUARANTINE, SCRAP, DISTRIBUTION_CENTER, DARK_STORE
  // ─── Hierarchy ───
  companyId       String?  @db.Uuid @map("company_id")
  companyName     String?  @map("company_name")
  branchId        String?  @db.Uuid @map("branch_id")
  branchName      String?  @map("branch_name")
  // ─── Manager ───
  managerId       String?  @db.Uuid @map("manager_id")
  managerName     String?  @map("manager_name")
  // ─── Address ───
  addressLine1    String?  @map("address_line_1")
  addressLine2    String?  @map("address_line_2")
  city            String?
  state           String?
  country         String   @default("India")
  pincode         String?
  // ─── Contact ───
  phone           String?
  email           String?
  // ─── Configuration ───
  timezone        String   @default("Asia/Kolkata")
  barcodeEnabled  Boolean  @default(true) @map("barcode_enabled")
  fifoEnabled     Boolean  @default(false) @map("fifo_enabled")
  fefoEnabled     Boolean  @default(true) @map("fefo_enabled")
  qualityInspectionRequired Boolean @default(true) @map("quality_inspection_required")
  defaultPickingStrategy String @default("FEFO") @map("default_picking_strategy")
  defaultPutawayStrategy String @default("FEFO") @map("default_putaway_strategy")
  defaultUom      String?  @map("default_uom")
  // ─── Capacity ───
  totalVolumeM3   Decimal? @db.Decimal(12, 2) @map("total_volume_m3")
  totalWeightKg   Decimal? @db.Decimal(12, 2) @map("total_weight_kg")
  totalPalletPositions Int? @map("total_pallet_positions")
  totalBins       Int?     @map("total_bins")
  // ─── Operating hours ───
  operatingHoursStart String @default("08:00") @map("operating_hours_start")
  operatingHoursEnd   String @default("20:00") @map("operating_hours_end")
  workingDays     String   @default("MON,TUE,WED,THU,FRI,SAT") @map("working_days")
  // ─── Status ───
  status          String   @default("ACTIVE") // ACTIVE, INACTIVE, MAINTENANCE, CLOSED
  statusReason    String?  @map("status_reason")
  // ─── Audit ───
  createdById     String?  @db.Uuid @map("created_by_id")
  createdByName   String?  @map("created_by_name")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  zones           WarehouseZone[]
  capacityRecords WarehouseCapacity[]
  temperatureZones TemperatureZone[]
  calendar        WarehouseCalendar[]
  rules           WarehouseRule[]
  accessRules     WarehouseAccessRule[]

  @@map("warehouse_master")
  @@index([warehouseType, status], map: "idx_wm_type_status")
  @@index([companyId, branchId], map: "idx_wm_company_branch")
  @@index([status], map: "idx_wm_status")
}

// ─── Epic 2: Warehouse Zones ───────────────────────────
model WarehouseZone {
  id              String   @id @default(uuid()) @db.Uuid
  warehouseId     String   @db.Uuid @map("warehouse_id")
  zoneCode        String   @map("zone_code")
  zoneName        String   @map("zone_name")
  description     String?
  // ─── Type ───
  zoneType        String   @map("zone_type") // RECEIVING, PUTAWAY, STORAGE, PICKING, PACKING, DISPATCH, RETURNS, QUARANTINE, QUALITY_INSPECTION, DAMAGED_GOODS
  // ─── Hierarchy ───
  parentZoneId    String?  @db.Uuid @map("parent_zone_id")
  displayOrder    Int      @default(100) @map("display_order")
  // ─── Temperature ───
  temperatureZoneId String? @db.Uuid @map("temperature_zone_id")
  // ─── Capacity ───
  volumeM3        Decimal? @db.Decimal(12, 2) @map("volume_m3")
  weightCapacityKg Decimal? @db.Decimal(12, 2) @map("weight_capacity_kg")
  palletPositions Int?     @map("pallet_positions")
  binCount        Int      @default(0) @map("bin_count")
  // ─── Access ───
  isRestricted    Boolean  @default(false) @map("is_restricted")
  accessRequired  Boolean  @default(false) @map("access_required")
  // ─── Status ───
  status          String   @default("ACTIVE")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  warehouse       WarehouseMaster @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@unique([warehouseId, zoneCode], map: "wz_unique_wh_zone")
  @@map("warehouse_zones")
  @@index([warehouseId, zoneType], map: "idx_wz_wh_type")
  @@index([zoneType, status], map: "idx_wz_type_status")
}

// ─── Epic 3: Temperature Zones ─────────────────────────
model TemperatureZone {
  id              String   @id @default(uuid()) @db.Uuid
  warehouseId     String   @db.Uuid @map("warehouse_id")
  zoneCode        String   @map("zone_code")
  zoneName        String   @map("zone_name")
  // ─── Type ───
  tempZoneType    String   @map("temp_zone_type") // AMBIENT, CHILLED, FROZEN, DEEP_FREEZE, HUMIDITY_CONTROLLED
  // ─── Configuration ───
  minTemperature  Decimal  @db.Decimal(5, 2) @map("min_temperature")
  maxTemperature  Decimal  @db.Decimal(5, 2) @map("max_temperature")
  targetTemperature Decimal? @db.Decimal(5, 2) @map("target_temperature")
  minHumidity     Decimal? @db.Decimal(5, 2) @map("min_humidity")
  maxHumidity     Decimal? @db.Decimal(5, 2) @map("max_humidity")
  targetHumidity  Decimal? @db.Decimal(5, 2) @map("target_humidity")
  // ─── Alert ───
  alertThresholdMin Decimal @db.Decimal(5, 2) @default(2) @map("alert_threshold_min")
  alertThresholdMax Decimal @db.Decimal(5, 2) @default(2) @map("alert_threshold_max")
  // ─── Monitoring ───
  isActive        Boolean  @default(true) @map("is_active")
  lastReading     Decimal? @db.Decimal(5, 2) @map("last_reading")
  lastReadingAt   DateTime? @map("last_reading_at")
  // ─── Status ───
  status          String   @default("ACTIVE")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  warehouse       WarehouseMaster @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  logs            TemperatureLog[]

  @@unique([warehouseId, zoneCode], map: "tz_unique_wh_zone")
  @@map("temperature_zones")
  @@index([warehouseId, tempZoneType], map: "idx_tz_wh_type")
  @@index([tempZoneType, status], map: "idx_tz_type_status")
}

model TemperatureLog {
  id              String   @id @default(uuid()) @db.Uuid
  temperatureZoneId String  @db.Uuid @map("temperature_zone_id")
  // ─── Reading ───
  temperature     Decimal  @db.Decimal(5, 2)
  humidity        Decimal? @db.Decimal(5, 2)
  // ─── Alert ───
  isAlert         Boolean  @default(false) @map("is_alert")
  alertType       String?  @map("alert_type") // HIGH_TEMP, LOW_TEMP, HIGH_HUMIDITY, LOW_HUMIDITY
  alertMessage    String?  @map("alert_message")
  // ─── Sensor ───
  sensorId        String?  @map("sensor_id")
  sensorLocation  String?  @map("sensor_location")
  // ─── Timestamp ───
  recordedAt      DateTime @map("recorded_at")
  createdAt       DateTime @default(now()) @map("created_at")

  temperatureZone TemperatureZone @relation(fields: [temperatureZoneId], references: [id], onDelete: Cascade)

  @@map("temperature_logs")
  @@index([temperatureZoneId, recordedAt], map: "idx_tl_zone_time")
  @@index([isAlert], map: "idx_tl_alert")
}

// ─── Epic 4: Warehouse Capacity ─────────────────────────
model WarehouseCapacity {
  id              String   @id @default(uuid()) @db.Uuid
  warehouseId     String   @db.Uuid @map("warehouse_id")
  zoneId          String?  @db.Uuid @map("zone_id")
  // ─── Capacity ───
  totalVolume     Decimal  @db.Decimal(12, 2) @default(0) @map("total_volume")
  usedVolume      Decimal  @db.Decimal(12, 2) @default(0) @map("used_volume")
  availableVolume Decimal  @db.Decimal(12, 2) @default(0) @map("available_volume")
  reservedVolume  Decimal  @db.Decimal(12, 2) @default(0) @map("reserved_volume")
  totalWeight     Decimal  @db.Decimal(12, 2) @default(0) @map("total_weight")
  usedWeight      Decimal  @db.Decimal(12, 2) @default(0) @map("used_weight")
  availableWeight Decimal  @db.Decimal(12, 2) @default(0) @map("available_weight")
  totalPallets    Int      @default(0) @map("total_pallets")
  usedPallets     Int      @default(0) @map("used_pallets")
  availablePallets Int     @default(0) @map("available_pallets")
  totalBins       Int      @default(0) @map("total_bins")
  usedBins        Int      @default(0) @map("used_bins")
  availableBins   Int      @default(0) @map("available_bins")
  // ─── Utilization ───
  utilizationPercent Decimal @db.Decimal(5, 2) @default(0) @map("utilization_percent")
  // ─── Snapshot ───
  snapshotDate    DateTime @map("snapshot_date")
  createdAt       DateTime @default(now()) @map("created_at")

  warehouse       WarehouseMaster @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@map("warehouse_capacity")
  @@index([warehouseId, snapshotDate], map: "idx_wc_wh_date")
  @@index([zoneId], map: "idx_wc_zone")
}

// ─── Epic 5: Warehouse Calendar ────────────────────────
model WarehouseCalendar {
  id              String   @id @default(uuid()) @db.Uuid
  warehouseId     String   @db.Uuid @map("warehouse_id")
  calendarDate    DateTime @map("calendar_date")
  // ─── Type ───
  dayType         String   @map("day_type") // WORKING_DAY, HOLIDAY, MAINTENANCE, SPECIAL
  // ─── Hours ───
  startTime       String?  @map("start_time")
  endTime         String?  @map("end_time")
  // ─── Shifts ───
  shift1Start     String?  @map("shift1_start")
  shift1End       String?  @map("shift1_end")
  shift2Start     String?  @map("shift2_start")
  shift2End       String?  @map("shift2_end")
  shift3Start     String?  @map("shift3_start")
  shift3End       String?  @map("shift3_end")
  // ─── Description ───
  description     String?
  // ─── Status ───
  isClosed        Boolean  @default(false) @map("is_closed")
  createdAt       DateTime @default(now()) @map("created_at")

  warehouse       WarehouseMaster @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@map("warehouse_calendar")
  @@index([warehouseId, calendarDate], map: "idx_wcal_wh_date")
}

// ─── Epic 6: Warehouse Security ────────────────────────
model WarehouseAccessRule {
  id              String   @id @default(uuid()) @db.Uuid
  warehouseId     String   @db.Uuid @map("warehouse_id")
  // ─── Access ───
  userRole        String   @map("user_role") // WAREHOUSE_MANAGER, SUPERVISOR, OPERATOR, FORKLIFT_OPERATOR, QUALITY_INSPECTOR, VISITOR
  // ─── Permissions ───
  canReceive      Boolean  @default(false) @map("can_receive")
  canPutaway      Boolean  @default(false) @map("can_putaway")
  canPick         Boolean  @default(false) @map("can_pick")
  canPack         Boolean  @default(false) @map("can_pack")
  canDispatch     Boolean  @default(false) @map("can_dispatch")
  canAdjust       Boolean  @default(false) @map("can_adjust")
  canCount        Boolean  @default(false) @map("can_count")
  canAccessRestricted Boolean @default(false) @map("can_access_restricted")
  canAccessColdStorage  Boolean @default(false) @map("can_access_cold_storage")
  // ─── Restricted zones ───
  restrictedZoneIds String[] @default([]) @map("restricted_zone_ids")
  // ─── Status ───
  status          String   @default("ACTIVE")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  warehouse       WarehouseMaster @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@map("warehouse_access_rules")
  @@index([warehouseId, userRole], map: "idx_war_wh_role")
  @@index([status], map: "idx_war_status")
}

// ─── Epic 7: Warehouse Rules ───────────────────────────
model WarehouseRule {
  id              String   @id @default(uuid()) @db.Uuid
  warehouseId     String   @db.Uuid @map("warehouse_id")
  ruleCode        String   @map("rule_code")
  ruleName        String   @map("rule_name")
  description     String?
  // ─── Rule ───
  ruleType        String   @map("rule_type") // MAX_BIN_WEIGHT, MAX_STACK_HEIGHT, HAZARDOUS_MATERIAL, FOOD_SAFETY, FIFO_ENABLED, FEFO_ENABLED, BARCODE_MANDATORY, QUALITY_INSPECTION_REQUIRED, MAX_PICK_TIME, PUTAWAY_RULE
  ruleValue       String   @map("rule_value")
  ruleUnit        String?  @map("rule_unit") // KG, M, HOURS, BOOLEAN, PERCENT
  // ─── Enforcement ───
  enforcementMode String   @default("WARN") @map("enforcement_mode") // BLOCK, WARN, LOG
  // ─── Status ───
  status          String   @default("ACTIVE")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  warehouse       WarehouseMaster @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@unique([warehouseId, ruleCode], map: "wr_unique_wh_rule")
  @@map("warehouse_rules")
  @@index([warehouseId, ruleType], map: "idx_wr_wh_type")
  @@index([ruleType, status], map: "idx_wr_type_status")
}

// ═══════════════════════════════════════════════════════════
// SPRINT 23 — WAREHOUSE LOCATION, BIN MANAGEMENT & DIGITAL MAP
// Zone → Aisle → Rack → Shelf → Bin hierarchy with barcodes
// ═══════════════════════════════════════════════════════════

// ─── Epic 2: Aisle Management ──────────────────────────
model WarehouseAisle {
  id              String   @id @default(uuid()) @db.Uuid
  warehouseId     String   @db.Uuid @map("warehouse_id")
  zoneId          String?  @db.Uuid @map("zone_id")
  aisleCode       String   @map("aisle_code")
  aisleName       String   @map("aisle_name")
  description     String?
  // ─── Physical ───
  lengthM         Decimal? @db.Decimal(8, 2) @map("length_m")
  widthM          Decimal? @db.Decimal(8, 2) @map("width_m")
  // ─── Traffic ───
  trafficDirection String  @default("TWO_WAY") @map("traffic_direction") // ONE_WAY, TWO_WAY, FORKLIFT_ONLY, WALKING_ONLY
  // ─── Status ───
  status          String   @default("ACTIVE")
  displayOrder    Int      @default(100) @map("display_order")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([warehouseId, aisleCode], map: "wa_unique_wh_aisle")
  @@map("warehouse_aisles")
  @@index([warehouseId, zoneId], map: "idx_wa_wh_zone")
  @@index([zoneId], map: "idx_wa_zone")
  @@index([status], map: "idx_wa_status")
}

// ─── Epic 3: Rack Management ───────────────────────────
model WarehouseRack {
  id              String   @id @default(uuid()) @db.Uuid
  warehouseId     String   @db.Uuid @map("warehouse_id")
  zoneId          String?  @db.Uuid @map("zone_id")
  aisleId         String   @db.Uuid @map("aisle_id")
  rackCode        String   @map("rack_code")
  rackName        String   @map("rack_name")
  description     String?
  // ─── Physical ───
  heightM         Decimal? @db.Decimal(8, 2) @map("height_m")
  widthM          Decimal? @db.Decimal(8, 2) @map("width_m")
  depthM          Decimal? @db.Decimal(8, 2) @map("depth_m")
  maxWeightKg     Decimal? @db.Decimal(12, 2) @map("max_weight_kg")
  shelfCount      Int      @default(1) @map("shelf_count")
  // ─── Safety ───
  fireZone        String?  @map("fire_zone")
  // ─── Status ───
  status          String   @default("ACTIVE")
  displayOrder    Int      @default(100) @map("display_order")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([warehouseId, rackCode], map: "wrk_unique_wh_rack")
  @@map("warehouse_racks")
  @@index([warehouseId, aisleId], map: "idx_wrk_wh_aisle")
  @@index([aisleId], map: "idx_wrk_aisle")
  @@index([zoneId], map: "idx_wrk_zone")
  @@index([status], map: "idx_wrk_status")
}

// ─── Epic 4: Shelf Management ──────────────────────────
model WarehouseShelf {
  id              String   @id @default(uuid()) @db.Uuid
  warehouseId     String   @db.Uuid @map("warehouse_id")
  rackId          String   @db.Uuid @map("rack_id")
  shelfCode       String   @map("shelf_code")
  shelfName       String   @map("shelf_name")
  // ─── Physical ───
  level           Int      @default(1) // 1 = bottom, higher = upper shelves
  heightFromFloor Decimal? @db.Decimal(8, 2) @map("height_from_floor")
  maxWeightKg     Decimal? @db.Decimal(12, 2) @map("max_weight_kg")
  maxVolumeM3     Decimal? @db.Decimal(12, 2) @map("max_volume_m3")
  // ─── Accessibility ───
  pickingLevel    String   @default("GROUND") @map("picking_level") // GROUND, MID, HIGH, TOP
  accessibility   String   @default("EASY") // EASY, MODERATE, DIFFICULT, LADDER_REQUIRED
  // ─── Status ───
  status          String   @default("ACTIVE")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([warehouseId, shelfCode], map: "wsh_unique_wh_shelf")
  @@map("warehouse_shelves")
  @@index([warehouseId, rackId], map: "idx_wsh_wh_rack")
  @@index([rackId], map: "idx_wsh_rack")
  @@index([status], map: "idx_wsh_status")
}

// ─── Epic 5: Bin Master ────────────────────────────────
model WarehouseBin {
  id              String   @id @default(uuid()) @db.Uuid
  warehouseId     String   @db.Uuid @map("warehouse_id")
  warehouseCode   String   @map("warehouse_code")
  zoneId          String?  @db.Uuid @map("zone_id")
  zoneCode        String?  @map("zone_code")
  aisleId         String?  @db.Uuid @map("aisle_id")
  aisleCode       String?  @map("aisle_code")
  rackId          String?  @db.Uuid @map("rack_id")
  rackCode        String?  @map("rack_code")
  shelfId         String?  @db.Uuid @map("shelf_id")
  shelfCode       String?  @map("shelf_code")
  // ─── Bin code (human readable) ───
  binCode         String   @map("bin_code") // e.g., A-05-03-12
  // ─── Barcode / QR ───
  barcode         String?  @unique
  qrCode          String?  @unique @map("qr_code")
  // ─── Capacity ───
  maxWeightKg     Decimal? @db.Decimal(12, 2) @map("max_weight_kg")
  maxVolumeM3     Decimal? @db.Decimal(12, 2) @map("max_volume_m3")
  currentWeightKg Decimal  @db.Decimal(12, 2) @default(0) @map("current_weight_kg")
  currentVolumeM3 Decimal  @db.Decimal(12, 2) @default(0) @map("current_volume_m3")
  // ─── Utilization ───
  utilizationPercent Decimal @db.Decimal(5, 2) @default(0) @map("utilization_percent")
  // ─── Temperature ───
  temperatureZone String?  @map("temperature_zone") // AMBIENT, CHILLED, FROZEN
  // ─── Type ───
  binType         String   @default("STANDARD") @map("bin_type") // STANDARD, BULK, PICK_FACE, CROSS_DOCK, QUARANTINE
  // ─── Status ───
  status          String   @default("AVAILABLE") // AVAILABLE, OCCUPIED, RESERVED, BLOCKED, MAINTENANCE, CLEANING, DISABLED
  statusReason    String?  @map("status_reason")
  // ─── Items ───
  itemCapacity    Int      @default(1) @map("item_capacity") // max distinct products
  currentItemTypes Int     @default(0) @map("current_item_types")
  // ─── Audit ───
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([warehouseId, binCode], map: "wb_unique_wh_bin")
  @@map("warehouse_bins")
  @@index([warehouseId, status], map: "idx_wb_wh_status")
  @@index([zoneId, aisleId, rackId, shelfId], map: "idx_wb_hierarchy")
  @@index([status], map: "idx_wb_status")
  @@index([binType], map: "idx_wb_type")
  @@index([temperatureZone], map: "idx_wb_temp")
  @@index([utilizationPercent], map: "idx_wb_utilization")
}

// ─── Epic 6: Bin Capacity Engine ───────────────────────
model BinCapacityLog {
  id              String   @id @default(uuid()) @db.Uuid
  binId           String   @db.Uuid @map("bin_id")
  binCode         String   @map("bin_code")
  warehouseId     String   @db.Uuid @map("warehouse_id")
  // ─── Snapshot ───
  currentWeightKg Decimal  @db.Decimal(12, 2) @map("current_weight_kg")
  currentVolumeM3 Decimal  @db.Decimal(12, 2) @map("current_volume_m3")
  maxWeightKg     Decimal  @db.Decimal(12, 2) @map("max_weight_kg")
  maxVolumeM3     Decimal  @db.Decimal(12, 2) @map("max_volume_m3")
  utilizationPercent Decimal @db.Decimal(5, 2) @map("utilization_percent")
  // ─── Alert ───
  alertType       String?  @map("alert_type") // FULL, OVERLOADED, UNDERUTILIZED, NEAR_FULL
  alertMessage    String?  @map("alert_message")
  // ─── Items ───
  itemTypes       Int      @default(0) @map("item_types")
  totalQuantity   Decimal  @db.Decimal(18, 4) @default(0) @map("total_quantity")
  // ─── Snapshot time ───
  snapshotAt      DateTime @default(now()) @map("snapshot_at")
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("bin_capacity_logs")
  @@index([binId, snapshotAt], map: "idx_bcl_bin_time")
  @@index([alertType], map: "idx_bcl_alert")
  @@index([warehouseId, snapshotAt], map: "idx_bcl_wh_time")
}

// ═══════════════════════════════════════════════════════════
// SPRINT 24 — RECEIVING OPERATIONS, DOCK MANAGEMENT & ASN ENGINE
// Physical warehouse receiving: truck → dock → verify → receive
// ═══════════════════════════════════════════════════════════

// ─── Epic 1: Advanced Shipping Notice (ASN) ────────────
model AdvancedShippingNotice {
  id              String   @id @default(uuid()) @db.Uuid
  asnNumber       String   @unique @map("asn_number")
  asnDate         DateTime @default(now()) @map("asn_date")
  expectedArrival DateTime @map("expected_arrival")
  // ─── Type ───
  receivingType   String   @map("receiving_type") // PURCHASE_ORDER, MANUFACTURING_RECEIPT, INTER_WAREHOUSE_TRANSFER, CUSTOMER_RETURN, SUPPLIER_REPLACEMENT, OPENING_STOCK, SAMPLE_DELIVERY, VENDOR_MANAGED_INVENTORY
  // ─── Supplier ───
  supplierId      String?  @db.Uuid @map("supplier_id")
  supplierName    String?  @map("supplier_name")
  // ─── Reference ───
  referenceType   String?  @map("reference_type")
  referenceNumber String?  @map("reference_number")
  // ─── Logistics ───
  vehicleNumber   String?  @map("vehicle_number")
  driverName      String?  @map("driver_name")
  driverPhone     String?  @map("driver_phone")
  carrierName     String?  @map("carrier_name")
  // ─── Warehouse ───
  warehouseId     String?  @db.Uuid @map("warehouse_id")
  warehouseName   String?  @map("warehouse_name")
  // ─── Status ───
  status          String   @default("DRAFT") // DRAFT, SUBMITTED, CONFIRMED, VEHICLE_ARRIVED, RECEIVING, COMPLETED, CANCELLED
  // ─── Summary ───
  totalLines      Int      @default(0) @map("total_lines")
  totalPallets    Int?     @map("total_pallets")
  totalCartons    Int?     @map("total_cartons")
  totalQuantity   Decimal  @db.Decimal(18, 4) @default(0) @map("total_quantity")
  totalWeight     Decimal? @db.Decimal(12, 2) @map("total_weight")
  totalVolume     Decimal? @db.Decimal(12, 2) @map("total_volume")
  // ─── Appointment ───
  appointmentId   String?  @db.Uuid @map("appointment_id")
  // ─── Audit ───
  createdById     String?  @db.Uuid @map("created_by_id")
  createdByName   String?  @map("created_by_name")
  confirmedAt     DateTime? @map("confirmed_at")
  completedAt     DateTime? @map("completed_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  lines           ASNLine[]
  appointment     ReceivingAppointment? @relation(fields: [appointmentId], references: [id])
  exceptions      ReceivingException[]

  @@map("advanced_shipping_notices")
  @@index([receivingType, status], map: "idx_asn_type_status")
  @@index([supplierId, expectedArrival], map: "idx_asn_supplier_date")
  @@index([warehouseId, status], map: "idx_asn_wh_status")
  @@index([status, expectedArrival], map: "idx_asn_status_date")
}

model ASNLine {
  id              String   @id @default(uuid()) @db.Uuid
  asnId           String   @db.Uuid @map("asn_id")
  lineOrder       Int      @map("line_order")
  // ─── Item ───
  productId       String   @db.Uuid @map("product_id")
  productName     String   @map("product_name")
  productVariantId String? @db.Uuid @map("product_variant_id")
  uomId           String?  @db.Uuid @map("uom_id")
  uomName         String?  @map("uom_name")
  // ─── Quantity ───
  expectedQty     Decimal  @db.Decimal(18, 4) @map("expected_qty")
  receivedQty     Decimal  @db.Decimal(18, 4) @default(0) @map("received_qty")
  // ─── Packaging ───
  palletCount     Int?     @map("pallet_count")
  cartonCount     Int?     @map("carton_count")
  // ─── Batch ───
  batchNumber     String?  @map("batch_number")
  supplierBatchNo String?  @map("supplier_batch_no")
  manufacturingDate DateTime? @map("manufacturing_date")
  expiryDate      DateTime? @map("expiry_date")
  // ─── Barcode ───
  barcode         String?  @map("barcode")
  // ─── Status ───
  lineStatus      String   @default("PENDING") @map("line_status") // PENDING, RECEIVING, RECEIVED, SHORT, OVER, DAMAGED, REJECTED
  // ─── Audit ───
  createdAt       DateTime @default(now()) @map("created_at")

  asn             AdvancedShippingNotice @relation(fields: [asnId], references: [id], onDelete: Cascade)

  @@map("asn_lines")
  @@index([asnId, lineOrder], map: "idx_asnl_asn_order")
  @@index([productId], map: "idx_asnl_product")
  @@index([lineStatus], map: "idx_asnl_status")
}

// ─── Epic 2: Receiving Appointments ────────────────────
model ReceivingAppointment {
  id              String   @id @default(uuid()) @db.Uuid
  appointmentNumber String  @unique @map("appointment_number")
  appointmentDate DateTime @map("appointment_date")
  // ─── Time slot ───
  startTime       DateTime @map("start_time")
  endTime         DateTime @map("end_time")
  // ─── Dock ───
  dockId          String?  @db.Uuid @map("dock_id")
  dockCode        String?  @map("dock_code")
  // ─── Supplier ───
  supplierId      String?  @db.Uuid @map("supplier_id")
  supplierName    String?  @map("supplier_name")
  // ─── Vehicle ───
  vehicleNumber   String?  @map("vehicle_number")
  driverName      String?  @map("driver_name")
  driverPhone     String?  @map("driver_phone")
  // ─── ASN link ───
  asnId           String?  @db.Uuid @map("asn_id")
  asnNumber       String?  @map("asn_number")
  // ─── Warehouse ───
  warehouseId     String?  @db.Uuid @map("warehouse_id")
  warehouseName   String?  @map("warehouse_name")
  // ─── Priority ───
  priority        String   @default("NORMAL") // EMERGENCY, HIGH, NORMAL, LOW
  // ─── Status ───
  status          String   @default("SCHEDULED") // SCHEDULED, CONFIRMED, ARRIVED, IN_PROGRESS, COMPLETED, CANCELLED, NO_SHOW
  // ─── Audit ───
  createdById     String?  @db.Uuid @map("created_by_id")
  createdByName   String?  @map("created_by_name")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  asns            AdvancedShippingNotice[]

  @@map("receiving_appointments")
  @@index([appointmentDate, status], map: "idx_ra_date_status")
  @@index([dockId, appointmentDate], map: "idx_ra_dock_date")
  @@index([supplierId], map: "idx_ra_supplier")
  @@index([status], map: "idx_ra_status")
}

// ─── Epic 3: Gate Entry ────────────────────────────────
model GateEntry {
  id              String   @id @default(uuid()) @db.Uuid
  gatePassNumber  String   @unique @map("gate_pass_number")
  gateDate        DateTime @map("gate_date")
  // ─── Type ───
  entryType       String   @map("entry_type") // INBOUND, OUTBOUND, VISITOR, CONTRACTOR
  // ─── Vehicle ───
  vehicleNumber   String   @map("vehicle_number")
  vehicleType     String?  @map("vehicle_type") // TRUCK, CONTAINER, TEMPO, VAN, CAR
  driverName      String   @map("driver_name")
  driverLicense   String?  @map("driver_license")
  driverPhone     String?  @map("driver_phone")
  // ─── Security ───
  securityOfficerId String? @db.Uuid @map("security_officer_id")
  securityOfficerName String? @map("security_officer_name")
  // ─── Seal ───
  sealNumber      String?  @map("seal_number")
  sealIntact      Boolean  @default(true) @map("seal_intact")
  // ─── Timing ───
  arrivalTime     DateTime @default(now()) @map("arrival_time")
  exitTime        DateTime? @map("exit_time")
  durationMinutes Int?     @map("duration_minutes")
  // ─── Reference ───
  referenceType   String?  @map("reference_type") // ASN, APPOINTMENT, SALES_ORDER, TRANSFER
  referenceNumber String?  @map("reference_number")
  // ─── Warehouse ───
  warehouseId     String?  @db.Uuid @map("warehouse_id")
  warehouseName   String?  @map("warehouse_name")
  // ─── Photos ───
  photoUrls       String[] @default([]) @map("photo_urls")
  // ─── Status ───
  status          String   @default("ARRIVED") // ARRIVED, IN_WAREHOUSE, DEPARTED, DENIED
  remarks         String?
  // ─── Audit ───
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("gate_entries")
  @@index([entryType, gateDate], map: "idx_ge_type_date")
  @@index([vehicleNumber], map: "idx_ge_vehicle")
  @@index([status], map: "idx_ge_status")
  @@index([gateDate], map: "idx_ge_date")
}

// ─── Epic 4: Dock Management ───────────────────────────
model LoadingDock {
  id              String   @id @default(uuid()) @db.Uuid
  warehouseId     String   @db.Uuid @map("warehouse_id")
  dockCode        String   @map("dock_code")
  dockName        String   @map("dock_name")
  // ─── Type ───
  dockType        String   @map("dock_type") // RECEIVING_DOCK, DISPATCH_DOCK, MIXED_DOCK, COLD_DOCK, BULK_DOCK, CONTAINER_DOCK
  // ─── Physical ───
  dockDoorNumber  String?  @map("dock_door_number")
  // ─── Capacity ───
  maxVehicleSize  String?  @map("max_vehicle_size") // SMALL, MEDIUM, LARGE, CONTAINER
  // ─── Temperature ───
  isTemperatureControlled Boolean @default(false) @map("is_temperature_controlled")
  temperatureZone String?  @map("temperature_zone")
  // ─── Equipment ───
  hasForkliftAccess Boolean @default(true) @map("has_forklift_access")
  hasPalletJack    Boolean @default(true) @map("has_pallet_jack")
  hasConveyor      Boolean @default(false) @map("has_conveyor")
  // ─── Status ───
  status          String   @default("AVAILABLE") // AVAILABLE, OCCUPIED, MAINTENANCE, CLOSED
  currentVehicleNumber String? @map("current_vehicle_number")
  currentAppointmentId String? @db.Uuid @map("current_appointment_id")
  // ─── Stats ───
  totalOperations Int      @default(0) @map("total_operations")
  avgUnloadTime   Int?     @map("avg_unload_time") // minutes
  // ─── Audit ───
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([warehouseId, dockCode], map: "ld_unique_wh_dock")
  @@map("loading_docks")
  @@index([warehouseId, status], map: "idx_ld_wh_status")
  @@index([dockType, status], map: "idx_ld_type_status")
  @@index([status], map: "idx_ld_status")
}

// ─── Epic 7: Receiving Exceptions ──────────────────────
model ReceivingException {
  id              String   @id @default(uuid()) @db.Uuid
  exceptionNumber String   @unique @map("exception_number")
  exceptionDate   DateTime @map("exception_date")
  // ─── Link ───
  asnId           String?  @db.Uuid @map("asn_id")
  asnNumber       String?  @map("asn_number")
  asnLineId       String?  @db.Uuid @map("asn_line_id")
  // ─── Type ───
  exceptionType   String   @map("exception_type") // SHORT_DELIVERY, OVER_DELIVERY, DAMAGED_GOODS, WRONG_PRODUCT, WRONG_BATCH, BROKEN_SEAL, TEMPERATURE_VIOLATION, MISSING_DOCUMENTS
  // ─── Details ───
  description     String?
  // ─── Item ───
  productId       String?  @db.Uuid @map("product_id")
  productName     String?  @map("product_name")
  // ─── Quantity ───
  expectedQty     Decimal? @db.Decimal(18, 4) @map("expected_qty")
  receivedQty     Decimal? @db.Decimal(18, 4) @map("received_qty")
  differenceQty   Decimal? @db.Decimal(18, 4) @map("difference_qty")
  // ─── Photos ───
  photoUrls       String[] @default([]) @map("photo_urls")
  // ─── Resolution ───
  resolutionStatus String  @default("PENDING") @map("resolution_status") // PENDING, UNDER_REVIEW, ACCEPTED, REJECTED, PARTIAL_ACCEPT, ESCALATED
  resolutionAction String? @map("resolution_action")
  resolutionNotes String?  @map("resolution_notes")
  resolvedById    String?  @db.Uuid @map("resolved_by_id")
  resolvedByName  String?  @map("resolved_by_name")
  resolvedAt      DateTime? @map("resolved_at")
  // ─── Status ───
  status          String   @default("ACTIVE") // ACTIVE, RESOLVED, CANCELLED
  // ─── Audit ───
  reportedById    String?  @db.Uuid @map("reported_by_id")
  reportedByName  String?  @map("reported_by_name")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  asn             AdvancedShippingNotice? @relation(fields: [asnId], references: [id], onDelete: SetNull)

  @@map("receiving_exceptions")
  @@index([asnId], map: "idx_re_asn")
  @@index([exceptionType, resolutionStatus], map: "idx_re_type_resolution")
  @@index([resolutionStatus], map: "idx_re_resolution")
  @@index([status], map: "idx_re_status")
}

// ═══════════════════════════════════════════════════════════
// SPRINT 25 — DIRECTED PUTAWAY, STORAGE OPTIMIZATION & BIN INTELLIGENCE
// System tells operators WHERE to store inventory — no manual decisions
// ═══════════════════════════════════════════════════════════

// ─── Epic 1: Putaway Task Engine ───────────────────────
model WmsPutawayTask {
  id              String   @id @default(uuid()) @db.Uuid
  taskNumber      String   @unique @map("task_number")
  taskDate        DateTime @default(now()) @map("task_date")
  // ─── Type ───
