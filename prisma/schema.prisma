  // ─── Scope ───
  warehouseId     String?  @db.Uuid @map("warehouse_id")
  warehouseName   String?  @map("warehouse_name")
  // ─── Status ───
  status          String   @default("ACTIVE") // ACTIVE, ACKNOWLEDGED, ACTIONED, DISMISSED
  actionTaken     String?  @map("action_taken") // FEFO_PRIORITIZE, DISCOUNT, DONATE, DESTROY, RETURN_TO_SUPPLIER
  actionedById    String?  @db.Uuid @map("actioned_by_id")
  actionedAt      DateTime? @map("actioned_at")
  // ─── Notifications ───
  emailSent       Boolean  @default(false) @map("email_sent")
  dashboardShown  Boolean  @default(true) @map("dashboard_shown")
  // ─── Audit ───
