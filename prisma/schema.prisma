  // ─── Validation ───
  validationResult    String   @default("VALID") // VALID, WRONG_INGREDIENT, EXPIRED_BATCH, WRONG_QTY, BLOCKED_BATCH, UNKNOWN_BARCODE, DUPLICATE_SCAN
  validationMessage   String?  @map("validation_message")
  // ─── Inventory ───
  inventoryTransactionId String? @db.Uuid @map("inventory_transaction_id")
  // ─── Status ───
