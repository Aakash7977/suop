  @@map("commercial_rules")
  @@index([ruleType, status], map: "idx_cr_type_status")
  @@index([companyId, branchId], map: "idx_cr_scope")
  @@index([productId, customerId], map: "idx_cr_product_customer")
}

// ─── Epic 10: Price Resolution Log (audit) ──────────────
model PriceResolutionLog {
  id              String   @id @default(uuid()) @db.Uuid
  // ─── Request context ───
  requestId       String   @unique @map("request_id")
  channelId       String   @map("channel_id") // RETAIL_POS, RESTAURANT_POS, ERP, ECOMMERCE, CUSTOMER_PORTAL
  // ─── Input ───
  productId       String   @db.Uuid @map("product_id")
  productVariantId String? @db.Uuid @map("product_variant_id")
  companyId       String?  @db.Uuid @map("company_id")
  branchId        String?  @db.Uuid @map("branch_id")
  customerId      String?  @db.Uuid @map("customer_id")
  uomId           String?  @db.Uuid @map("uom_id")
  quantity        Decimal  @db.Decimal(18, 4)
  // ─── Output ───
  basePrice       Decimal  @db.Decimal(18, 4) @map("base_price")
  listPrice       Decimal  @db.Decimal(18, 4) @map("list_price")
  appliedDiscounts Json    @default("[]") @map("applied_discounts")
  appliedPromotions Json   @default("[]") @map("applied_promotions")
  discountAmount  Decimal  @db.Decimal(18, 4) @default(0) @map("discount_amount")
  promotionAmount Decimal  @db.Decimal(18, 4) @default(0) @map("promotion_amount")
  taxableAmount   Decimal  @db.Decimal(18, 4) @map("taxable_amount")
  taxComponents   Json     @default("[]") @map("tax_components")
  taxAmount       Decimal  @db.Decimal(18, 4) @default(0) @map("tax_amount")
  finalPrice      Decimal  @db.Decimal(18, 4) @map("final_price")
  // ─── Resolution trace ───
  resolutionTrace Json     @map("resolution_trace") // Steps taken for audit
  // ─── Source price list & rules ───
  sourcePriceListId String? @db.Uuid @map("source_price_list_id")
  // ─── Audit ───
  requestedAt     DateTime @default(now()) @map("requested_at")
  responseTimeMs  Int      @map("response_time_ms")

  @@map("price_resolution_logs")
  @@index([productId, requestedAt], map: "idx_prl_product_time")
  @@index([channelId], map: "idx_prl_channel")
  @@index([customerId], map: "idx_prl_customer")
}

// ═══════════════════════════════════════════════════════════
// SPRINT 9 — ENTERPRISE BUSINESS PARTNER PLATFORM
// Unified master for Customers, Suppliers, Transporters,
// Franchisees, Corporate Clients, Delivery Partners, Service Providers
// ═══════════════════════════════════════════════════════════

// ─── Epic 1: Business Partner Master ─────────────────────
model BusinessPartner {
  id                  String   @id @default(uuid()) @db.Uuid
  partnerCode         String   @unique @map("partner_code")
  legalName           String   @map("legal_name")
  displayName         String   @map("display_name")
  // ─── Type ───
  partnerType         String   @map("partner_type") // INDIVIDUAL, COMPANY, GOVERNMENT, NGO, TRUST, CORPORATE, FOREIGN_ENTITY
  // ─── Status ───
  status              String   @default("ACTIVE") // DRAFT, ACTIVE, INACTIVE, SUSPENDED, BLACKLISTED
  // ─── Tax & Compliance Identifiers ───
  gstNumber           String?  @map("gst_number")
  panNumber           String?  @map("pan_number")
  msmeNumber          String?  @map("msme_number")
  fssaiNumber         String?  @map("fssai_number")
  iecCode             String?  @map("iec_code") // Import Export Code
  // ─── Commercial ───
  currency            String   @default("INR") @db.Char(3)
  creditLimit         Decimal? @db.Decimal(18, 2) @map("credit_limit")
  creditDays          Int?     @map("credit_days")
  paymentTermsId      String?  @map("payment_terms_id")
  paymentMode         String?  @map("payment_mode") // CASH, CREDIT, ADVANCE, LC, BG
  // ─── Profile ───
  preferredLanguage   String?  @map("preferred_language")
  website             String?
  logoUrl             String?  @map("logo_url")
  // ─── Risk ───
  riskCategory        String?  @map("risk_category") // LOW, MEDIUM, HIGH, CRITICAL
  riskScore           Decimal? @db.Decimal(5, 2) @map("risk_score")
  // ─── Parent (for subsidiaries) ───
  parentPartnerId     String?  @db.Uuid @map("parent_partner_id")
  // ─── Audit ───
  createdById         String?  @db.Uuid @map("created_by_id")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")
  deletedAt           DateTime? @map("deleted_at")

  roles               BusinessPartnerRole[]
  addresses           BusinessPartnerAddress[]
  contacts            BusinessPartnerContact[]
  financialProfile    BusinessPartnerFinancialProfile?
  complianceRecords   BusinessPartnerCompliance[]
  bankAccounts        BusinessPartnerBankAccount[]
  relationshipsFrom   BusinessPartnerRelationship[] @relation("BPRelFrom")
  relationshipsTo     BusinessPartnerRelationship[] @relation("BPRelTo")
  scorecards          BusinessPartnerScorecard[]
  groupMemberships    BusinessPartnerGroupMembership[]

  @@map("business_partners")
  @@index([partnerType, status], map: "idx_bp_type_status")
  @@index([gstNumber], map: "idx_bp_gst")
  @@index([panNumber], map: "idx_bp_pan")
  @@index([parentPartnerId], map: "idx_bp_parent")
  @@index([status], map: "idx_bp_status")
}

// ─── Partner Roles (multiple per partner) ───────────────
model BusinessPartnerRole {
  id              String   @id @default(uuid()) @db.Uuid
  partnerId       String   @db.Uuid @map("partner_id")
  role            String   // CUSTOMER, SUPPLIER, DISTRIBUTOR, TRANSPORTER, DELIVERY_PARTNER, MANUFACTURER, RETAIL_OUTLET, RESTAURANT_OUTLET, FRANCHISE, SERVICE_PROVIDER, CONSULTANT
  isPrimary       Boolean  @default(false) @map("is_primary")
  assignedAt      DateTime @default(now()) @map("assigned_at")
  assignedById    String?  @db.Uuid @map("assigned_by_id")
  status          String   @default("ACTIVE") // ACTIVE, INACTIVE, SUSPENDED
  notes           String?

  partner         BusinessPartner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@unique([partnerId, role], map: "bpr_unique_partner_role")
  @@map("business_partner_roles")
  @@index([role, status], map: "idx_bpr_role_status")
  @@index([partnerId], map: "idx_bpr_partner")
}

// ─── Epic 2: Address Management ─────────────────────────
model BusinessPartnerAddress {
  id              String   @id @default(uuid()) @db.Uuid
  partnerId       String   @db.Uuid @map("partner_id")
  addressType     String   @map("address_type") // REGISTERED_OFFICE, BILLING, SHIPPING, FACTORY, WAREHOUSE, BRANCH, RESTAURANT, PICKUP, RETURN
  isDefault       Boolean  @default(false) @map("is_default")
