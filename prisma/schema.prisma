// ─── Epic 8: Price Approval Workflow ────────────────────
model PriceApprovalRequest {
  id              String   @id @default(uuid()) @db.Uuid
  // ─── Reference ───
  entityType      String   @map("entity_type") // PRICE_LIST, PRODUCT_PRICE, FUTURE_PRICE, PROMOTION, DISCOUNT_RULE
  entityId        String   @db.Uuid @map("entity_id")
  entityName      String   @map("entity_name")
  // ─── Workflow stages ───
  currentStage    String   @default("DRAFT") @map("current_stage") // DRAFT, PRICING_TEAM, FINANCE, MANAGEMENT, APPROVED, PUBLISHED, REJECTED
  // ─── Pricing Team ───
  pricingTeamReviewerId String? @db.Uuid @map("pricing_team_reviewer_id")
  pricingTeamReviewedAt DateTime? @map("pricing_team_reviewed_at")
  pricingTeamDecision  String?  @map("pricing_team_decision")
  pricingTeamNotes     String?  @map("pricing_team_notes")
  // ─── Finance ───
  financeReviewerId String?  @db.Uuid @map("finance_reviewer_id")
  financeReviewedAt DateTime? @map("finance_reviewed_at")
  financeDecision  String?  @map("finance_decision")
  financeNotes     String?  @map("finance_notes")
  // ─── Management ───
  managementReviewerId String? @db.Uuid @map("management_reviewer_id")
  managementReviewedAt DateTime? @map("management_reviewed_at")
  managementDecision  String?  @map("management_decision")
  managementNotes     String?  @map("management_notes")
  // ─── Final ───
  approvedBy      String?  @db.Uuid @map("approved_by")
  approvedAt      DateTime? @map("approved_at")
  publishedBy     String?  @db.Uuid @map("published_by")
  publishedAt     DateTime? @map("published_at")
  // ─── Rejection ───
  rejectedBy      String?  @db.Uuid @map("rejected_by")
  rejectedAt      DateTime? @map("rejected_at")
  rejectionReason String?  @map("rejection_reason")
  // ─── SLA ───
  slaDueAt        DateTime @map("sla_due_at")
  slaBreached     Boolean  @default(false) @map("sla_breached")
  // ─── Status ───
  status          String   @default("PENDING") // PENDING, IN_REVIEW, APPROVED, PUBLISHED, REJECTED, CANCELLED
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("price_approval_requests")
  @@index([entityType, entityId], map: "idx_par_price_entity")
  @@index([currentStage, status], map: "idx_par_price_stage")
  @@index([entityType, status], map: "idx_par_price_type_status")
  @@index([slaDueAt, slaBreached], map: "idx_par_price_sla")
  @@index([status, currentStage], map: "idx_par_price_status_stage")
}

// ─── Epic 9: Commercial Rules Engine ────────────────────
model CommercialRule {
  id              String   @id @default(uuid()) @db.Uuid
