  // ─── Metric ───
  metricName      String   @map("metric_name") // COMPLETENESS, ACCURACY, CONSISTENCY, DUPLICATE_PERCENT, APPROVAL_SLA, VALIDATION_ERRORS, INACTIVE_PRODUCTS, MISSING_IMAGES, MISSING_BARCODES
