  @@index([entityType, entityId, changedAt], map: "idx_mda_entity_time")
  @@index([action, moduleName], map: "idx_mda_action_module")
  @@index([userId, changedAt], map: "idx_mda_user_time")
  @@index([changedAt], map: "idx_mda_time")
}

// ─── Epic 7: Master Data Quality Dashboard ──────────────
model DataQualityMetric {
  id              String   @id @default(uuid()) @db.Uuid
  // ─── Scope ───
  entityType      String   @map("entity_type") // PRODUCT, BUSINESS_PARTNER, PRICE_LIST, etc.
