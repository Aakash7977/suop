  @@map("recall_batches")
  @@index([recallId], map: "idx_rb_recall")
  @@index([batchId], map: "idx_rb_batch")
  @@index([status], map: "idx_rb_status")
}

// ─── Epic 6: Batch Genealogy ───────────────────────────
model BatchGenealogy {
  id              String   @id @default(uuid()) @db.Uuid
  // ─── From batch (input) ───
  fromBatchId     String   @db.Uuid @map("from_batch_id")
  fromBatchNumber String   @map("from_batch_number")
  fromProductId   String   @db.Uuid @map("from_product_id")
  fromProductName String   @map("from_product_name")
  fromBatchType   String   @map("from_batch_type") // RAW_MATERIAL, SEMI_FINISHED, etc.
  // ─── To batch (output) ───
  toBatchId       String   @db.Uuid @map("to_batch_id")
  toBatchNumber   String   @map("to_batch_number")
  toProductId     String   @db.Uuid @map("to_product_id")
  toProductName   String   @map("to_product_name")
  toBatchType     String   @map("to_batch_type") // FINISHED_GOODS, SEMI_FINISHED, etc.
  // ─── Relationship ───
  relationshipType String  @map("relationship_type") // PRODUCED_FROM, USED_IN, REPACKED_FROM, REWORKED_FROM, BLEND_OF
  // ─── Quantity ───
  quantityUsed    Decimal  @db.Decimal(18, 4) @map("quantity_used")
  uomId           String?  @db.Uuid @map("uom_id")
  // ─── Production ───
  productionOrderId String? @map("production_order_id")
  productionDate  DateTime? @map("production_date")
  // ─── Audit ───
  createdAt       DateTime @default(now()) @map("created_at")

  fromBatch       BatchMaster @relation("GenealogyFrom", fields: [fromBatchId], references: [id], onDelete: Cascade)
  toBatch         BatchMaster @relation("GenealogyTo", fields: [toBatchId], references: [id], onDelete: Cascade)

  @@map("batch_genealogy")
  @@index([fromBatchId], map: "idx_bg_from")
  @@index([toBatchId], map: "idx_bg_to")
  @@index([relationshipType], map: "idx_bg_relation")
  @@index([productionOrderId], map: "idx_bg_production")
}

// ═══════════════════════════════════════════════════════════
// SPRINT 20 — INVENTORY COSTING, VALUATION & FINANCE INTEGRATION
// Connects inventory quantities with financial values
// ═══════════════════════════════════════════════════════════

// ─── Epic 1: Cost Layer (FIFO tracking) ────────────────
model InventoryCostLayer {
  id              String   @id @default(uuid()) @db.Uuid
  // ─── Item ───
  productId       String   @db.Uuid @map("product_id")
  productName     String   @map("product_name")
  productVariantId String? @db.Uuid @map("product_variant_id")
  batchId         String?  @db.Uuid @map("batch_id")
  batchNumber     String?  @map("batch_number")
  uomId           String?  @db.Uuid @map("uom_id")
  // ─── Scope ───
  warehouseId     String?  @db.Uuid @map("warehouse_id")
  warehouseName   String?  @map("warehouse_name")
  // ─── Costing method ───
  costingMethod   String   @map("costing_method") // FIFO, WEIGHTED_AVERAGE, MOVING_AVERAGE, STANDARD, ACTUAL, SPECIFIC_IDENTIFICATION
  // ─── Layer details ───
  layerNumber     Int      @map("layer_number")
  // ─── Receipt reference ───
  receiptType     String   @map("receipt_type") // PURCHASE, PRODUCTION, TRANSFER, OPENING, ADJUSTMENT
  receiptNumber   String?  @map("receipt_number")
  receiptDate     DateTime @map("receipt_date")
  // ─── Quantities ───
  originalQty     Decimal  @db.Decimal(18, 4) @map("original_qty")
  consumedQty     Decimal  @db.Decimal(18, 4) @default(0) @map("consumed_qty")
  remainingQty    Decimal  @db.Decimal(18, 4) @default(0) @map("remaining_qty")
  // ─── Cost ───
  unitCost        Decimal  @db.Decimal(18, 4) @map("unit_cost")
  totalOriginalValue Decimal @db.Decimal(18, 2) @map("total_original_value")
  totalConsumedValue Decimal @db.Decimal(18, 2) @default(0) @map("total_consumed_value")
  totalRemainingValue Decimal @db.Decimal(18, 2) @default(0) @map("total_remaining_value")
  // ─── Landed cost ───
  landedUnitCost  Decimal? @db.Decimal(18, 4) @map("landed_unit_cost")
  hasLandedCost   Boolean  @default(false) @map("has_landed_cost")
  // ─── Status ───
  status          String   @default("ACTIVE") // ACTIVE, PARTIALLY_CONSUMED, FULLY_CONSUMED, EXPIRED, CLOSED
  // ─── Audit ───
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("inventory_cost_layers")
  @@index([productId, warehouseId, status], map: "idx_icl_product_wh_status")
  @@index([costingMethod, status], map: "idx_icl_method_status")
  @@index([receiptDate], map: "idx_icl_receipt_date")
  @@index([batchId], map: "idx_icl_batch")
  @@index([status], map: "idx_icl_status")
}

// ─── Epic 1: Cost History (immutable) ──────────────────
model InventoryCostHistory {
  id              String   @id @default(uuid()) @db.Uuid
  productId       String   @db.Uuid @map("product_id")
  productName     String   @map("product_name")
  warehouseId     String?  @db.Uuid @map("warehouse_id")
  warehouseName   String?  @map("warehouse_name")
  // ─── Cost snapshot ───
  costingMethod   String   @map("costing_method")
  unitCost        Decimal  @db.Decimal(18, 4) @map("unit_cost")
  totalQty        Decimal  @db.Decimal(18, 4) @map("total_qty")
  totalValue      Decimal  @db.Decimal(18, 2) @map("total_value")
  // ─── Trigger ───
  changeType      String   @map("change_type") // RECEIPT, ISSUE, ADJUSTMENT, REVALUATION, LANDED_COST, TRANSFER
  changeReference String?  @map("change_reference")
  changeDate      DateTime @map("change_date")
  // ─── Previous ───
  previousUnitCost Decimal? @db.Decimal(18, 4) @map("previous_unit_cost")
  previousTotalValue Decimal? @db.Decimal(18, 2) @map("previous_total_value")
  // ─── Variance ───
  costVariance    Decimal? @db.Decimal(18, 4) @map("cost_variance")
  valueVariance   Decimal? @db.Decimal(18, 2) @map("value_variance")
  // ─── Audit ───
  createdById     String?  @db.Uuid @map("created_by_id")
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("inventory_cost_history")
  @@index([productId, warehouseId, changeDate], map: "idx_ich_product_wh_date")
  @@index([changeType], map: "idx_ich_type")
  @@index([changeDate], map: "idx_ich_date")
}

// ─── Epic 6: Landed Cost ───────────────────────────────
model LandedCostDocument {
  id              String   @id @default(uuid()) @db.Uuid
  documentNumber  String   @unique @map("document_number")
  documentDate    DateTime @map("document_date")
  // ─── Reference ───
  referenceType   String   @map("reference_type") // PURCHASE_ORDER, GRN, SHIPMENT, CONTAINER
  referenceNumber String   @map("reference_number")
  // ─── Supplier ───
  supplierId      String?  @db.Uuid @map("supplier_id")
  supplierName    String?  @map("supplier_name")
  // ─── Total costs ───
  productCost     Decimal  @db.Decimal(18, 2) @map("product_cost")
  totalLandedCost Decimal  @db.Decimal(18, 2) @default(0) @map("total_landed_cost")
  totalAllocatedCost Decimal @db.Decimal(18, 2) @default(0) @map("total_allocated_cost")
  // ─── Status ───
  status          String   @default("DRAFT") // DRAFT, PENDING_APPROVAL, APPROVED, ALLOCATED, POSTED, CANCELLED
  // ─── Audit ───
  createdById     String?  @db.Uuid @map("created_by_id")
  approvedById    String?  @db.Uuid @map("approved_by_id")
  approvedAt      DateTime? @map("approved_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  allocations     LandedCostAllocation[]

  @@map("landed_cost_documents")
  @@index([referenceType, referenceNumber], map: "idx_lcd_reference")
  @@index([status], map: "idx_lcd_status")
  @@index([documentDate], map: "idx_lcd_date")
}

model LandedCostAllocation {
  id              String   @id @default(uuid()) @db.Uuid
  documentId      String   @db.Uuid @map("document_id")
  // ─── Cost component ───
  costComponent   String   @map("cost_component") // FREIGHT, INSURANCE, CUSTOM_DUTY, LOADING, UNLOADING, TRANSPORT, HANDLING, BROKERAGE
  description     String?
  // ─── Amount ───
  amount          Decimal  @db.Decimal(18, 2)
  currency        String   @default("INR") @db.Char(3)
  // ─── Allocation method ───
  allocationMethod String  @map("allocation_method") // QUANTITY, WEIGHT, VOLUME, VALUE, EQUAL
  allocationPercent Decimal @db.Decimal(8, 4) @default(0) @map("allocation_percent")
  // ─── Vendor ───
  vendorId        String?  @db.Uuid @map("vendor_id")
  vendorName      String?  @map("vendor_name")
  vendorInvoiceNo String?  @map("vendor_invoice_no")
  // ─── Status ───
  isAllocated     Boolean  @default(false) @map("is_allocated")
  allocatedAt     DateTime? @map("allocated_at")
  // ─── Audit ───
  createdAt       DateTime @default(now()) @map("created_at")

  document        LandedCostDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@map("landed_cost_allocations")
  @@index([documentId], map: "idx_lca_document")
  @@index([costComponent], map: "idx_lca_component")
}

// ─── Epic 7: Inventory Revaluation ─────────────────────
model InventoryRevaluation {
