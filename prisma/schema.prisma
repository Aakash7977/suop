  // ─── Quality ───
  qualityStatus       String   @default("PASSED") @map("quality_status") // PASSED, HOLD, FAILED
  qualityApprovedAt   DateTime? @map("quality_approved_at")
  qualityApprovedBy   String?  @map("quality_approved_by")
  // ─── Inventory Posting ───
  inventoryPosted     Boolean  @default(false) @map("inventory_posted")
  inventoryPostedAt   DateTime? @map("inventory_posted_at")
  inventoryTransactionNumber String? @map("inventory_transaction_number")
  // ─── Warehouse Handover ───
  warehouseReceiptNumber String? @map("warehouse_receipt_number")
  warehouseId         String?  @db.Uuid @map("warehouse_id")
  warehouseName       String?  @map("warehouse_name")
  putawayTaskId       String?  @db.Uuid @map("putaway_task_id")
  putawayTaskNumber   String?  @map("putaway_task_number")
  transferredAt       DateTime? @map("transferred_at")
  transferDurationMs  Int?     @map("transfer_duration_ms") // target <5000ms
  withinTarget        Boolean  @default(true) @map("within_target")
  // ─── Status ───
  status              String   @default("PENDING") @map("status") // PENDING, QUALITY_APPROVED, INVENTORY_POSTED, WAREHOUSE_TRANSFERRED, COMPLETED
  // ─── Audit ───
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("finished_goods_confirmations")
  @@index([packagingOrderId], map: "idx_fgc41_order")
  @@index([productionBatchNumber], map: "idx_fgc41_batch")
  @@index([productSku], map: "idx_fgc41_sku")
  @@index([status], map: "idx_fgc41_status")
}

// ─── Epic 7: Packaging Cost Tracking ────────────────────────────────────
model PackagingCostSummary {
  id                  String   @id @default(uuid()) @db.Uuid
