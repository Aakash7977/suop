model CostElement {
  id                  String   @id @default(uuid()) @db.Uuid
  productionCostId    String   @db.Uuid @map("production_cost_id")
  costCode            String   @map("cost_code")
  // ─── Element ───
  elementType         String   @map("element_type") // MATERIAL, PACKAGING, LABOR, MACHINE, UTILITY, OVERHEAD, QUALITY, WAREHOUSE
  elementCode         String   @map("element_code") // RAW-CASHEW, LABOR-MIXING, MACHINE-COOK-01, ELEC, RENT
  elementName         String   @map("element_name")
  // ─── Cost ───
  plannedCost         Decimal  @db.Decimal(14, 2) @default(0) @map("planned_cost")
  actualCost          Decimal  @db.Decimal(14, 2) @default(0) @map("actual_cost")
  varianceAmount      Decimal  @db.Decimal(14, 2) @default(0) @map("variance_amount")
  variancePercent     Decimal  @db.Decimal(6, 2) @default(0) @map("variance_percent")
  // ─── Driver ───
  costDriver          String?  @map("cost_driver") // QTY, HOURS, KG, KWH, M3, FIXED
  driverQuantity      Decimal? @db.Decimal(14, 4) @map("driver_quantity")
  ratePerDriver       Decimal? @db.Decimal(12, 4) @map("rate_per_driver")
  // ─── Source ───
  source              String   @default("CALCULATED") @map("source") // CALCULATED, MANUAL, ALLOCATED, IMPORTED
  // ─── Audit ───
  createdAt           DateTime @default(now()) @map("created_at")

  productionCost      ProductionCost @relation(fields: [productionCostId], references: [id], onDelete: Cascade)

  @@map("cost_elements")
  @@index([productionCostId], map: "idx_ce42_pc")
  @@index([elementType], map: "idx_ce42_type")
}

