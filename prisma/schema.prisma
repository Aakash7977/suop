  productSku          String   @map("product_sku")
  productName         String   @map("product_name")
  // ─── Cost Type ───
  costType            String   @map("cost_type") // STANDARD, ACTUAL, ESTIMATED, SIMULATION, HISTORICAL
  // ─── Components ───
  materialCost        Decimal  @db.Decimal(14, 2) @default(0) @map("material_cost")
  packagingCost       Decimal  @db.Decimal(14, 2) @default(0) @map("packaging_cost")
  laborCost           Decimal  @db.Decimal(14, 2) @default(0) @map("labor_cost")
  machineCost         Decimal  @db.Decimal(14, 2) @default(0) @map("machine_cost")
  utilityCost         Decimal  @db.Decimal(14, 2) @default(0) @map("utility_cost")
  overheadCost        Decimal  @db.Decimal(14, 2) @default(0) @map("overhead_cost")
  qualityCost         Decimal  @db.Decimal(14, 2) @default(0) @map("quality_cost")
  warehouseTransferCost Decimal @db.Decimal(14, 2) @default(0) @map("warehouse_transfer_cost")
  // ─── Total ───
  totalManufacturingCost Decimal @db.Decimal(14, 2) @default(0) @map("total_manufacturing_cost")
  // ─── Quantity ───
  outputQuantity      Decimal  @db.Decimal(18, 4) @default(0) @map("output_quantity")
  uom                 String   @default("KG") @map("uom")
  costPerUnit         Decimal  @db.Decimal(12, 4) @default(0) @map("cost_per_unit")
  costPerKg           Decimal  @db.Decimal(12, 4) @default(0) @map("cost_per_kg")
  // ─── Variance ───
  plannedCost         Decimal  @db.Decimal(14, 2) @default(0) @map("planned_cost")
  actualCost          Decimal  @db.Decimal(14, 2) @default(0) @map("actual_cost")
  varianceAmount      Decimal  @db.Decimal(14, 2) @default(0) @map("variance_amount")
  variancePercent     Decimal  @db.Decimal(6, 2) @default(0) @map("variance_percent")
  varianceStatus      String   @default("WITHIN_THRESHOLD") @map("variance_status") // WITHIN_THRESHOLD, REVIEW_REQUIRED, CRITICAL
  // ─── Finance ───
  journalPosted       Boolean  @default(false) @map("journal_posted")
  journalEntryNumber  String?  @map("journal_entry_number")
  journalPostedAt     DateTime? @map("journal_posted_at")
  financialPeriod     String?  @map("financial_period") // FY2026-Q1-Jul
  // ─── Audit ───
  calculatedAt        DateTime @default(now()) @map("calculated_at")
  recalculatedAt      DateTime? @map("recalculated_at")
  calculationDurationMs Int?   @map("calculation_duration_ms") // target <5000ms
  withinTarget        Boolean  @default(true) @map("within_target")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  costElements        CostElement[]
  costTransactions    CostTransaction[]

  @@map("production_costs")
  @@index([costType], map: "idx_pc42_type")
  @@index([productionOrderNumber], map: "idx_pc42_po")
  @@index([productSku], map: "idx_pc42_sku")
  @@index([varianceStatus], map: "idx_pc42_variance")
