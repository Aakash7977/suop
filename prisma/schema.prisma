  labelPrinted    Boolean  @default(false) @map("label_printed")
  // ─── Status ───
  status          String   @default("OPEN") // OPEN, SEALED, LABELED, LOADED, SHIPPED
  sealedAt        DateTime? @map("sealed_at")
  // ─── Audit ───
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("cartons")
  @@index([packingJobId], map: "idx_c_packing_job")
  @@index([status], map: "idx_c_status")
}

// ─── Epic 7: Shipping Labels ───────────────────────────
model ShippingLabel {
  id              String   @id @default(uuid()) @db.Uuid
  labelNumber     String   @unique @map("label_number")
  labelDate       DateTime @default(now()) @map("label_date")
  // ─── Type ───
  labelType       String   @map("label_type") // ORDER_LABEL, PALLET_LABEL, CARTON_LABEL, COURIER_LABEL, INTERNAL_LABEL, QR_LABEL, BARCODE_LABEL
  // ─── Link ───
  packingJobId    String?  @db.Uuid @map("packing_job_id")
  cartonId        String?  @db.Uuid @map("carton_id")
  pickingTaskId   String?  @unique @db.Uuid @map("picking_task_id")
  // ─── Recipient ───
  partnerId       String?  @db.Uuid @map("partner_id")
  partnerName     String?  @map("partner_name")
  shipToName      String?  @map("ship_to_name")
  shipToAddress   String?  @map("ship_to_address")
  shipToCity      String?  @map("ship_to_city")
  shipToState     String?  @map("ship_to_state")
  shipToPincode   String?  @map("ship_to_pincode")
  // ─── Shipment ───
  carrierName     String?  @map("carrier_name")
  trackingNumber  String?  @map("tracking_number")
  // ─── Content ───
  contentSummary  String?  @map("content_summary")
  totalWeight     Decimal? @db.Decimal(12, 2) @map("total_weight")
  totalCartons    Int?     @map("total_cartons")
  // ─── Format ───
  format          String   @default("PDF") // PDF, ZPL, PNG, DPL
  // ─── Print ───
  printStatus     String   @default("PENDING") // PENDING, PRINTED, FAILED
  printedAt       DateTime? @map("printed_at")
  printedById     String?  @db.Uuid @map("printed_by_id")
  // ─── Status ───
  status          String   @default("ACTIVE") // ACTIVE, VOID, REPRINTED
  // ─── Audit ───
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("shipping_labels")
  @@index([labelType, status], map: "idx_sl_type_status")
  @@index([packingJobId], map: "idx_sl_packing_job")
  @@index([carrierName], map: "idx_sl_carrier")
  @@index([status], map: "idx_sl_status")
}
