  lotId           String?  @db.Uuid @map("lot_id")
  serialNumberId  String?  @db.Uuid @map("serial_number_id")
  uomId           String?  @db.Uuid @map("uom_id")
  // ─── Quantities ───
  systemQuantity  Decimal  @db.Decimal(18, 4) @map("system_quantity")
  physicalQuantity Decimal @db.Decimal(18, 4) @map("physical_quantity")
  differenceQty   Decimal  @db.Decimal(18, 4) @default(0) @map("difference_qty")
  adjustmentQty   Decimal  @db.Decimal(18, 4) @default(0) @map("adjustment_qty")
  // ─── Cost ───
  unitCost        Decimal? @db.Decimal(18, 4) @map("unit_cost")
  adjustmentValue Decimal  @db.Decimal(18, 2) @default(0) @map("adjustment_value")
  // ─── Location ───
  locationId      String?  @db.Uuid @map("location_id")
  bin             String?
  // ─── Root cause ───
