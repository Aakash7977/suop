  // ─── Scope ───
  warehouseId     String?  @db.Uuid @map("warehouse_id")
  warehouseName   String?  @map("warehouse_name")
  // ─── Disposition ───
  disposition     String   @default("PENDING") @map("disposition") // PENDING, DESTROYED, DONATED, RETURNED_TO_SUPPLIER, ANIMAL_FEED, SOLD_AS_SCRAP
  disposalDate    DateTime? @map("disposal_date")
  disposalWitnessId String? @db.Uuid @map("disposal_witness_id")
  disposalWitnessName String? @map("disposal_witness_name")
  // ─── Status ───
  status          String   @default("PENDING_APPROVAL") // PENDING_APPROVAL, APPROVED, POSTED, DISPOSED, CANCELLED
  // ─── Category ───
  expiryCategory  String   @map("expiry_category") // EXPIRED, NEAR_EXPIRY, BLOCKED
  daysBeforeExpiry Int?    @map("days_before_expiry") // negative = already expired
