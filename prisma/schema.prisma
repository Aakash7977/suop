  resolution          String?  // REASSIGN, ESCALATE, CLOSE
  resolutionNotes     String?  @map("resolution_notes")
  resolvedById        String?  @db.Uuid @map("resolved_by_id")
  resolvedByName      String?  @map("resolved_by_name")
  resolvedAt          DateTime? @map("resolved_at")
  // ─── Escalation ───
  escalatedToId       String?  @db.Uuid @map("escalated_to_id")
  escalatedToName     String?  @map("escalated_to_name")
  escalatedAt         DateTime? @map("escalated_at")
  escalationLevel     Int      @default(0) @map("escalation_level")
  // ─── Impact ───
