// ─── Epic 8: Product Change History ─────────────────────
model ProductChangeHistory {
  id              String   @id @default(uuid()) @db.Uuid
  productId       String   @db.Uuid @map("product_id")
  // ─── Version ───
  version         Int
  // ─── Change ───
  changeType      String   @map("change_type") // CREATE, UPDATE, PRICE_CHANGE, CATEGORY_CHANGE, ARCHIVE, RESTORE, LIFECYCLE_TRANSITION
