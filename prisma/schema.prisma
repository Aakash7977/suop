// ═══════════════════════════════════════════════════════════
// SPRINT 15 — STOCK TRANSFER & IN-TRANSIT INVENTORY ENGINE
// Move inventory across warehouses, branches, bins, locations
// ═══════════════════════════════════════════════════════════

// ─── Epic 1: Stock Transfer Document ────────────────────
model StockTransfer {
  id              String   @id @default(uuid()) @db.Uuid
