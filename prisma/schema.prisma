  @@index([partnerId, addressType], map: "idx_bpa_partner_type")
  @@index([city, state], map: "idx_bpa_city_state")
  @@index([pincode], map: "idx_bpa_pincode")
}

// ─── Epic 3: Contact Management ─────────────────────────
model BusinessPartnerContact {
  id              String   @id @default(uuid()) @db.Uuid
  partnerId       String   @db.Uuid @map("partner_id")
  // ─── Identity ───
  firstName       String   @map("first_name")
  lastName        String?  @map("last_name")
  designation     String?
  department      String?
  // ─── Contact channels ───
