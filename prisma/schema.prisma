// ─── Epic 2: Cycle Count Plans ─────────────────────────
model CycleCountPlan {
  id              String   @id @default(uuid()) @db.Uuid
  planCode        String   @unique @map("plan_code")
  planName        String   @map("plan_name")
  description     String?
  // ─── Frequency ───
  frequency       String   // DAILY, WEEKLY, MONTHLY, QUARTERLY, YEARLY
  // ─── ABC Strategy ───
  abcClassA       String   @default("MONTHLY") @map("abc_class_a")
  abcClassB       String   @default("QUARTERLY") @map("abc_class_b")
  abcClassC       String   @default("YEARLY") @map("abc_class_c")
  // ─── Scope ───
  warehouseId     String?  @db.Uuid @map("warehouse_id")
  warehouseName   String?  @map("warehouse_name")
  // ─── Configuration ───
  varianceThreshold Decimal @db.Decimal(8, 2) @default(5) @map("variance_threshold") // % threshold for recount
  autoRecount     Boolean  @default(true) @map("auto_recount")
  blindCount      Boolean  @default(false) @map("blind_count")
  // ─── Status ───
  status          String   @default("ACTIVE")
  lastRunAt       DateTime? @map("last_run_at")
  nextRunAt       DateTime? @map("next_run_at")
  // ─── Audit ───
  createdById     String?  @db.Uuid @map("created_by_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  schedules       CycleCountSchedule[]

  @@map("cycle_count_plans")
  @@index([frequency, status], map: "idx_ccp_freq_status")
  @@index([warehouseId], map: "idx_ccp_warehouse")
  @@index([nextRunAt], map: "idx_ccp_next_run")
}

model CycleCountSchedule {
  id              String   @id @default(uuid()) @db.Uuid
  planId          String   @db.Uuid @map("plan_id")
  scheduleDate    DateTime @map("schedule_date")
  // ─── Scope ───
  abcClass        String?  @map("abc_class") // A, B, C
  zone            String?
  productCategoryId String? @db.Uuid @map("product_category_id")
  itemCount       Int      @default(0) @map("item_count")
  // ─── Status ───
  status          String   @default("SCHEDULED") // SCHEDULED, ASSIGNED, IN_PROGRESS, COMPLETED, SKIPPED
  assignedTeamId  String?  @db.Uuid @map("assigned_team_id")
  assignedTeamName String? @map("assigned_team_name")
  // ─── Result ───
  physicalInventoryId String? @db.Uuid @map("physical_inventory_id")
  accuracyPercent Decimal? @db.Decimal(5, 2) @map("accuracy_percent")
  // ─── Audit ───
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  plan            CycleCountPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@map("cycle_count_schedules")
  @@index([planId, scheduleDate], map: "idx_ccs_plan_date")
  @@index([status, scheduleDate], map: "idx_ccs_status_date")
  @@index([abcClass], map: "idx_ccs_abc")
}

// ─── Epic 5: Count Teams ───────────────────────────────
model CountTeam {
  id              String   @id @default(uuid()) @db.Uuid
  teamCode        String   @unique @map("team_code")
  teamName        String   @map("team_name")
  // ─── Members ───
  leaderId        String?  @db.Uuid @map("leader_id")
  leaderName      String?  @map("leader_name")
