  productionOrderNumber String  @map("production_order_number")
  // ─── Execution ───
  operatorId          String   @db.Uuid @map("operator_id")
  operatorCode        String   @map("operator_code")
  operatorName        String   @map("operator_name")
  machineId           String?  @db.Uuid @map("machine_id")
  machineCode         String?  @map("machine_code")
  workCenterCode      String   @map("work_center_code")
  // ─── Time ───
  scanTime            DateTime @default(now()) @map("scan_time")
  startTime           DateTime? @map("start_time")
  endTime             DateTime? @map("end_time")
  setupDurationMin    Int?     @map("setup_duration_min")
  runDurationMin      Int?     @map("run_duration_min")
  cleanupDurationMin  Int?     @map("cleanup_duration_min")
  downtimeMin         Int      @default(0) @map("downtime_min")
  // ─── Quantity ───
  inputQty            Decimal? @db.Decimal(14, 3) @map("input_qty")
  outputQty           Decimal? @db.Decimal(14, 3) @map("output_qty")
  scrapQty            Decimal? @db.Decimal(14, 3) @default(0) @map("scrap_qty")
  // ─── Quality ───
  qualityResult       String?  @map("quality_result") // PASS, FAIL, CONCERN
  qualityNotes        String?  @map("quality_notes")
  // ─── Status ───
  status              String   @default("SCANNED") // SCANNED, MATERIALS_VERIFIED, IN_PROGRESS, PAUSED, COMPLETED, FAILED
  remarks             String?
  // ─── Audit ───
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  logs                ExecutionLog[]

  @@map("work_order_execution")
  @@index([workOrderId], map: "idx_woe_wo")
  @@index([operatorId, status], map: "idx_woe_op_status")
  @@index([status], map: "idx_woe_status")
}

model ExecutionLog {
  id                  String   @id @default(uuid()) @db.Uuid
  executionId         String   @db.Uuid @map("execution_id")
  logType             String   @map("log_type") // SCAN, MATERIAL_CONSUMED, START, PAUSE, RESUME, COMPLETE, QUALITY_CHECK, EXCEPTION, DOWNTIME
