  partnerName         String?  @map("partner_name")
  carrierName         String?  @map("carrier_name")
  // ─── Gate ───
  gateNumber          String   @map("gate_number")
  warehouseId         String   @db.Uuid @map("warehouse_id")
  warehouseName       String   @map("warehouse_name")
  // ─── Security ───
  securityOfficerId   String?  @db.Uuid @map("security_officer_id")
  securityOfficerName String?  @map("security_officer_name")
  // ─── Pass ───
  gatePassNumber      String   @unique @map("gate_pass_number")
  passType            String   @default("QR") @map("pass_type") // QR, BARCODE, RFID, ANPR
  passQRCode          String?  @map("pass_qr_code")
  // ─── Verification ───
  documentsVerified   Boolean  @default(false) @map("documents_verified")
  vehicleInspected    Boolean  @default(false) @map("vehicle_inspected")
  sealVerified        Boolean  @default(false) @map("seal_verified")
  // ─── Photo Evidence ───
  photoFrontUrl       String?  @map("photo_front_url")
  photoBackUrl        String?  @map("photo_back_url")
  photoSideUrl        String?  @map("photo_side_url")
  photoSealUrl        String?  @map("photo_seal_url")
  // ─── Timing ───
  entryTime           DateTime @default(now()) @map("entry_time")
  expectedExitTime    DateTime? @map("expected_exit_time")
  // ─── Status ───
  status              String   @default("ENTERED") // ENTERED, IN_YARD, AT_DOCK, READY_TO_EXIT, EXITED, DENIED
  remarks             String?
  // ─── Audit ───
  createdAt           DateTime @default(now()) @map("created_at")

  gateExit            YardGateExit?

  @@map("yard_gate_entries")
  @@index([warehouseId, entryTime], map: "idx_yge_wh_time")
  @@index([vehicleNumber], map: "idx_yge_vehicle")
  @@index([status], map: "idx_yge_status")
}

model YardGateExit {
  id                  String   @id @default(uuid()) @db.Uuid
  exitNumber          String   @unique @map("exit_number")
  // ─── Link ───
  gateEntryId         String   @unique @db.Uuid @map("gate_entry_id")
  entryNumber         String   @map("entry_number")
  gatePassNumber      String   @map("gate_pass_number")
  // ─── Vehicle ───
  vehicleNumber       String   @map("vehicle_number")
  driverName          String   @map("driver_name")
  // ─── Security ───
  securityOfficerId   String?  @db.Uuid @map("security_officer_id")
  securityOfficerName String?  @map("security_officer_name")
  // ─── Verification ───
  sealVerified        Boolean  @default(false) @map("seal_verified")
  documentsVerified   Boolean  @default(false) @map("documents_verified")
  vehicleInspected    Boolean  @default(false) @map("vehicle_inspected")
  cargoVerified       Boolean  @default(false) @map("cargo_verified")
  // ─── Photo Evidence ───
  photoExitUrl        String?  @map("photo_exit_url")
  photoSealUrl        String?  @map("photo_seal_url")
  // ─── Timing ───
  exitTime            DateTime @default(now()) @map("exit_time")
  yardDurationMinutes Int?     @map("yard_duration_minutes")
  // ─── Status ───
