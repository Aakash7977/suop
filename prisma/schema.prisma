  // ─── Quantities ───
  requestedQty    Decimal  @db.Decimal(18, 4) @map("requested_qty")
  issuedQty       Decimal  @db.Decimal(18, 4) @default(0) @map("issued_qty")
  // ─── Location ───
  storageLocationId String? @db.Uuid @map("storage_location_id")
  storageLocationName String? @map("storage_location_name")
  bin             String?
