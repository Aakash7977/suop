  @@index([riskCategory], map: "idx_bpfp_risk")
  @@index([paymentMode], map: "idx_bpfp_payment_mode")
}

// ─── Epic 5: Compliance Management ──────────────────────
model BusinessPartnerCompliance {
  id              String   @id @default(uuid()) @db.Uuid
  partnerId       String   @db.Uuid @map("partner_id")
  // ─── Compliance type ───
  complianceType  String   @map("compliance_type") // GST, PAN, MSME, FSSAI, IEC, ISO, AGREEMENT, INSURANCE
  // ─── Details ───
  certificateNumber String @map("certificate_number")
  issuingAuthority String? @map("issuing_authority")
  issueDate       DateTime? @map("issue_date")
  expiryDate      DateTime? @map("expiry_date")
  // ─── Document ───
  documentUrl     String?  @map("document_url")
  documentVerified Boolean @default(false) @map("document_verified")
  verifiedById    String?  @db.Uuid @map("verified_by_id")
  verifiedAt      DateTime? @map("verified_at")
  // ─── Status ───
  status          String   @default("ACTIVE") // ACTIVE, EXPIRED, PENDING_VERIFICATION, REJECTED
  notes           String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  partner         BusinessPartner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@unique([partnerId, complianceType], map: "bpcomp_unique")
  @@map("business_partner_compliance")
  @@index([partnerId, status], map: "idx_bpcomp_partner_status")
  @@index([complianceType, status], map: "idx_bpcomp_type_status")
  @@index([expiryDate], map: "idx_bpcomp_expiry")
}

// ─── Epic 6: Customer & Supplier Classification ─────────
model CustomerGroup {
  id              String   @id @default(uuid()) @db.Uuid
  groupCode       String   @unique @map("group_code")
  groupName       String   @map("group_name")
  description     String?
  groupType       String   @default("CUSTOMER") // CUSTOMER, SUPPLIER
  discountPercent Decimal? @db.Decimal(5, 2) @map("discount_percent")
  paymentTermsDefault String? @map("payment_terms_default")
  status          String   @default("ACTIVE")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  members         BusinessPartnerGroupMembership[]

  @@map("customer_groups")
  @@index([groupType, status], map: "idx_cg_type_status")
}

// Join table for partner ↔ group
model BusinessPartnerGroupMembership {
  id              String   @id @default(uuid()) @db.Uuid
  partnerId       String   @db.Uuid @map("partner_id")
  groupId         String   @db.Uuid @map("group_id")
  assignedAt      DateTime @default(now()) @map("assigned_at")
  assignedById    String?  @db.Uuid @map("assigned_by_id")

  partner         BusinessPartner @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  group           CustomerGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([partnerId, groupId], map: "bpgm_unique")
  @@map("business_partner_group_memberships")
  @@index([groupId], map: "idx_bpgm_group")
}

// Partner Tags (flexible labels)
model PartnerTag {
  id              String   @id @default(uuid()) @db.Uuid
  tagName         String   @unique @map("tag_name")
  tagColor        String?  @map("tag_color")
  description     String?
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("partner_tags")
}

// ─── Epic 7: Payment & Banking ──────────────────────────
model BusinessPartnerBankAccount {
  id              String   @id @default(uuid()) @db.Uuid
  partnerId       String   @db.Uuid @map("partner_id")
  // ─── Account details ───
  accountName     String   @map("account_name")
  accountNumber   String   @map("account_number") // encrypted in production
  bankName        String   @map("bank_name")
  branchName      String?  @map("branch_name")
  ifscCode        String   @map("ifsc_code")
  swiftCode       String?  @map("swift_code")
  iban            String?
  // ─── UPI ───
  upiId           String?  @map("upi_id")
  // ─── Account type ───
  accountType     String   @default("SAVINGS") @map("account_type") // SAVINGS, CURRENT, CC, OD
  // ─── Default ───
  isDefault       Boolean  @default(false) @map("is_default")
  // ─── Verification ───
  isVerified      Boolean  @default(false) @map("is_verified")
  verifiedAt      DateTime? @map("verified_at")
  verifiedById    String?  @db.Uuid @map("verified_by_id")
  // ─── Status ───
  status          String   @default("ACTIVE")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  partner         BusinessPartner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@map("business_partner_bank_accounts")
  @@index([partnerId, status], map: "idx_bpba_partner_status")
  @@index([ifscCode], map: "idx_bpba_ifsc")
}

// ─── Epic 8: Business Partner Relationships ─────────────
model BusinessPartnerRelationship {
  id              String   @id @default(uuid()) @db.Uuid
  fromPartnerId   String   @db.Uuid @map("from_partner_id")
  toPartnerId     String   @db.Uuid @map("to_partner_id")
  // ─── Relationship type ───
  relationshipType String  @map("relationship_type") // PARENT_COMPANY, SUBSIDIARY, DISTRIBUTOR, DEALER, FRANCHISE, PREFERRED_SUPPLIER, STRATEGIC_PARTNER, SISTER_CONCERN, JV_PARTNER
  // ─── Validity ───
  validFrom       DateTime @default(now()) @map("valid_from")
  validTo         DateTime? @map("valid_to")
  // ─── Notes ───
  notes           String?
  status          String   @default("ACTIVE")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  fromPartner     BusinessPartner @relation("BPRelFrom", fields: [fromPartnerId], references: [id], onDelete: Cascade)
  toPartner       BusinessPartner @relation("BPRelTo", fields: [toPartnerId], references: [id], onDelete: Cascade)

  @@unique([fromPartnerId, toPartnerId, relationshipType], map: "bprel_unique")
  @@map("business_partner_relationships")
  @@index([fromPartnerId], map: "idx_bprel_from")
  @@index([toPartnerId], map: "idx_bprel_to")
  @@index([relationshipType], map: "idx_bprel_type")
}

// ─── Epic 9: Business Partner Evaluation (Scorecards) ───
model BusinessPartnerScorecard {
  id              String   @id @default(uuid()) @db.Uuid
  partnerId       String   @db.Uuid @map("partner_id")
  // ─── Period ───
  periodYear      Int      @map("period_year")
  periodQuarter   Int?     @map("period_quarter") // 1-4, null for annual
  // ─── Metrics ───
  onTimeDeliveryRating Decimal? @db.Decimal(5, 2) @map("on_time_delivery_rating") // 0-100
  orderAccuracyRating  Decimal? @db.Decimal(5, 2) @map("order_accuracy_rating")
  qualityRating        Decimal? @db.Decimal(5, 2) @map("quality_rating")
  complaintRate        Decimal? @db.Decimal(5, 2) @map("complaint_rate") // % of orders with complaints
  paymentHistoryRating Decimal? @db.Decimal(5, 2) @map("payment_history_rating")
  responseTimeRating   Decimal? @db.Decimal(5, 2) @map("response_time_rating")
  // ─── Computed ───
  riskScore            Decimal? @db.Decimal(5, 2) @map("risk_score")
  overallScore         Decimal? @db.Decimal(5, 2) @map("overall_score")
  performanceGrade     String?  @map("performance_grade") // A+, A, B, C, D
  // ─── Counts ───
  totalOrders          Int      @default(0) @map("total_orders")
  totalOrderValue      Decimal  @db.Decimal(18, 2) @default(0) @map("total_order_value")
  totalComplaints      Int      @default(0) @map("total_complaints")
  totalReturns         Int      @default(0) @map("total_returns")
  // ─── Review ───
  reviewedById         String?  @db.Uuid @map("reviewed_by_id")
  reviewedAt           DateTime? @map("reviewed_at")
  reviewNotes          String?  @map("review_notes")
  // ─── Audit ───
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  partner              BusinessPartner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@unique([partnerId, periodYear, periodQuarter], map: "bps_unique_period")
  @@map("business_partner_scorecards")
  @@index([partnerId, periodYear], map: "idx_bps_partner_year")
  @@index([overallScore], map: "idx_bps_score")
  @@index([performanceGrade], map: "idx_bps_grade")
}

// ═══════════════════════════════════════════════════════════
// SPRINT 10 — ENTERPRISE IDENTIFICATION, BARCODE & TRACEABILITY
// Barcodes, QR Codes, Batches, Lots, Serial Numbers, GS1,
// Label Templates, Print Jobs, Traceability Engine
// ═══════════════════════════════════════════════════════════

// ─── Epic 1: Barcode Master ─────────────────────────────
model BarcodeType {
  id              String   @id @default(uuid()) @db.Uuid
  code            String   @unique // EAN_13, EAN_8, UPC_A, UPC_E, CODE_128, CODE_39, GS1_128, ITF_14, INTERNAL
  name            String
  description     String?
  format          String?  // Regex pattern or length rule
  length          Int?
  requiresChecksum Boolean @default(false) @map("requires_checksum")
  isGs1Standard   Boolean  @default(false) @map("is_gs1_standard")
  status          String   @default("ACTIVE")
  createdAt       DateTime @default(now()) @map("created_at")

  barcodes        Barcode[]

  @@map("barcode_types")
}

model Barcode {
  id              String   @id @default(uuid()) @db.Uuid
  barcode         String   @unique
  barcodeTypeId   String   @db.Uuid @map("barcode_type_id")
  // ─── Link to product/variant ───
  productId       String?  @db.Uuid @map("product_id")
  productVariantId String? @db.Uuid @map("product_variant_id")
  uomId           String?  @db.Uuid @map("uom_id")
  // ─── Flags ───
  isPrimary       Boolean  @default(false) @map("is_primary")
  status          String   @default("ACTIVE") // ACTIVE, INACTIVE, RECALLED
  // ─── Validity ───
  effectiveDate   DateTime @default(now()) @map("effective_date")
  expiryDate      DateTime? @map("expiry_date")
  // ─── Audit ───
  createdById     String?  @db.Uuid @map("created_by_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  barcodeType     BarcodeType @relation(fields: [barcodeTypeId], references: [id])
  assignments     BarcodeAssignment[]

  @@map("barcodes")
  @@index([productId, isPrimary], map: "idx_bc_product_primary")
  @@index([barcodeTypeId], map: "idx_bc_type")
  @@index([status], map: "idx_bc_status")
}

model BarcodeAssignment {
  id              String   @id @default(uuid()) @db.Uuid
  barcodeId       String   @db.Uuid @map("barcode_id")
  // ─── Context ───
  entityType      String   @map("entity_type") // PRODUCT, VARIANT, BATCH, LOT, SERIAL, LOCATION, ASSET
  entityId        String   @db.Uuid @map("entity_id")
  // ─── Scope ───
  companyId       String?  @db.Uuid @map("company_id")
  branchId        String?  @db.Uuid @map("branch_id")
  assignedAt      DateTime @default(now()) @map("assigned_at")
  assignedById    String?  @db.Uuid @map("assigned_by_id")

  barcode         Barcode  @relation(fields: [barcodeId], references: [id], onDelete: Cascade)

  @@map("barcode_assignments")
  @@index([entityType, entityId], map: "idx_bca_entity")
  @@index([barcodeId], map: "idx_bca_barcode")
}

// ─── Epic 2: QR Code Platform ──────────────────────────
model QrCode {
  id              String   @id @default(uuid()) @db.Uuid
  qrCode          String   @unique
  // ─── Purpose ───
  purpose         String   // PRODUCT, BATCH, WAREHOUSE, LOCATION, ASSET, ORDER, INVOICE
  // ─── Link ───
  entityType      String   @map("entity_type")
  entityId        String?  @db.Uuid @map("entity_id")
  // ─── Data ───
  qrData          Json     @map("qr_data") // Encoded payload
  // ─── Encryption ───
  isEncrypted     Boolean  @default(false) @map("is_encrypted")
  encryptionMethod String? @map("encryption_method")
  // ─── Validity ───
  effectiveDate   DateTime @default(now()) @map("effective_date")
  expiryDate      DateTime? @map("expiry_date")
  // ─── Scan tracking ───
  scanCount       Int      @default(0) @map("scan_count")
  lastScannedAt   DateTime? @map("last_scanned_at")
  // ─── Status ───
  status          String   @default("ACTIVE")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("qr_codes")
  @@index([purpose, status], map: "idx_qr_purpose_status")
  @@index([entityType, entityId], map: "idx_qr_entity")
  @@index([expiryDate], map: "idx_qr_expiry")
}

// ─── Epic 3: Batch Management ──────────────────────────
model Batch {
  id              String   @id @default(uuid()) @db.Uuid
  batchNumber     String   @unique
  // ─── Product link ───
  productId       String   @db.Uuid @map("product_id")
  productVariantId String? @db.Uuid @map("product_variant_id")
  // ─── Dates ───
  manufacturingDate DateTime @map("manufacturing_date")
  expiryDate      DateTime @map("expiry_date")
  bestBeforeDate  DateTime? @map("best_before_date")
  // ─── Quantity ───
  quantityProduced Decimal @db.Decimal(18, 4) @map("quantity_produced")
  quantityRemaining Decimal @db.Decimal(18, 4) @default(0) @map("quantity_remaining")
  uomId           String?  @db.Uuid @map("uom_id")
  // ─── Origin ───
  manufacturingOrderId String? @map("manufacturing_order_id")
  warehouseId     String?  @db.Uuid @map("warehouse_id")
  branchId        String?  @db.Uuid @map("branch_id")
  // ─── Status ───
  status          String   @default("PLANNED") // PLANNED, PRODUCED, RELEASED, QUARANTINED, BLOCKED, CONSUMED, EXPIRED
  statusReason    String?  @map("status_reason")
  // ─── Quality ───
  qualityGrade    String?  @map("quality_grade") // A, B, C, REJECT
  inspectedBy     String?  @db.Uuid @map("inspected_by")
  inspectedAt     DateTime? @map("inspected_at")
  // ─── Audit ───
  createdById     String?  @db.Uuid @map("created_by_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  lots            Lot[]
  traceabilityLogs TraceabilityLog[]

  @@map("batches")
  @@index([productId, status], map: "idx_batch_product_status")
  @@index([batchNumber], map: "idx_batch_number")
  @@index([expiryDate], map: "idx_batch_expiry")
  @@index([manufacturingDate], map: "idx_batch_mfg")
  @@index([status], map: "idx_batch_status")
}

// ─── Epic 4: Lot Management ────────────────────────────
model Lot {
  id              String   @id @default(uuid()) @db.Uuid
  lotNumber       String   @unique
  // ─── Hierarchy ───
  batchId         String?  @db.Uuid @map("batch_id")
  productId       String   @db.Uuid @map("product_id")
  productVariantId String? @db.Uuid @map("product_variant_id")
  // ─── Lot type ───
  lotType         String   @map("lot_type") // SUPPLIER_LOT, PRODUCTION_LOT, WAREHOUSE_LOT, RETURN_LOT, INSPECTION_LOT
  // ─── Supplier (for SUPPLIER_LOT) ───
  supplierId      String?  @db.Uuid @map("supplier_id")
  supplierInvoiceNumber String? @map("supplier_invoice_number")
  // ─── Quantity ───
  quantityReceived Decimal @db.Decimal(18, 4) @map("quantity_received")
  quantityRemaining Decimal @db.Decimal(18, 4) @default(0) @map("quantity_remaining")
  uomId           String?  @db.Uuid @map("uom_id")
  // ─── Dates ───
  receivedDate    DateTime? @map("received_date")
  manufacturingDate DateTime? @map("manufacturing_date")
  expiryDate      DateTime? @map("expiry_date")
  // ─── Quality ───
  qualityStatus   String   @default("PENDING") // PENDING, PASSED, FAILED, QUARANTINED
  inspectionNotes String?  @map("inspection_notes")
  // ─── Status ───
  status          String   @default("ACTIVE")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  batch           Batch?   @relation(fields: [batchId], references: [id], onDelete: SetNull)

  @@map("lots")
  @@index([batchId], map: "idx_lot_batch")
  @@index([productId], map: "idx_lot_product")
  @@index([lotType, status], map: "idx_lot_type_status")
  @@index([supplierId], map: "idx_lot_supplier")
}

// ─── Epic 5: Serial Number Management ──────────────────
model SerialNumber {
  id              String   @id @default(uuid()) @db.Uuid
  serialNumber    String   @unique
  // ─── Asset/product ───
  productId       String   @db.Uuid @map("product_id")
  productVariantId String? @db.Uuid @map("product_variant_id")
  // ─── Context ───
  entityType      String   @map("entity_type") // MACHINE, EQUIPMENT, ELECTRONICS, HIGH_VALUE_ITEM
  entityId        String?  @db.Uuid @map("entity_id")
  // ─── Warranty ───
  warrantyStart   DateTime? @map("warranty_start")
  warrantyEnd     DateTime? @map("warranty_end")
  warrantyDays    Int?
  // ─── Service ───
  serviceHistory  Json     @default("[]") @map("service_history")
  lastServiceDate DateTime? @map("last_service_date")
  nextServiceDate DateTime? @map("next_service_date")
  // ─── Location ───
  currentLocation String?  @map("current_location")
  currentBranchId String?  @db.Uuid @map("current_branch_id")
  // ─── Status ───
  status          String   @default("ACTIVE") // ACTIVE, IN_SERVICE, UNDER_REPAIR, RETIRED, LOST, STOLEN
  // ─── Audit ───
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("serial_numbers")
  @@index([productId, status], map: "idx_sn_product_status")
  @@index([serialNumber], map: "idx_sn_serial")
  @@index([entityType], map: "idx_sn_entity_type")
  @@index([warrantyEnd], map: "idx_sn_warranty_end")
}

// ─── Epic 6: GS1 Standards ─────────────────────────────
model Gs1Identifier {
  id              String   @id @default(uuid()) @db.Uuid
  gs1Type         String   @map("gs1_type") // GTIN, GLN, SSCC, GS1_128
  identifier      String   @unique
  // ─── Application Identifiers (for GS1-128) ───
  applicationIdentifiers Json? @map("application_identifiers")
  // ─── Link ───
  entityType      String   @map("entity_type") // PRODUCT, LOCATION, LOGISTIC_UNIT, ASSET
  entityId        String?  @db.Uuid @map("entity_id")
  // ─── Company prefix ───
  companyPrefix   String   @map("company_prefix")
  checkDigit      String   @map("check_digit")
  // ─── Status ───
  status          String   @default("ACTIVE")
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("gs1_identifiers")
  @@index([gs1Type, status], map: "idx_gs1_type_status")
  @@index([companyPrefix], map: "idx_gs1_company")
  @@index([entityType, entityId], map: "idx_gs1_entity")
}

// ─── Epic 7: Label Management ──────────────────────────
model LabelTemplate {
  id              String   @id @default(uuid()) @db.Uuid
  templateCode    String   @unique @map("template_code")
  templateName    String   @map("template_name")
  // ─── Type ───
  labelType       String   @map("label_type") // PRODUCT, SHELF, PALLET, BATCH, LOCATION, SHIPPING, QR, BARCODE
  // ─── Format ───
  printFormat     String   @map("print_format") // A4, THERMAL, ZEBRA, BROTHER, PDF
  widthMm         Decimal  @db.Decimal(10, 2) @map("width_mm")
  heightMm        Decimal  @db.Decimal(10, 2) @map("height_mm")
  // ─── Layout ───
  layout          Json     // { fields: [...], positions: [...], styling: {...} }
  // ─── Content ───
  fields          Json     @default("[]") // Array of { name, source, format }
  // ─── Approval ───
  status          String   @default("DRAFT") // DRAFT, PENDING_APPROVAL, APPROVED, PUBLISHED, ARCHIVED
  approvedById    String?  @db.Uuid @map("approved_by_id")
  approvedAt      DateTime? @map("approved_at")
  // ─── Version ───
  version         Int      @default(1)
  // ─── Audit ───
  createdById     String?  @db.Uuid @map("created_by_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  printJobs       LabelPrintJob[]

  @@map("label_templates")
  @@index([labelType, status], map: "idx_lt_type_status")
  @@index([printFormat], map: "idx_lt_format")
}

model LabelPrintJob {
  id              String   @id @default(uuid()) @db.Uuid
  templateId      String   @db.Uuid @map("template_id")
  // ─── Print context ───
  printMode       String   @map("print_mode") // SINGLE, BULK, AUTO, SCHEDULED, REPRINT
  // ─── Target ───
  entityType      String   @map("entity_type") // PRODUCT, BATCH, LOT, LOCATION, ASSET
  entityIds       String[] @default([]) @map("entity_ids")
  // ─── Printer ───
  printerType     String   @map("printer_type") // THERMAL, LASER, INKJET, BLUETOOTH, NETWORK
  printerName     String   @map("printer_name")
  // ─── Counts ───
  copiesPerEntity Int      @default(1) @map("copies_per_entity")
  totalCopies     Int      @default(0) @map("total_copies")
  printedCopies   Int      @default(0) @map("printed_copies")
  // ─── Status ───
  status          String   @default("QUEUED") // QUEUED, PRINTING, COMPLETED, FAILED, CANCELLED
  errorMessage    String?  @map("error_message")
  // ─── Schedule ───
  scheduledAt     DateTime? @map("scheduled_at")
  startedAt       DateTime? @map("started_at")
  completedAt     DateTime? @map("completed_at")
  // ─── Audit ───
  requestedById   String?  @db.Uuid @map("requested_by_id")
  createdAt       DateTime @default(now()) @map("created_at")

  template        LabelTemplate @relation(fields: [templateId], references: [id])

  @@map("label_print_jobs")
  @@index([templateId, status], map: "idx_lpj_template_status")
  @@index([status, scheduledAt], map: "idx_lpj_status_scheduled")
  @@index([printerName], map: "idx_lpj_printer")
}

// ─── Epic 9: Traceability Engine ───────────────────────
model TraceabilityLog {
  id              String   @id @default(uuid()) @db.Uuid
  // ─── Entity being tracked ───
  entityType      String   @map("entity_type") // RAW_MATERIAL, BATCH, LOT, SERIAL, FINISHED_GOOD, INVOICE, CUSTOMER
  entityId        String   @db.Uuid @map("entity_id")
  entityName      String   @map("entity_name")
  // ─── Batch link (most common traceability unit) ───
  batchId         String?  @db.Uuid @map("batch_id")
  // ─── Movement ───
  eventType       String   @map("event_type") // PURCHASE_RECEIPT, WAREHOUSE_IN, PRODUCTION_INPUT, PRODUCTION_OUTPUT, WAREHOUSE_TRANSFER, SALES_DISPATCH, CUSTOMER_DELIVERY, RETURN, RECALL, QUALITY_HOLD, DISPOSAL
  // ─── From / To ───
  fromEntityType  String?  @map("from_entity_type")
  fromEntityId    String?  @db.Uuid @map("from_entity_id")
  fromEntityName  String?  @map("from_entity_name")
  toEntityType    String?  @map("to_entity_type")
  toEntityId      String?  @db.Uuid @map("to_entity_id")
  toEntityName    String?  @map("to_entity_name")
  // ─── Quantity ───
  quantity        Decimal? @db.Decimal(18, 4)
  uomId           String?  @db.Uuid @map("uom_id")
  // ─── References ───
  referenceType   String?  @map("reference_type") // PURCHASE_ORDER, PRODUCTION_ORDER, SALES_ORDER, INVOICE, TRANSFER_ORDER
  referenceNumber String?  @map("reference_number")
  // ─── Location ───
  warehouseId     String?  @db.Uuid @map("warehouse_id")
  branchId        String?  @db.Uuid @map("branch_id")
  // ─── Partner ───
  partnerId       String?  @db.Uuid @map("partner_id")
  partnerName     String?  @map("partner_name")
  // ─── Notes ───
  notes           String?
  // ─── Audit ───
  eventDate       DateTime @default(now()) @map("event_date")
  recordedById    String?  @db.Uuid @map("recorded_by_id")
  createdAt       DateTime @default(now()) @map("created_at")

  batch           Batch?   @relation(fields: [batchId], references: [id], onDelete: SetNull)

  @@map("traceability_logs")
  @@index([entityType, entityId], map: "idx_tl_entity")
  @@index([batchId], map: "idx_tl_batch")
  @@index([eventType], map: "idx_tl_event_type")
  @@index([eventDate], map: "idx_tl_event_date")
  @@index([partnerId], map: "idx_tl_partner")
  @@index([referenceNumber], map: "idx_tl_reference")
}

// ═══════════════════════════════════════════════════════════
// SPRINT 11 — DATA GOVERNANCE, LIFECYCLE & MASTER DATA QUALITY
// Product Lifecycle, Approval Workflows, Import/Export Engine,
// Validation Framework, Duplicate Detection & Merge,
// Audit Trail, Quality Dashboard, Change History
// ═══════════════════════════════════════════════════════════

// ─── Epic 1: Product Lifecycle Management ───────────────
model ProductLifecycle {
  id              String   @id @default(uuid()) @db.Uuid
  productId       String   @db.Uuid @unique @map("product_id")
  // ─── Lifecycle state ───
  currentState    String   @map("current_state") // DRAFT, UNDER_REVIEW, APPROVED, PUBLISHED, ACTIVE, INACTIVE, DISCONTINUED, ARCHIVED
  previousState   String?  @map("previous_state")
  // ─── State timestamps ───
  submittedAt     DateTime? @map("submitted_at")
  approvedAt      DateTime? @map("approved_at")
  publishedAt     DateTime? @map("published_at")
  activatedAt     DateTime? @map("activated_at")
  inactivatedAt   DateTime? @map("inactivated_at")
  discontinuedAt  DateTime? @map("discontinued_at")
  archivedAt      DateTime? @map("archived_at")
  // ─── Reason for current state ───
  stateReason     String?  @map("state_reason")
  // ─── Audit ───
  createdById     String?  @db.Uuid @map("created_by_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  history         ProductLifecycleHistory[]

  @@map("product_lifecycle")
  @@index([currentState], map: "idx_plc_state")
}

model ProductLifecycleHistory {
  id              String   @id @default(uuid()) @db.Uuid
  lifecycleId     String   @db.Uuid @map("lifecycle_id")
  productId       String   @db.Uuid @map("product_id")
  // ─── Transition ───
  fromState       String   @map("from_state")
  toState         String   @map("to_state")
  // ─── Actor ───
  changedById     String?  @db.Uuid @map("changed_by_id")
  changedByName   String?  @map("changed_by_name")
  // ─── Context ───
  reason          String?
  comments        String?
  ipAddress       String?  @map("ip_address")
  // ─── Approval link ───
  approvalStepId  String?  @db.Uuid @map("approval_step_id")
  // ─── Timestamp ───
  changedAt       DateTime @default(now()) @map("changed_at")

  lifecycle       ProductLifecycle @relation(fields: [lifecycleId], references: [id], onDelete: Cascade)

  @@map("product_lifecycle_history")
  @@index([productId, changedAt], map: "idx_plh_product_time")
  @@index([fromState, toState], map: "idx_plh_transition")
}

// ─── Epic 2: Product Approval Workflow ──────────────────
model ProductApprovalWorkflow {
  id              String   @id @default(uuid()) @db.Uuid
  productId       String   @db.Uuid @map("product_id")
  productName     String   @map("product_name")
  // ─── Workflow config ───
  workflowType    String   @map("workflow_type") // STANDARD, PARALLEL, CONDITIONAL
  isParallel      Boolean  @default(false) @map("is_parallel")
  // ─── Current state ───
  currentStage    String   @default("CREATOR") @map("current_stage") // CREATOR, REVIEWER, QA, COMPLIANCE, FINANCE, PUBLISHER
  status          String   @default("PENDING") // PENDING, IN_REVIEW, APPROVED, REJECTED, PUBLISHED, CANCELLED
  // ─── SLA ───
  slaDueAt        DateTime @map("sla_due_at")
  slaBreached     Boolean  @default(false) @map("sla_breached")
  // ─── Audit ───
  initiatedById   String?  @db.Uuid @map("initiated_by_id")
  initiatedAt     DateTime @default(now()) @map("initiated_at")
  completedAt     DateTime? @map("completed_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  steps           ProductApprovalStep[]
  logs            ProductApprovalLog[]

  @@map("product_approval_workflows")
  @@index([productId, status], map: "idx_paw_product_status")
  @@index([currentStage, status], map: "idx_paw_stage_status")
  @@index([slaDueAt, slaBreached], map: "idx_paw_sla")
}

model ProductApprovalStep {
  id              String   @id @default(uuid()) @db.Uuid
  workflowId      String   @db.Uuid @map("workflow_id")
  // ─── Step config ───
  stepOrder       Int      @map("step_order")
  stepName        String   @map("step_name") // CREATOR, REVIEWER, QA, COMPLIANCE, FINANCE, PUBLISHER
  stepType        String   @map("step_type") // SEQUENTIAL, PARALLEL, CONDITIONAL
  // ─── Approver ───
  approverId      String?  @db.Uuid @map("approver_id")
  approverRole    String?  @map("approver_role")
  // ─── Decision ───
  decision        String?  // PENDING, APPROVED, REJECTED, SKIPPED
  decisionComments String? @map("decision_comments")
  decidedAt       DateTime? @map("decided_at")
  // ─── Condition (for CONDITIONAL type) ───
  conditionExpression String? @map("condition_expression")
  isRequired      Boolean  @default(true) @map("is_required")

  workflow        ProductApprovalWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@map("product_approval_steps")
  @@index([workflowId, stepOrder], map: "idx_pas_workflow_order")
  @@index([decision], map: "idx_pas_decision")
}

model ProductApprovalLog {
  id              String   @id @default(uuid()) @db.Uuid
  workflowId      String   @db.Uuid @map("workflow_id")
  stepId          String?  @db.Uuid @map("step_id")
  // ─── Action ───
  action          String   // SUBMITTED, APPROVED, REJECTED, SKIPPED, COMMENTED, REASSIGNED
  stepName        String   @map("step_name")
  // ─── Actor ───
  actorId         String?  @db.Uuid @map("actor_id")
  actorName       String?  @map("actor_name")
  // ─── Details ───
  comments        String?
  ipAddress       String?  @map("ip_address")
  actionAt        DateTime @default(now()) @map("action_at")

  workflow        ProductApprovalWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@map("product_approval_logs")
  @@index([workflowId, actionAt], map: "idx_pal_workflow_time")
  @@index([action], map: "idx_pal_action")
}

// ─── Epic 3: Bulk Import & Export Engine ────────────────
model ImportJob {
  id              String   @id @default(uuid()) @db.Uuid
  jobCode         String   @unique @map("job_code")
  // ─── Source ───
  entityType      String   @map("entity_type") // PRODUCT, BUSINESS_PARTNER, PRICE_LIST, etc.
  fileName        String   @map("file_name")
  fileSizeBytes   Int      @map("file_size_bytes")
  fileFormat      String   @map("file_format") // EXCEL, CSV
  // ─── Progress ───
  totalRows       Int      @default(0) @map("total_rows")
  processedRows   Int      @default(0) @map("processed_rows")
  successRows     Int      @default(0) @map("success_rows")
  errorRows       Int      @default(0) @map("error_rows")
  duplicateRows   Int      @default(0) @map("duplicate_rows")
  // ─── Status ───
  status          String   @default("QUEUED") // QUEUED, VALIDATING, PREVIEWING, IMPORTING, COMPLETED, FAILED, ROLLBACK
  // ─── Rollback ───
  isRollbackable  Boolean  @default(true) @map("is_rollbackable")
  rolledBackAt    DateTime? @map("rolled_back_at")
  rolledBackById  String?  @db.Uuid @map("rolled_back_by_id")
  rollbackReason  String?  @map("rollback_reason")
  // ─── Validation summary ───
  validationSummary Json?  @map("validation_summary")
  // ─── Audit ───
  initiatedById   String?  @db.Uuid @map("initiated_by_id")
  initiatedAt     DateTime @default(now()) @map("initiated_at")
  completedAt     DateTime? @map("completed_at")
  createdAt       DateTime @default(now()) @map("created_at")

  errors          ImportError[]

  @@map("import_jobs")
  @@index([entityType, status], map: "idx_ij_entity_status")
  @@index([status, initiatedAt], map: "idx_ij_status_time")
}

model ExportJob {
  id              String   @id @default(uuid()) @db.Uuid
  jobCode         String   @unique @map("job_code")
  // ─── Source ───
  entityType      String   @map("entity_type")
  // ─── Filters ───
  filters         Json     @default("{}")
  // ─── Output ───
  fileFormat      String   @map("file_format") // EXCEL, CSV, PDF, JSON
  fileName        String   @map("file_name")
  fileUrl         String?  @map("file_url")
  fileSizeBytes   Int?     @map("file_size_bytes")
  // ─── Progress ───
  totalRows       Int      @default(0) @map("total_rows")
  exportedRows    Int      @default(0) @map("exported_rows")
  // ─── Status ───
  status          String   @default("QUEUED") // QUEUED, EXPORTING, COMPLETED, FAILED
  // ─── Audit ───
  initiatedById   String?  @db.Uuid @map("initiated_by_id")
  initiatedAt     DateTime @default(now()) @map("initiated_at")
  completedAt     DateTime? @map("completed_at")
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("export_jobs")
  @@index([entityType, status], map: "idx_ej_entity_status")
  @@index([status], map: "idx_ej_status")
}

model ImportError {
  id              String   @id @default(uuid()) @db.Uuid
  importJobId     String   @db.Uuid @map("import_job_id")
  // ─── Error location ───
  rowNumber       Int      @map("row_number")
  columnName      String?  @map("column_name")
  // ─── Error details ───
  errorType       String   @map("error_type") // VALIDATION, DUPLICATE, MISSING_REQUIRED, INVALID_FORMAT, BUSINESS_RULE
  errorMessage    String   @map("error_message")
  errorValue      String?  @map("error_value")
  // ─── Severity ───
  severity        String   @default("ERROR") // ERROR, WARNING
  createdAt       DateTime @default(now()) @map("created_at")

  importJob       ImportJob @relation(fields: [importJobId], references: [id], onDelete: Cascade)

  @@map("import_errors")
  @@index([importJobId, rowNumber], map: "idx_ie_job_row")
  @@index([errorType, severity], map: "idx_ie_type_severity")
}

// ─── Epic 4: Data Validation Framework ──────────────────
model ValidationRule {
  id              String   @id @default(uuid()) @db.Uuid
  ruleCode        String   @unique @map("rule_code")
  ruleName        String   @map("rule_name")
  description     String?
  // ─── Scope ───
  entityType      String   @map("entity_type") // PRODUCT, BUSINESS_PARTNER, PRICE_LIST, etc.
  fieldName       String   @map("field_name")
  // ─── Rule type ───
  ruleType        String   @map("rule_type") // REQUIRED, UNIQUE, RANGE, REGEX, BUSINESS_RULE, CROSS_REFERENCE
  // ─── Rule config ───
  ruleConfig      Json     @map("rule_config") // { pattern, min, max, crossRef, etc. }
  // ─── Enforcement ───
  severity        String   @default("ERROR") // ERROR, WARNING
  enforcementMode String   @default("BLOCK") @map("enforcement_mode") // BLOCK, WARN, LOG
  // ─── Status ───
  status          String   @default("ACTIVE")
  // ─── Audit ───
  createdById     String?  @db.Uuid @map("created_by_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  results         ValidationResult[]

  @@map("validation_rules")
  @@index([entityType, fieldName], map: "idx_vr_entity_field")
  @@index([ruleType, status], map: "idx_vr_type_status")
}

model ValidationResult {
  id              String   @id @default(uuid()) @db.Uuid
  ruleId          String   @db.Uuid @map("rule_id")
  // ─── Entity being validated ───
  entityType      String   @map("entity_type")
  entityId        String   @db.Uuid @map("entity_id")
  entityName      String   @map("entity_name")
  // ─── Result ───
  isValid         Boolean  @map("is_valid")
  errorMessage    String?  @map("error_message")
  fieldValue      String?  @map("field_value")
  // ─── Context ───
  validationBatch String?  @map("validation_batch")
  // ─── Audit ───
  validatedAt     DateTime @default(now()) @map("validated_at")

  rule            ValidationRule @relation(fields: [ruleId], references: [id])

  @@map("validation_results")
  @@index([entityType, entityId, isValid], map: "idx_vres_entity_valid")
  @@index([ruleId, isValid], map: "idx_vres_rule_valid")
  @@index([validationBatch], map: "idx_vres_batch")
}

// ─── Epic 5: Duplicate Detection & Merge ────────────────
model DuplicateCandidate {
  id              String   @id @default(uuid()) @db.Uuid
  // ─── Primary record ───
  primaryEntityType String  @map("primary_entity_type")
  primaryEntityId   String  @db.Uuid @map("primary_entity_id")
  primaryEntityName String  @map("primary_entity_name")
  // ─── Duplicate record ───
  duplicateEntityType String @map("duplicate_entity_type")
  duplicateEntityId   String @db.Uuid @map("duplicate_entity_id")
  duplicateEntityName String @map("duplicate_entity_name")
  // ─── Detection ───
  detectionRule   String   @map("detection_rule") // NAME, SKU, BARCODE, HSN, BRAND, SIMILAR_NAME
  matchScore      Decimal  @db.Decimal(5, 2) @map("match_score") // 0-100
  matchedFields   Json     @default("[]") @map("matched_fields")
  // ─── Resolution ───
  resolutionStatus String  @default("PENDING") @map("resolution_status") // PENDING, MERGED, IGNORED, FALSE_POSITIVE
  resolutionAction String? @map("resolution_action") // KEEP_PRIMARY, MERGE, ARCHIVE_DUPLICATE
  resolvedById    String?  @db.Uuid @map("resolved_by_id")
  resolvedAt      DateTime? @map("resolved_at")
  resolutionNotes String?  @map("resolution_notes")
  // ─── Audit ───
  detectedAt      DateTime @default(now()) @map("detected_at")
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("duplicate_candidates")
  @@index([primaryEntityType, primaryEntityId], map: "idx_dc_primary")
  @@index([duplicateEntityType, duplicateEntityId], map: "idx_dc_duplicate")
  @@index([resolutionStatus], map: "idx_dc_resolution")
  @@index([matchScore], map: "idx_dc_score")
}

model MergeHistory {
  id              String   @id @default(uuid()) @db.Uuid
  // ─── Merge operation ───
  entityType      String   @map("entity_type")
  primaryEntityId String   @db.Uuid @map("primary_entity_id")
  mergedEntityId  String   @db.Uuid @map("merged_entity_id")
  primaryEntityName String @map("primary_entity_name")
  mergedEntityName  String @map("merged_entity_name")
  // ─── Merge details ───
  fieldsMerged    Json     @default("[]") @map("fields_merged")
  referencesMoved Json     @default("[]") @map("references_moved")
  // ─── Post-merge action ───
  duplicateAction String   @map("duplicate_action") // ARCHIVED, DELETED, KEPT_INACTIVE
  // ─── Audit ───
  mergedById      String?  @db.Uuid @map("merged_by_id")
  mergedByName    String?  @map("merged_by_name")
  mergedAt        DateTime @default(now()) @map("merged_at")
  ipAddress       String?  @map("ip_address")
  notes           String?

  @@map("merge_history")
  @@index([entityType, primaryEntityId], map: "idx_mh_entity_primary")
  @@index([mergedAt], map: "idx_mh_time")
}

// ─── Epic 6: Master Data Audit Trail ────────────────────
model MasterDataAudit {
  id              String   @id @default(uuid()) @db.Uuid
  // ─── Entity ───
  entityType      String   @map("entity_type") // PRODUCT, BUSINESS_PARTNER, PRICE_LIST, BATCH, etc.
  entityId        String   @db.Uuid @map("entity_id")
  entityName      String   @map("entity_name")
  // ─── Change ───
  action          String   // CREATE, UPDATE, DELETE, ARCHIVE, RESTORE, MERGE
  moduleName      String   @map("module_name")
  // ─── Before/After ───
  beforeValue     Json?    @map("before_value")
  afterValue      Json?    @map("after_value")
  changedFields   Json     @default("[]") @map("changed_fields")
  // ─── Actor ───
  userId          String?  @db.Uuid @map("user_id")
  userName        String?  @map("user_name")
  userRole        String?  @map("user_role")
