  sourceId            String?  @db.Uuid @map("source_id")
  sourceNumber        String?  @map("source_number")
  taskId              String?  @db.Uuid @map("task_id")
  taskNumber          String?  @map("task_number")
  waveId              String?  @db.Uuid @map("wave_id")
