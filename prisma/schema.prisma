  qualityScore    Decimal? @db.Decimal(5, 2) @map("quality_score") // 0-100
  // ─── Period ───
  measuredAt      DateTime @default(now()) @map("measured_at")
  periodDate      DateTime @map("period_date")
  // ─── Details ───
  details         Json?    @default("{}")

  @@map("data_quality_metrics")
  @@index([entityType, metricName, periodDate], map: "idx_dqm_entity_metric_period")
  @@index([qualityScore], map: "idx_dqm_score")
  @@index([periodDate], map: "idx_dqm_period")
