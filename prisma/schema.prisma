  @@index([inventoryAdjustmentId, lineOrder], map: "idx_ial_ia_order")
  @@index([productId, batchId], map: "idx_ial_product_batch")
  @@index([rootCauseCategory], map: "idx_ial_root_cause")
}

// ─── Epic 2: Adjustment Reasons ─────────────────────────
model AdjustmentReason {
  id              String   @id @default(uuid()) @db.Uuid
  reasonCode      String   @unique @map("reason_code")
  reasonName      String   @map("reason_name")
  description     String?
  // ─── Behavior ───
