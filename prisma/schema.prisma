  recoveryChecklist   Json?    @map("recovery_checklist") // [{ item, completed, completedBy, completedAt }]
  // ─── Impact ───
  businessImpact      String?  @map("business_impact")
  estimatedLoss       Decimal? @db.Decimal(12, 2) @map("estimated_loss")
  // ─── Post-Incident ───
  rootCause           String?  @map("root_cause")
  preventiveActions   String[] @default([]) @map("preventive_actions")
  lessonsLearned      String?  @map("lessons_learned")
  // ─── Status ───
  status              String   @default("DETECTED") // DETECTED, ACKNOWLEDGED, RECOVERY_IN_PROGRESS, RECOVERED, CLOSED, POST_INCIDENT_REVIEW
  // ─── Audit ───
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("recovery_incidents")
  @@index([warehouseId, status], map: "idx_ri_wh_status")
  @@index([incidentType, status], map: "idx_ri_type_status")
  @@index([severity, status], map: "idx_ri_sev_status")
  @@index([detectedAt], map: "idx_ri_detected")
}

model SystemHealthMonitor {
  id                  String   @id @default(uuid()) @db.Uuid
  // ─── System ───
  systemName          String   @map("system_name") // ERP_BACKEND, DATABASE, REDIS, RABBITMQ, MOBILE_API, ANALYTICS_ENGINE
  systemType          String   @map("system_type") // APPLICATION, DATABASE, CACHE, QUEUE, API, STORAGE
  // ─── Health ───
  status              String   @default("HEALTHY") // HEALTHY, DEGRADED, UNHEALTHY, OFFLINE
  healthScore         Int      @default(100) @map("health_score") // 0-100
  // ─── Metrics ───
  uptimePct           Decimal? @db.Decimal(5, 2) @map("uptime_pct")
  responseTimeMs      Int?     @map("response_time_ms")
  errorRatePct        Decimal? @db.Decimal(5, 2) @map("error_rate_pct")
  cpuUsagePct         Decimal? @db.Decimal(5, 2) @map("cpu_usage_pct")
  memoryUsagePct      Decimal? @db.Decimal(5, 2) @map("memory_usage_pct")
  diskUsagePct        Decimal? @db.Decimal(5, 2) @map("disk_usage_pct")
  // ─── Last Check ───
  lastCheckedAt       DateTime @default(now()) @map("last_checked_at")
  lastIncidentAt      DateTime? @map("last_incident_at")
  // ─── Audit ───
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("system_health_monitors")
  @@unique([systemName], map: "uq_shm_system")
  @@index([status], map: "idx_shm_status")
  @@index([healthScore], map: "idx_shm_health")
}

// ═══════════════════════════════════════════════════════════════
// SPRINT 34 — MANUFACTURING FOUNDATION & PLANT MASTER (PART 5 MES)
// Epic 1: Plant · Epic 2: Department · Epic 3: Line · Epic 4: Work Center
// Epic 5: Calendar · Epic 6: Resources · Epic 7: Config · Epic 8: Rules
// ═══════════════════════════════════════════════════════════════

// ─── Epic 1: Manufacturing Plant Master ─────────────────
model ManufacturingPlant {
  id                  String   @id @default(uuid()) @db.Uuid
  plantCode           String   @unique @map("plant_code")
  plantName           String   @map("plant_name")
  // ─── Type ───
  plantType           String   @map("plant_type") // SWEET_MANUFACTURING, NAMKEEN_MANUFACTURING, BAKERY, BATTER_PRODUCTION, READY_TO_EAT_KITCHEN, CENTRAL_KITCHEN, PACKAGING_PLANT, SEMI_FINISHED_PLANT, COLD_PROCESSING, DRY_PROCESSING
  // ─── Org Hierarchy ───
  companyId           String?  @db.Uuid @map("company_id")
  companyName         String?  @map("company_name")
  branchId            String?  @db.Uuid @map("branch_id")
  branchName          String?  @map("branch_name")
  // ─── Manager ───
  managerId           String?  @db.Uuid @map("manager_id")
  managerName         String?  @map("manager_name")
  // ─── Location ───
  addressLine1        String?  @map("address_line1")
  addressLine2        String?  @map("address_line2")
  city                String?
  state               String?
  pincode             String?
  country             String?  @default("India")
  timezone            String   @default("Asia/Kolkata") @map("timezone")
  // ─── Capacity ───
  capacityPerDayKg    Decimal? @db.Decimal(10, 2) @map("capacity_per_day_kg")
  capacityPerDayUnits Int?     @map("capacity_per_day_units")
  // ─── Operating Hours ───
  operatingHoursStart String?  @default("06:00") @map("operating_hours_start")
  operatingHoursEnd   String?  @default("22:00") @map("operating_hours_end")
  operatingDays       String[] @default(["MON","TUE","WED","THU","FRI","SAT"]) @map("operating_days")
  // ─── Warehouse Links ───
  defaultRawMaterialWarehouseId   String?  @db.Uuid @map("default_raw_material_warehouse_id")
  defaultRawMaterialWarehouseName String?  @map("default_raw_material_warehouse_name")
  defaultFinishedGoodsWarehouseId String?  @db.Uuid @map("default_finished_goods_warehouse_id")
  defaultFinishedGoodsWarehouseName String? @map("default_finished_goods_warehouse_name")
  // ─── Numbering ───
  batchNumberFormat   String?  @default("BATCH-{YYYY}-{SEQ:0000}") @map("batch_number_format")
  productionNumberFormat String? @default("PROD-{YYYY}-{SEQ:0000}") @map("production_number_format")
  // ─── Status ───
  status              String   @default("ACTIVE") // ACTIVE, INACTIVE, MAINTENANCE, SHUTDOWN
  // ─── Audit ───
  isActive            Boolean  @default(true) @map("is_active")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  departments         ProductionDepartment[]
  productionLines     ProductionLine[]
  resources           ProductionResource[]
  calendar            ProductionCalendar[]
  shifts              ProductionShift[]
  holidays            PlantHoliday[]
  configuration       PlantConfiguration?

  @@map("manufacturing_plants")
  @@index([plantType, status], map: "idx_mp_type_status")
  @@index([branchId], map: "idx_mp_branch")
}

// ─── Epic 2: Production Departments ─────────────────────
model ProductionDepartment {
  id                  String   @id @default(uuid()) @db.Uuid
  departmentCode      String   @unique @map("department_code")
  departmentName      String   @map("department_name")
  // ─── Plant Link ───
  plantId             String   @db.Uuid @map("plant_id")
  plantName           String   @map("plant_name")
  // ─── Type ───
  departmentType      String   @map("department_type") // SWEET_PRODUCTION, NAMKEEN_PRODUCTION, BATTER_PRODUCTION, PACKAGING, QUALITY_HOLD, FINISHED_GOODS, MAINTENANCE, UTILITIES, CLEANING
  // ─── Manager ───
  managerId           String?  @db.Uuid @map("manager_id")
  managerName         String?  @map("manager_name")
  // ─── Capacity ───
  capacityPerDayKg    Decimal? @db.Decimal(10, 2) @map("capacity_per_day_kg")
  capacityPerShiftKg  Decimal? @db.Decimal(10, 2) @map("capacity_per_shift_kg")
  // ─── Status ───
  status              String   @default("ACTIVE") // ACTIVE, INACTIVE, MAINTENANCE
  // ─── Audit ───
  isActive            Boolean  @default(true) @map("is_active")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  plant               ManufacturingPlant @relation(fields: [plantId], references: [id])
  productionLines     ProductionLine[]

  @@map("production_departments")
  @@index([plantId, status], map: "idx_pd_plant_status")
  @@index([departmentType], map: "idx_pd_type")
}

// ─── Epic 3: Production Lines ───────────────────────────
model ProductionLine {
  id                  String   @id @default(uuid()) @db.Uuid
  lineCode            String   @unique @map("line_code")
  lineName            String   @map("line_name")
  // ─── Department Link ───
  plantId             String   @db.Uuid @map("plant_id")
  plantName           String   @map("plant_name")
  departmentId        String   @db.Uuid @map("department_id")
  departmentName      String   @map("department_name")
  // ─── Capacity ───
  capacityPerHourKg   Decimal? @db.Decimal(10, 2) @map("capacity_per_hour_kg")
  capacityPerShiftKg  Decimal? @db.Decimal(10, 2) @map("capacity_per_shift_kg")
  capacityPerDayKg    Decimal? @db.Decimal(10, 2) @map("capacity_per_day_kg")
  hourlyOutputTarget  Int?     @map("hourly_output_target")
  // ─── Product Link ───
  primaryProduct      String?  @map("primary_product")
  supportedProducts   String[] @default([]) @map("supported_products")
  // ─── Status ───
  status              String   @default("ACTIVE") // ACTIVE, INACTIVE, MAINTENANCE, CLEANING, SETUP
  currentStatus       String   @default("IDLE") // IDLE, RUNNING, PAUSED, CHANGEOVER, CLEANING, MAINTENANCE
  // ─── Audit ───
  isActive            Boolean  @default(true) @map("is_active")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  plant               ManufacturingPlant @relation(fields: [plantId], references: [id])
  department          ProductionDepartment @relation(fields: [departmentId], references: [id])
  workCenters         WorkCenter[]

  @@map("production_lines")
  @@index([plantId, status], map: "idx_pl_plant_status")
  @@index([departmentId], map: "idx_pl_dept")
}

// ─── Epic 4: Work Centers ───────────────────────────────
model WorkCenter {
  id                  String   @id @default(uuid()) @db.Uuid
  workCenterCode      String   @unique @map("work_center_code")
  workCenterName      String   @map("work_center_name")
  // ─── Line Link ───
  plantId             String   @db.Uuid @map("plant_id")
  plantName           String   @map("plant_name")
  departmentId        String   @db.Uuid @map("department_id")
  departmentName      String   @map("department_name")
  lineId              String   @db.Uuid @map("line_id")
  lineName            String   @map("line_name")
  // ─── Type ───
  workCenterType      String   @map("work_center_type") // MIXING, COOKING, ROASTING, FRYING, COOLING, CUTTING, ROLLING, PACKING, INSPECTION, DISPATCH_PREP, RAW_MATERIAL_PREP
  // ─── Sequence ───
  sequenceNo          Int      @map("sequence_no") // order in the production line
  // ─── Capacity ───
  capacityPerHourKg   Decimal? @db.Decimal(10, 2) @map("capacity_per_hour_kg")
  cycleTimeMinutes    Decimal? @db.Decimal(8, 2) @map("cycle_time_minutes")
  // ─── Resources ───
  assignedOperators   Int      @default(1) @map("assigned_operators")
  assignedMachines    Int      @default(0) @map("assigned_machines")
  // ─── Efficiency ───
  efficiencyTargetPct Decimal? @db.Decimal(5, 2) @default(85) @map("efficiency_target_pct")
  // ─── Status ───
  status              String   @default("ACTIVE") // ACTIVE, INACTIVE, MAINTENANCE
  currentStatus       String   @default("IDLE") // IDLE, RUNNING, PAUSED, SETUP, CLEANING, MAINTENANCE
  // ─── Audit ───
  isActive            Boolean  @default(true) @map("is_active")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  line                ProductionLine @relation(fields: [lineId], references: [id])

  @@map("work_centers")
  @@index([lineId, sequenceNo], map: "idx_wc_line_seq")
  @@index([plantId, status], map: "idx_wc_plant_status")
  @@index([workCenterType], map: "idx_wc_type")
}

// ─── Epic 5: Manufacturing Calendar ─────────────────────
model ProductionCalendar {
  id                  String   @id @default(uuid()) @db.Uuid
  plantId             String   @db.Uuid @map("plant_id")
  plantName           String   @map("plant_name")
  // ─── Date ───
  calendarDate        DateTime @map("calendar_date")
  dayOfWeek           String   @map("day_of_week") // MON, TUE, WED, THU, FRI, SAT, SUN
  // ─── Type ───
  dayType             String   @map("day_type") // WORKING, HOLIDAY, MAINTENANCE_SHUTDOWN, FESTIVAL, EMERGENCY_SHUTDOWN
  // ─── Operating ───
  isOperatingDay      Boolean  @default(true) @map("is_operating_day")
  operatingHoursStart String?  @map("operating_hours_start")
  operatingHoursEnd   String?  @map("operating_hours_end")
  // ─── Notes ───
  notes               String?
  // ─── Audit ───
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  plant               ManufacturingPlant @relation(fields: [plantId], references: [id], onDelete: Cascade)

  @@map("production_calendar")
  @@unique([plantId, calendarDate], map: "uq_pc_plant_date")
  @@index([plantId, calendarDate], map: "idx_pc_plant_date")
}

model ProductionShift {
  id                  String   @id @default(uuid()) @db.Uuid
  shiftCode           String   @unique @map("shift_code")
  shiftName           String   @map("shift_name") // Morning, Afternoon, Night
  // ─── Plant ───
  plantId             String   @db.Uuid @map("plant_id")
  plantName           String   @map("plant_name")
  // ─── Schedule ───
  startTime           String   @map("start_time") // HH:mm
  endTime             String   @map("end_time") // HH:mm
  breakStart          String?  @map("break_start")
  breakEnd            String?  @map("break_end")
  // ─── Days ───
  workingDays         String[] @default([]) @map("working_days")
  // ─── Type ───
  shiftType           String   @default("REGULAR") @map("shift_type") // REGULAR, OVERTIME, WEEKEND, HOLIDAY
  // ─── Grace ───
  graceEarlyMinutes   Int      @default(15) @map("grace_early_minutes")
  graceLateMinutes    Int      @default(15) @map("grace_late_minutes")
  // ─── Status ───
  isActive            Boolean  @default(true) @map("is_active")
  // ─── Audit ───
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  plant               ManufacturingPlant @relation(fields: [plantId], references: [id])

  @@map("production_shifts")
  @@index([plantId, isActive], map: "idx_ps_plant_active")
}

model PlantHoliday {
  id                  String   @id @default(uuid()) @db.Uuid
  plantId             String   @db.Uuid @map("plant_id")
  plantName           String   @map("plant_name")
  // ─── Holiday ───
  holidayDate         DateTime @map("holiday_date")
  holidayName         String   @map("holiday_name")
  holidayType         String   @default("PUBLIC") @map("holiday_type") // PUBLIC, FESTIVAL, NATIONAL, COMPANY, MAINTENANCE
  // ─── Impact ───
  isFullDay           Boolean  @default(true) @map("is_full_day")
  // ─── Audit ───
  createdAt           DateTime @default(now()) @map("created_at")

  plant               ManufacturingPlant @relation(fields: [plantId], references: [id], onDelete: Cascade)

  @@map("plant_holidays")
  @@unique([plantId, holidayDate], map: "uq_ph_plant_date")
  @@index([plantId, holidayDate], map: "idx_ph_plant_date")
}

// ─── Epic 6: Production Resources ───────────────────────
model ProductionResource {
  id                  String   @id @default(uuid()) @db.Uuid
  resourceCode        String   @unique @map("resource_code")
  resourceName        String   @map("resource_name")
  // ─── Plant ───
  plantId             String   @db.Uuid @map("plant_id")
  plantName           String   @map("plant_name")
  // ─── Type ───
  resourceType        String   @map("resource_type") // MACHINE, OPERATOR, TOOL, UTILITY, PRODUCTION_TABLE, PACKAGING_STATION, CLEANING_EQUIPMENT
  // ─── Machine Link (if applicable) ───
  equipmentId         String?  @db.Uuid @map("equipment_id")
  equipmentCode       String?  @map("equipment_code")
  // ─── Work Center Link (if assigned) ───
  workCenterId        String?  @db.Uuid @map("work_center_id")
  workCenterCode      String?  @map("work_center_code")
  // ─── Capacity ───
  capacityPerHour     Decimal? @db.Decimal(10, 2) @map("capacity_per_hour")
  capacityUnit        String?  @default("KG") @map("capacity_unit")
  // ─── Status ───
  status              String   @default("AVAILABLE") // AVAILABLE, IN_USE, MAINTENANCE, CLEANING, OFFLINE
  // ─── Audit ───
  isActive            Boolean  @default(true) @map("is_active")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  plant               ManufacturingPlant @relation(fields: [plantId], references: [id])

  @@map("production_resources")
  @@index([plantId, resourceType, status], map: "idx_pr_plant_type_status")
  @@index([workCenterId], map: "idx_pr_workcenter")
}

// ─── Epic 7: Plant Configuration ────────────────────────
model PlantConfiguration {
  id                  String   @id @default(uuid()) @db.Uuid
  plantId             String   @unique @db.Uuid @map("plant_id")
  // ─── Production Start Time ───
  defaultProductionStart String? @default("06:00") @map("default_production_start")
  // ─── Shift Rules ───
  requireShiftLogin   Boolean  @default(true) @map("require_shift_login")
  autoEndShiftAt      String?  @default("22:00") @map("auto_end_shift_at")
  // ─── Warehouse Defaults ───
  defaultRawMaterialWarehouseId   String?  @db.Uuid @map("default_raw_material_warehouse_id")
  defaultFinishedGoodsWarehouseId String?  @db.Uuid @map("default_finished_goods_warehouse_id")
  // ─── Batch Numbering ───
  batchNumberFormat   String   @default("BATCH-{YYYY}-{SEQ:0000}") @map("batch_number_format")
  batchSeqCounter     Int      @default(0) @map("batch_seq_counter")
  // ─── Production Numbering ───
  productionNumberFormat String @default("PROD-{YYYY}-{SEQ:0000}") @map("production_number_format")
  productionSeqCounter Int     @default(0) @map("production_seq_counter")
  // ─── Quality Hold Rules ───
  autoQualityHoldOnNewBatch Boolean @default(true) @map("auto_quality_hold_on_new_batch")
  qualityHoldDurationHours  Int     @default(24) @map("quality_hold_duration_hours")
  requireSupervisorApproval Boolean @default(true) @map("require_supervisor_approval")
  // ─── Barcode Rules ───
  requireBatchBarcode Boolean  @default(true) @map("require_batch_barcode")
  requireProductBarcode Boolean @default(true) @map("require_product_barcode")
  // ─── Manufacturing Rules ───
  enforceFIFO         Boolean  @default(true) @map("enforce_fifo")
  enforceFEFO         Boolean  @default(true) @map("enforce_fefo")
  mandatoryBatch      Boolean  @default(true) @map("mandatory_batch")
  recipeLocking       Boolean  @default(true) @map("recipe_locking")
  digitalSignoff      Boolean  @default(false) @map("digital_signoff")
  // ─── Audit ───
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  plant               ManufacturingPlant @relation(fields: [plantId], references: [id], onDelete: Cascade)

  @@map("plant_configurations")
}

// ═══════════════════════════════════════════════════════════════
// SPRINT 35 — RECIPE, FORMULA, BOM & VERSION MANAGEMENT (PART 5)
// Epic 1: Recipe · Epic 2: Formula · Epic 3: BOM · Epic 4: Version
// Epic 5: Yield · Epic 6: Batch Scaling · Epic 7: Alternate · Epic 8: Nutrition · Epic 9: Cost
// ═══════════════════════════════════════════════════════════════

// ─── Epic 1: Recipe Master ──────────────────────────────
model Recipe {
  id                  String   @id @default(uuid()) @db.Uuid
  recipeCode          String   @unique @map("recipe_code")
  recipeName          String   @map("recipe_name")
  // ─── Product Link ───
  productId           String?  @db.Uuid @map("product_id")
  productSku          String?  @map("product_sku")
  productName         String?  @map("product_name")
  // ─── Category ───
  productType         String   @map("product_type") // TRADITIONAL_SWEETS, MILK_SWEETS, DRY_FRUIT_SWEETS, NAMKEEN, SNACKS, READY_TO_EAT, IDLI_BATTER, DOSA_BATTER, PACKAGING_KITS, SEMI_FINISHED
  // ─── Plant ───
  plantId             String?  @db.Uuid @map("plant_id")
  plantName           String?  @map("plant_name")
  // ─── Yield ───
  yieldQuantity       Decimal  @db.Decimal(12, 3) @map("yield_quantity")
  yieldUom            String   @default("KG") @map("yield_uom")
  // ─── Production Instructions (Chief Architect Recommendation) ───
  productionInstructions String? @map("production_instructions")
  qualityCheckpoints  String[] @default([]) @map("quality_checkpoints")
  packagingInstructions String? @map("packaging_instructions")
  // ─── Status ───
  status              String   @default("DRAFT") // DRAFT, UNDER_REVIEW, APPROVED, ACTIVE, INACTIVE, ARCHIVED
  // ─── Approval ───
  approvedById        String?  @db.Uuid @map("approved_by_id")
  approvedByName      String?  @map("approved_by_name")
  approvedAt          DateTime? @map("approved_at")
  // ─── Effective ───
  effectiveFrom       DateTime? @map("effective_from")
  effectiveTo         DateTime? @map("effective_to")
  // ─── Audit ───
  createdById         String?  @db.Uuid @map("created_by_id")
  createdByName       String?  @map("created_by_name")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  versions            RecipeVersion[]
  formulas            Formula[]
  boms                BillOfMaterial[]

  @@map("recipes")
  @@index([productType, status], map: "idx_rec_type_status")
  @@index([status], map: "idx_rec_status")
}

model RecipeVersion {
  id                  String   @id @default(uuid()) @db.Uuid
  recipeId            String   @db.Uuid @map("recipe_id")
  recipeCode          String   @map("recipe_code")
  // ─── Version ───
  majorVersion        Int      @default(1) @map("major_version")
  minorVersion        Int      @default(0) @map("minor_version")
  versionLabel        String   @map("version_label") // e.g. "1.0", "1.1", "2.0"
  // ─── Change ───
  changeSummary       String?  @map("change_summary")
  changeReason        String?  @map("change_reason")
  // ─── Snapshot ───
  recipeSnapshot      Json     @map("recipe_snapshot") // full recipe + formula + BOM at this version
  // ─── Status ───
  status              String   @default("DRAFT") // DRAFT, UNDER_REVIEW, APPROVED, ACTIVE, ARCHIVED
  // ─── Approval ───
  approvedById        String?  @db.Uuid @map("approved_by_id")
  approvedByName      String?  @map("approved_by_name")
  approvedAt          DateTime? @map("approved_at")
  // ─── Effective ───
  effectiveFrom       DateTime? @map("effective_from")
  // ─── Audit ───
  createdById         String?  @db.Uuid @map("created_by_id")
  createdByName       String?  @map("created_by_name")
  createdAt           DateTime @default(now()) @map("created_at")

  recipe              Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@map("recipe_versions")
  @@unique([recipeId, majorVersion, minorVersion], map: "uq_rv_recipe_version")
  @@index([recipeId, createdAt], map: "idx_rv_recipe_time")
}

// ─── Epic 2: Formula Management ────────────────────────
model Formula {
  id                  String   @id @default(uuid()) @db.Uuid
  formulaCode         String   @unique @map("formula_code")
  formulaName         String   @map("formula_name")
  // ─── Recipe Link ───
  recipeId            String   @db.Uuid @map("recipe_id")
  recipeCode          String   @map("recipe_code")
  recipeVersion       String   @map("recipe_version")
  // ─── Type ───
  formulaType         String   @default("FIXED") // FIXED, PERCENTAGE, RATIO, CONDITIONAL
  // ─── Status ───
  status              String   @default("ACTIVE") // ACTIVE, INACTIVE, ARCHIVED
  // ─── Audit ───
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  recipe              Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  lines               FormulaLine[]

  @@map("formulas")
  @@index([recipeId], map: "idx_fml_recipe")
}

model FormulaLine {
  id                  String   @id @default(uuid()) @db.Uuid
  formulaId           String   @db.Uuid @map("formula_id")
  lineNo              Int      @map("line_no")
  // ─── Ingredient ───
  ingredientId        String?  @db.Uuid @map("ingredient_id")
  ingredientSku       String   @map("ingredient_sku")
  ingredientName      String   @map("ingredient_name")
  // ─── Quantity ───
  quantity            Decimal  @db.Decimal(12, 3) @default(0)
  uom                 String   @default("KG")
  percentage          Decimal? @db.Decimal(5, 2) @map("percentage") // for percentage formulas
  // ─── Process Stage ───
  processStage        String   @map("process_stage") // MIXING, COOKING, COOLING, ROLLING, CUTTING, PACKING, etc.
  // ─── Loss ───
  lossPercentage      Decimal  @db.Decimal(5, 2) @default(0) @map("loss_percentage")
  // ─── Flags ───
  isCritical          Boolean  @default(false) @map("is_critical")
  isOptional          Boolean  @default(false) @map("is_optional")
  // ─── Notes ───
  notes               String?
  // ─── Audit ───
  createdAt           DateTime @default(now()) @map("created_at")

  formula             Formula @relation(fields: [formulaId], references: [id], onDelete: Cascade)

  @@map("formula_lines")
  @@index([formulaId, lineNo], map: "idx_fl_formula_line")
}

// ─── Epic 3: Bill of Materials (BOM) ───────────────────
model BillOfMaterial {
  id                  String   @id @default(uuid()) @db.Uuid
  bomCode             String   @unique @map("bom_code")
  // ─── Recipe Link ───
  recipeId            String   @db.Uuid @map("recipe_id")
  recipeCode          String   @map("recipe_code")
  // ─── Product ───
  productId           String?  @db.Uuid @map("product_id")
  productSku          String?  @map("product_sku")
  productName         String?  @map("product_name")
  // ─── Type ───
  bomType             String   @default("MANUFACTURING") // SINGLE_LEVEL, MULTI_LEVEL, PHANTOM, PACKAGING, ALTERNATE, ENGINEERING, MANUFACTURING
  // ─── Version ───
  version             Int      @default(1)
  // ─── Status ───
  status              String   @default("ACTIVE") // ACTIVE, INACTIVE, ARCHIVED
  // ─── Audit ───
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  recipe              Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  lines               BOMLine[]

  @@map("bill_of_materials")
  @@index([recipeId], map: "idx_bom_recipe")
  @@index([bomType, status], map: "idx_bom_type_status")
}

model BOMLine {
  id                  String   @id @default(uuid()) @db.Uuid
  bomId               String   @db.Uuid @map("bom_id")
  lineNo              Int      @map("line_no")
  // ─── Component ───
  componentId         String?  @db.Uuid @map("component_id")
  componentSku        String   @map("component_sku")
  componentName       String   @map("component_name")
  componentType       String   @default("RAW_MATERIAL") // RAW_MATERIAL, SEMI_FINISHED, PACKAGING, LABEL, CONSUMABLE
  // ─── Quantity ───
  quantity            Decimal  @db.Decimal(12, 3) @default(0)
  uom                 String   @default("KG")
  // ─── Loss ───
  scrapPercentage     Decimal  @db.Decimal(5, 2) @default(0) @map("scrap_percentage")
  // ─── Cost ───
  unitCost            Decimal? @db.Decimal(10, 2) @map("unit_cost")
  totalCost           Decimal? @db.Decimal(12, 2) @map("total_cost")
  // ─── Alternate ───
  hasAlternate        Boolean  @default(false) @map("has_alternate")
  // ─── Audit ───
  createdAt           DateTime @default(now()) @map("created_at")

  bom                 BillOfMaterial @relation(fields: [bomId], references: [id], onDelete: Cascade)

  @@map("bom_lines")
  @@index([bomId, lineNo], map: "idx_bl_bom_line")
}

// ─── Epic 5: Yield Management ──────────────────────────
model YieldRule {
  id                  String   @id @default(uuid()) @db.Uuid
  recipeId            String   @db.Uuid @map("recipe_id")
  recipeCode          String   @map("recipe_code")
  // ─── Yield ───
  expectedYieldPct    Decimal  @db.Decimal(5, 2) @map("expected_yield_pct") // e.g. 95% means 5% loss
  expectedLossPct     Decimal  @db.Decimal(5, 2) @map("expected_loss_pct")
  // ─── Limits ───
  minYieldPct         Decimal  @db.Decimal(5, 2) @default(90) @map("min_yield_pct")
  maxYieldPct         Decimal  @db.Decimal(5, 2) @default(100) @map("max_yield_pct")
  // ─── Audit ───
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("yield_rules")
  @@unique([recipeId], map: "uq_yr_recipe")
}

model YieldHistory {
  id                  String   @id @default(uuid()) @db.Uuid
  recipeId            String   @db.Uuid @map("recipe_id")
  recipeCode          String   @map("recipe_code")
  // ─── Batch ───
  batchNumber         String   @map("batch_number")
  productionOrderId   String?  @db.Uuid @map("production_order_id")
  // ─── Weights ───
  inputWeightKg       Decimal  @db.Decimal(12, 3) @map("input_weight_kg")
  outputWeightKg      Decimal  @db.Decimal(12, 3) @map("output_weight_kg")
  // ─── Yield ───
  expectedYieldPct    Decimal  @db.Decimal(5, 2) @map("expected_yield_pct")
  actualYieldPct      Decimal  @db.Decimal(5, 2) @map("actual_yield_pct")
  yieldVariancePct    Decimal  @db.Decimal(5, 2) @map("yield_variance_pct")
  // ─── Loss ───
  lossWeightKg        Decimal  @db.Decimal(12, 3) @map("loss_weight_kg")
  lossReason          String?  @map("loss_reason")
  // ─── Audit ───
  productionDate      DateTime @map("production_date")
  createdAt           DateTime @default(now()) @map("created_at")

  @@map("yield_history")
  @@index([recipeId, productionDate], map: "idx_yh_recipe_date")
}

// ─── Epic 7: Alternate Ingredients ─────────────────────
model AlternateIngredient {
  id                  String   @id @default(uuid()) @db.Uuid
  // ─── Primary ───
  primaryIngredientId    String?  @db.Uuid @map("primary_ingredient_id")
  primaryIngredientSku   String   @map("primary_ingredient_sku")
  primaryIngredientName  String   @map("primary_ingredient_name")
  // ─── Alternate ───
  alternateIngredientId    String?  @db.Uuid @map("alternate_ingredient_id")
  alternateIngredientSku   String   @map("alternate_ingredient_sku")
  alternateIngredientName  String   @map("alternate_ingredient_name")
  // ─── Replacement ───
  replacementRatio    Decimal  @db.Decimal(8, 4) @default(1) @map("replacement_ratio") // e.g. 1.1 means 1.1kg alternate = 1kg primary
  // ─── Quality ───
  qualityApprovalReq  Boolean  @default(true) @map("quality_approval_req")
  qualityApprovedBy   String?  @map("quality_approved_by")
  qualityApprovedAt   DateTime? @map("quality_approved_at")
  // ─── Cost ───
  costDifferencePct   Decimal? @db.Decimal(5, 2) @map("cost_difference_pct")
  // ─── Supplier ───
  supplierRestrictions String? @map("supplier_restrictions")
  // ─── Status ───
  status              String   @default("PENDING") // PENDING, APPROVED, REJECTED, EXPIRED
  // ─── Audit ───
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("alternate_ingredients")
  @@index([primaryIngredientSku, status], map: "idx_ai_primary_status")
}

// ─── Epic 8: Allergen & Nutrition Management ───────────
model Allergen {
  id                  String   @id @default(uuid()) @db.Uuid
  allergenCode        String   @unique @map("allergen_code")
  allergenName        String   @map("allergen_name")
  // ─── Type ───
  allergenType        String   @map("allergen_type") // MILK, NUTS, SOY, GLUTEN, SESAME, PEANUTS, EGG, FISH, SHELLFISH, SULPHITE
  // ─── Severity ───
  severity            String   @default("HIGH") // HIGH, MEDIUM, LOW
  // ─── Audit ───
  isActive            Boolean  @default(true) @map("is_active")
  createdAt           DateTime @default(now()) @map("created_at")

  @@map("allergens")
  @@index([allergenType], map: "idx_alg_type")
}

model NutritionProfile {
  id                  String   @id @default(uuid()) @db.Uuid
  // ─── Product/Recipe Link ───
  recipeId            String?  @db.Uuid @map("recipe_id")
  recipeCode          String?  @map("recipe_code")
  productId           String?  @db.Uuid @map("product_id")
  productSku          String?  @map("product_sku")
  // ─── Serving ───
  servingSize         Decimal  @db.Decimal(8, 2) @default(100) @map("serving_size")
  servingUom          String   @default("G") @map("serving_uom")
  // ─── Nutrition (per serving) ───
  calories            Decimal? @db.Decimal(8, 2)
  protein             Decimal? @db.Decimal(8, 2)
  fat                 Decimal? @db.Decimal(8, 2)
  saturatedFat        Decimal? @db.Decimal(8, 2) @map("saturated_fat")
  carbohydrates       Decimal? @db.Decimal(8, 2)
  sugar               Decimal? @db.Decimal(8, 2)
  fiber               Decimal? @db.Decimal(8, 2)
  sodium              Decimal? @db.Decimal(8, 2)
  // ─── Allergens ───
  allergens           String[] @default([]) // ["MILK", "NUTS", "GLUTEN"]
  // ─── Audit ───
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("nutrition_profiles")
  @@index([recipeId], map: "idx_np_recipe")
  @@index([productId], map: "idx_np_product")
}

// ─── Epic 9: Cost Roll-Up ──────────────────────────────
model CostRollup {
  id                  String   @id @default(uuid()) @db.Uuid
  rollupCode          String   @unique @map("rollup_code")
  // ─── Recipe ───
  recipeId            String   @db.Uuid @map("recipe_id")
  recipeCode          String   @map("recipe_code")
  recipeVersion       String   @map("recipe_version")
  // ─── Cost Breakdown ───
  ingredientCost      Decimal  @db.Decimal(12, 2) @default(0) @map("ingredient_cost")
  packagingCost       Decimal  @db.Decimal(12, 2) @default(0) @map("packaging_cost")
  processingCost      Decimal  @db.Decimal(12, 2) @default(0) @map("processing_cost")
  laborCost           Decimal  @db.Decimal(12, 2) @default(0) @map("labor_cost")
  overheadCost        Decimal  @db.Decimal(12, 2) @default(0) @map("overhead_cost")
  // ─── Total ───
  totalManufacturingCost Decimal @db.Decimal(12, 2) @default(0) @map("total_manufacturing_cost")
  costPerUnit         Decimal  @db.Decimal(10, 2) @map("cost_per_unit")
  costPerKg           Decimal  @db.Decimal(10, 2) @map("cost_per_kg")
  // ─── Type ───
  costType            String   @default("CURRENT") // CURRENT, FUTURE, HISTORICAL, SIMULATION
  // ─── Audit ───
  calculatedAt        DateTime @default(now()) @map("calculated_at")
  createdAt           DateTime @default(now()) @map("created_at")

  @@map("cost_rollups")
  @@index([recipeId, costType], map: "idx_cr_recipe_type")
  @@index([calculatedAt], map: "idx_cr_calculated")
}

// ═══════════════════════════════════════════════════════════════
// SPRINT 36 — PRODUCTION PLANNING, MRP & MASTER PRODUCTION SCHED
// Epic 1: MPS · Epic 2: MRP · Epic 3: Demand · Epic 4: Capacity
// Epic 5: Purchase · Epic 6: Shortage · Epic 7: Calendar · Epic 8: Simulation
// ═══════════════════════════════════════════════════════════════

// ─── Epic 1: Master Production Schedule (MPS) ───────────
model MasterProductionSchedule {
  id                  String   @id @default(uuid()) @db.Uuid
  scheduleNumber      String   @unique @map("schedule_number")
  // ─── Scope ───
  plantId             String   @db.Uuid @map("plant_id")
  plantName           String   @map("plant_name")
  // ─── Period ───
  periodType          String   @map("period_type") // DAILY, WEEKLY, MONTHLY, QUARTERLY
  periodStart         DateTime @map("period_start")
  periodEnd           DateTime @map("period_end")
  // ─── Planner ───
  plannerId           String?  @db.Uuid @map("planner_id")
  plannerName         String?  @map("planner_name")
  // ─── Version ───
  version             Int      @default(1)
  // ─── Status ───
  status              String   @default("DRAFT") // DRAFT, SUBMITTED, APPROVED, ACTIVE, COMPLETED, CANCELLED
  approvalStatus      String   @default("PENDING") // PENDING, UNDER_REVIEW, APPROVED, REJECTED
  approvedById        String?  @db.Uuid @map("approved_by_id")
  approvedByName      String?  @map("approved_by_name")
  approvedAt          DateTime? @map("approved_at")
  // ─── Summary ───
  totalProducts       Int      @default(0) @map("total_products")
  totalQuantity       Decimal  @db.Decimal(14, 3) @default(0) @map("total_quantity")
  totalUom            String   @default("KG") @map("total_uom")
  // ─── Audit ───
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  lines               MPSLine[]

  @@map("master_production_schedule")
  @@index([plantId, periodType, periodStart], map: "idx_mps_plant_period")
  @@index([status], map: "idx_mps_status")
}

model MPSLine {
  id                  String   @id @default(uuid()) @db.Uuid
  mpsId               String   @db.Uuid @map("mps_id")
  lineNo              Int      @map("line_no")
  // ─── Product ───
  productId           String?  @db.Uuid @map("product_id")
  productSku          String   @map("product_sku")
  productName         String   @map("product_name")
  recipeId            String?  @db.Uuid @map("recipe_id")
  recipeCode          String?  @map("recipe_code")
  // ─── Production ───
  productionLineId    String?  @db.Uuid @map("production_line_id")
  productionLineCode  String?  @map("production_line_code")
  plannedQuantity     Decimal  @db.Decimal(14, 3) @map("planned_quantity")
  uom                 String   @default("KG")
  // ─── Schedule ───
  plannedDate         DateTime @map("planned_date")
  plannedShift        String?  @map("planned_shift") // MORNING, AFTERNOON, NIGHT
  // ─── Demand Source ───
  demandSource        String   @map("demand_source") // SALES_ORDER, RETAIL_POS, RESTAURANT_POS, FORECAST, SAFETY_STOCK, DISTRIBUTOR, EXPORT
  demandQuantity      Decimal  @db.Decimal(14, 3) @map("demand_quantity")
  // ─── Batches ───
  estimatedBatches    Int?     @map("estimated_batches")
  // ─── Status ───
  status              String   @default("PLANNED") // PLANNED, SCHEDULED, IN_PROGRESS, COMPLETED, CANCELLED
  // ─── Audit ───
  createdAt           DateTime @default(now()) @map("created_at")

  mps                 MasterProductionSchedule @relation(fields: [mpsId], references: [id], onDelete: Cascade)

  @@map("mps_lines")
  @@index([mpsId, lineNo], map: "idx_mpsl_mps_line")
  @@index([plannedDate], map: "idx_mpsl_date")
}

// ─── Epic 2: Material Requirements Planning (MRP) ───────
model MRPRun {
  id                  String   @id @default(uuid()) @db.Uuid
  runNumber           String   @unique @map("run_number")
  // ─── Scope ───
  plantId             String   @db.Uuid @map("plant_id")
  plantName           String   @map("plant_name")
  mpsId               String?  @db.Uuid @map("mps_id")
  mpsNumber           String?  @map("mps_number")
  // ─── Period ───
  periodStart         DateTime @map("period_start")
  periodEnd           DateTime @map("period_end")
  // ─── Run ───
  runType             String   @default("FULL") // FULL, INCREMENTAL, SIMULATION
  runBy               String?  @map("run_by")
  runStartedAt        DateTime @default(now()) @map("run_started_at")
  runCompletedAt      DateTime? @map("run_completed_at")
  durationSeconds     Int?     @map("duration_seconds")
  // ─── Summary ───
  totalMaterials      Int      @default(0) @map("total_materials")
  totalShortages      Int      @default(0) @map("total_shortages")
  totalPurchaseSuggestions Int  @default(0) @map("total_purchase_suggestions")
  totalProductionSuggestions Int @default(0) @map("total_production_suggestions")
  // ─── Status ───
  status              String   @default("RUNNING") // RUNNING, COMPLETED, FAILED, CANCELLED
  // ─── Audit ───
  createdAt           DateTime @default(now()) @map("created_at")

  results             MRPResult[]
  shortages           MaterialShortage[]

  @@map("mrp_runs")
  @@index([plantId, periodStart], map: "idx_mrp_plant_period")
  @@index([status], map: "idx_mrp_status")
}

model MRPResult {
  id                  String   @id @default(uuid()) @db.Uuid
  mrpRunId            String   @db.Uuid @map("mrp_run_id")
  // ─── Material ───
  materialId          String?  @db.Uuid @map("material_id")
  materialSku         String   @map("material_sku")
  materialName        String   @map("material_name")
  materialType        String   @default("RAW_MATERIAL") // RAW_MATERIAL, PACKAGING, SEMI_FINISHED
  // ─── Calculation ───
  grossDemand         Decimal  @db.Decimal(14, 3) @default(0) @map("gross_demand")
  availableInventory  Decimal  @db.Decimal(14, 3) @default(0) @map("available_inventory")
  reservedInventory   Decimal  @db.Decimal(14, 3) @default(0) @map("reserved_inventory")
  safetyStock         Decimal  @db.Decimal(14, 3) @default(0) @map("safety_stock")
  netRequirement      Decimal  @db.Decimal(14, 3) @default(0) @map("net_requirement")
  // ─── Suggestion ───
  suggestionType      String   @map("suggestion_type") // PURCHASE, PRODUCE, TRANSFER, NONE
  suggestedQuantity   Decimal  @db.Decimal(14, 3) @default(0) @map("suggested_quantity")
  suggestedDate       DateTime? @map("suggested_date")
  // ─── Supplier ───
  suggestedSupplierId String?  @db.Uuid @map("suggested_supplier_id")
  suggestedSupplierName String? @map("suggested_supplier_name")
  leadTimeDays        Int?     @map("lead_time_days")
  // ─── Status ───
  isShortage          Boolean  @default(false) @map("is_shortage")
  // ─── Audit ───
  createdAt           DateTime @default(now()) @map("created_at")

  mrpRun              MRPRun @relation(fields: [mrpRunId], references: [id], onDelete: Cascade)

  @@map("mrp_results")
  @@index([mrpRunId, materialSku], map: "idx_mrr_run_material")
  @@index([isShortage], map: "idx_mrr_shortage")
}

model MaterialShortage {
  id                  String   @id @default(uuid()) @db.Uuid
  mrpRunId            String   @db.Uuid @map("mrp_run_id")
  // ─── Material ───
  materialSku         String   @map("material_sku")
  materialName        String   @map("material_name")
  materialType        String   @map("material_type")
  // ─── Shortage ───
  requiredQuantity    Decimal  @db.Decimal(14, 3) @map("required_quantity")
  availableQuantity   Decimal  @db.Decimal(14, 3) @map("available_quantity")
  shortageQuantity    Decimal  @db.Decimal(14, 3) @map("shortage_quantity")
  // ─── Impact ───
  severity            String   @default("MEDIUM") // LOW, MEDIUM, HIGH, CRITICAL
  affectedProducts    String[] @default([]) @map("affected_products")
  affectedOrders      Int      @default(0) @map("affected_orders")
  // ─── Resolution ───
  resolutionType      String?  @map("resolution_type") // PURCHASE, ALTERNATE, TRANSFER, PRODUCE, MANUAL
  resolutionStatus    String   @default("OPEN") // OPEN, IN_PROGRESS, RESOLVED, BLOCKED
  resolvedById        String?  @db.Uuid @map("resolved_by_id")
  resolvedByName      String?  @map("resolved_by_name")
  resolvedAt          DateTime? @map("resolved_at")
  resolutionNotes     String?  @map("resolution_notes")
  // ─── Alternate ───
  hasAlternate        Boolean  @default(false) @map("has_alternate")
  alternateMaterialSku String? @map("alternate_material_sku")
  // ─── Audit ───
  createdAt           DateTime @default(now()) @map("created_at")

  mrpRun              MRPRun @relation(fields: [mrpRunId], references: [id], onDelete: Cascade)

  @@map("material_shortages")
  @@index([mrpRunId, severity], map: "idx_ms_run_severity")
  @@index([resolutionStatus], map: "idx_ms_resolution")
}

// ─── Epic 3: Demand Planning ────────────────────────────
model DemandForecast {
  id                  String   @id @default(uuid()) @db.Uuid
  forecastCode        String   @unique @map("forecast_code")
  // ─── Product ───
  productId           String?  @db.Uuid @map("product_id")
  productSku          String   @map("product_sku")
  productName         String   @map("product_name")
  // ─── Period ───
  periodType          String   @map("period_type") // DAILY, WEEKLY, MONTHLY
  periodStart         DateTime @map("period_start")
  periodEnd           DateTime @map("period_end")
  // ─── Demand by Channel ───
  salesOrderDemand    Decimal  @db.Decimal(14, 3) @default(0) @map("sales_order_demand")
  retailPosDemand     Decimal  @db.Decimal(14, 3) @default(0) @map("retail_pos_demand")
  restaurantPosDemand Decimal  @db.Decimal(14, 3) @default(0) @map("restaurant_pos_demand")
  distributorDemand   Decimal  @db.Decimal(14, 3) @default(0) @map("distributor_demand")
  exportDemand        Decimal  @db.Decimal(14, 3) @default(0) @map("export_demand")
  safetyStockDemand   Decimal  @db.Decimal(14, 3) @default(0) @map("safety_stock_demand")
  // ─── Total ───
  totalDemand         Decimal  @db.Decimal(14, 3) @default(0) @map("total_demand")
  // ─── Forecast ───
  forecastMethod      String   @default("MOVING_AVERAGE") // MOVING_AVERAGE, SEASONAL_TREND, MANUAL_OVERRIDE, AI_FORECAST
  forecastQuantity    Decimal  @db.Decimal(14, 3) @default(0) @map("forecast_quantity")
  confidencePct       Int      @default(70) @map("confidence_pct")
  // ─── Audit ───
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("demand_forecasts")
  @@index([productSku, periodStart], map: "idx_df_product_period")
  @@index([periodStart], map: "idx_df_period")
}

// ─── Epic 4: Capacity Planning ──────────────────────────
model CapacityPlan {
  id                  String   @id @default(uuid()) @db.Uuid
  planCode            String   @unique @map("plan_code")
  // ─── Scope ───
  plantId             String   @db.Uuid @map("plant_id")
  plantName           String   @map("plant_name")
  productionLineId    String?  @db.Uuid @map("production_line_id")
  productionLineCode  String?  @map("production_line_code")
  // ─── Period ───
  periodStart         DateTime @map("period_start")
  periodEnd           DateTime @map("period_end")
  // ─── Capacity ───
  availableHours      Decimal  @db.Decimal(10, 2) @default(0) @map("available_hours")
  requiredHours       Decimal  @db.Decimal(10, 2) @default(0) @map("required_hours")
  utilizationPct      Decimal  @db.Decimal(5, 2) @default(0) @map("utilization_pct")
  // ─── Capacity by Type ───
