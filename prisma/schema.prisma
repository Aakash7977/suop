  promotion       Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)

  @@map("promotion_products")
  @@index([promotionId], map: "idx_pp_promo")
  @@index([productId], map: "idx_pp_product")
}

model PromotionCondition {
  id              String   @id @default(uuid()) @db.Uuid
  promotionId     String   @db.Uuid @map("promotion_id")
  conditionField  String   @map("condition_field") // MIN_ORDER_VALUE, MIN_QUANTITY, DAY_OF_WEEK, TIME_WINDOW, CUSTOMER_GROUP, BRANCH, PAYMENT_METHOD
  operator        String
