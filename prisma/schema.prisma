  severity            String   @default("MEDIUM") // LOW, MEDIUM, HIGH, CRITICAL
  // ─── Description ───
  title               String
  description         String
  rootCause           String?  @map("root_cause")
  // ─── Reporter ───
  reportedById        String?  @db.Uuid @map("reported_by_id")
