// SUOP — Enterprise Prisma Schema
// Sprint 3: Epic 1 — User Domain (Identity Platform)
//
// 7 Identity Tables:
//   users, user_profiles, user_devices, user_sessions,
//   password_history, password_reset_tokens, email_verification_tokens

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════════════════
// IDENTITY PLATFORM — Sprint 3
// ═══════════════════════════════════════════════════════════════

// ─── Users (Entity 601) ────────────────────────────────────────
model User {
  id                    String   @id @default(uuid()) @db.Uuid
  userId                String   @unique @map("user_id") // Display ID: USR-2026-00001
  employeeCode          String?  @unique @map("employee_code")
  username              String   @unique
  email                 String   @unique
  emailVerified         Boolean  @default(false) @map("email_verified")
  mobile                String?  @unique
  mobileVerified        Boolean  @default(false) @map("mobile_verified")
  passwordHash          String   @map("password_hash")
  passwordAlgorithm     String   @default("ARGON2ID") @map("password_algorithm")
  passwordChangedAt     DateTime @default(now()) @map("password_changed_at")
  passwordExpiresAt     DateTime? @map("password_expires_at")
  mfaEnabled            Boolean  @default(false) @map("mfa_enabled")
  mfaSecret             String?  @map("mfa_secret")
  firstName             String   @map("first_name")
  lastName              String   @map("last_name")
  displayName           String   @map("display_name")
  avatarUrl             String?  @map("avatar_url")
  language              String   @default("en-IN")
  timezone              String   @default("Asia/Kolkata")
  theme                 String   @default("LIGHT")
  lastLoginAt           DateTime? @map("last_login_at")
  lastLoginIp           String?  @map("last_login_ip")
  loginCount            Int      @default(0) @map("login_count")
  failedLoginAttempts   Int      @default(0) @map("failed_login_attempts")
  isLocked              Boolean  @default(false) @map("is_locked")
  lockedUntil           DateTime? @map("locked_until")
  lockReason            String?  @map("lock_reason")
  status                String   @default("PENDING") // PENDING, ACTIVE, INACTIVE, LOCKED, SUSPENDED, DELETED
  // IdP Abstraction (per Chief Architect recommendation)
  authProvider          String   @default("LOCAL") @map("auth_provider") // LOCAL, GOOGLE, MICROSOFT, LDAP, SAML
  authProviderId        String?  @map("auth_provider_id") // External ID from provider
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")
  deletedAt             DateTime? @map("deleted_at")

  profile               UserProfile?
  devices               UserDevice[]
  sessions              UserSession[]
  passwordHistory       PasswordHistory[]
  passwordResetTokens   PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]

  @@map("users")
  @@index([email, status], map: "idx_users_email_status")
  @@index([username, status], map: "idx_users_username_status")
  @@index([status, isLocked], map: "idx_users_status_locked")
  @@index([authProvider], map: "idx_users_auth_provider")
}

// ─── User Profiles ────────────────────────────────────────────
model UserProfile {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @unique @db.Uuid @map("user_id")
  bio             String?
  dateOfBirth     DateTime? @map("date_of_birth")
  gender          String?
  nationality     String?
  maritalStatus   String?   @map("marital_status")
  bloodGroup      String?   @map("blood_group")
  emergencyContactName    String?  @map("emergency_contact_name")
  emergencyContactPhone   String?  @map("emergency_contact_phone")
  emergencyContactRelation String? @map("emergency_contact_relation")
  addressLine1    String?   @map("address_line_1")
  addressLine2    String?   @map("address_line_2")
  city            String?
  state           String?
  country         String?
  postalCode      String?   @map("postal_code")
  linkedinUrl     String?   @map("linkedin_url")
  twitterUrl      String?   @map("twitter_url")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

// ─── User Devices (Entity 604) ────────────────────────────────
model UserDevice {
  id                  String   @id @default(uuid()) @db.Uuid
  userId              String   @db.Uuid @map("user_id")
  deviceType          String   @default("DESKTOP") @map("device_type") // DESKTOP, LAPTOP, MOBILE, TABLET, POS, BARCODE_SCANNER, KIOSK
  deviceName          String   @map("device_name")
  deviceFingerprint   String   @unique @map("device_fingerprint")
  operatingSystem     String?  @map("operating_system")
  osVersion           String?  @map("os_version")
  browserName         String?  @map("browser_name")
  browserVersion      String?  @map("browser_version")
  appVersion          String?  @map("app_version")
  userAgent           String?  @map("user_agent")
  isTrusted           Boolean  @default(false) @map("is_trusted")
  isRegistered        Boolean  @default(false) @map("is_registered")
  lastActiveAt        DateTime @default(now()) @map("last_active_at")
  lastActiveIp        String?  @map("last_active_ip") @db.Inet
  registeredAt        DateTime @default(now()) @map("registered_at")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions            UserSession[]

  @@map("user_devices")
  @@index([userId, isTrusted], map: "idx_devices_user_trusted")
  @@index([deviceType], map: "idx_devices_type")
}

// ─── User Sessions (Entity 603) ───────────────────────────────
model UserSession {
  id                    String   @id @default(uuid()) @db.Uuid
  sessionId             String   @unique @map("session_id") @db.VarChar(200)
  userId                String   @db.Uuid @map("user_id")
  deviceId              String?  @db.Uuid @map("device_id")
  sessionType           String   @default("WEB") @map("session_type") // WEB, MOBILE_APP, TABLET, API, KIOSK, POS
  clientIp              String   @map("client_ip")
  clientUserAgent       String   @map("client_user_agent")
  geolocation           Json?
  loginAt               DateTime @default(now()) @map("login_at")
  logoutAt              DateTime? @map("logout_at")
  lastActivityAt        DateTime @default(now()) @map("last_activity_at")
  expiresAt             DateTime @map("expires_at")
  refreshTokenHash      String   @map("refresh_token_hash")
  refreshTokenExpiresAt DateTime @map("refresh_token_expires_at")
  rememberMe            Boolean  @default(false) @map("remember_me")
  mfaVerified           Boolean  @default(false) @map("mfa_verified")
  mfaVerifiedAt         DateTime? @map("mfa_verified_at")
  riskScore             Float    @default(0) @map("risk_score")
  isSuspicious          Boolean  @default(false) @map("is_suspicious")
  revokedAt             DateTime? @map("revoked_at")
  revocationReason      String?  @map("revocation_reason")
  status                String   @default("ACTIVE") // ACTIVE, EXPIRED, LOGGED_OUT, REVOKED, SUSPENDED
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  user                  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  device                UserDevice? @relation(fields: [deviceId], references: [id])

  @@map("user_sessions")
  @@index([userId, status], map: "idx_sessions_user_status")
  @@index([status, expiresAt], map: "idx_sessions_status_expires")
  @@index([sessionId], map: "idx_sessions_session_id")
}

// ─── Password History ─────────────────────────────────────────
model PasswordHistory {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @db.Uuid @map("user_id")
  passwordHash    String   @map("password_hash")
  passwordAlgorithm String @default("ARGON2ID") @map("password_algorithm")
  changedAt       DateTime @default(now()) @map("changed_at")
  changedBy       String?  @db.Uuid @map("changed_by") // Who changed it (self or admin)
  changeReason    String?  @map("change_reason") // LOGIN, RESET, EXPIRY, ADMIN_RESET

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_history")
  @@index([userId, changedAt], map: "idx_pw_history_user_date")
}

// ─── Password Reset Tokens ────────────────────────────────────
model PasswordResetToken {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @db.Uuid @map("user_id")
  token           String   @unique @db.VarChar(500)
  tokenHash       String   @unique @map("token_hash") @db.VarChar(500)
  expiresAt       DateTime @map("expires_at") // 15 minutes
  usedAt          DateTime? @map("used_at")
  usedFromIp      String?  @map("used_from_ip") @db.Inet
  requestedAt     DateTime @default(now()) @map("requested_at")
  requestedFromIp String   @map("requested_from_ip") @db.Inet
  isUsed          Boolean  @default(false) @map("is_used")
  isExpired       Boolean  @default(false) @map("is_expired")
  status          String   @default("ACTIVE") // ACTIVE, USED, EXPIRED, CANCELLED

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
  @@index([userId, status], map: "idx_reset_tokens_user_status")
  @@index([tokenHash, status], map: "idx_reset_tokens_hash_status")
  @@index([expiresAt], map: "idx_reset_tokens_expires")
}

// ─── Email Verification Tokens ────────────────────────────────
model EmailVerificationToken {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @db.Uuid @map("user_id")
  email           String   // The email being verified
  token           String   @unique @db.VarChar(500)
  tokenHash       String   @unique @map("token_hash") @db.VarChar(500)
  expiresAt       DateTime @map("expires_at") // 24 hours
  usedAt          DateTime? @map("used_at")
  sentAt          DateTime @default(now()) @map("sent_at")
  sentTo          String   @map("sent_to") // email address
  isUsed          Boolean  @default(false) @map("is_used")
  isExpired       Boolean  @default(false) @map("is_expired")
  status          String   @default("ACTIVE") // ACTIVE, USED, EXPIRED

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_verification_tokens")
  @@index([userId, status], map: "idx_email_tokens_user_status")
  @@index([tokenHash, status], map: "idx_email_tokens_hash_status")
}

// ═══════════════════════════════════════════════════════════════
// PLATFORM TABLES (from Sprint 2 — kept for compatibility)
// ═══════════════════════════════════════════════════════════════

model AuditLog {
  id                  String   @id @default(uuid()) @db.Uuid
  eventId             String   @unique @map("event_id")
  businessModule      String   @map("business_module")
  entityType          String   @map("entity_type")
  entityId            String   @map("entity_id")
  action              String
  actionCategory      String   @map("action_category")
  eventType           String   @map("event_type")
  actorId             String?  @db.Uuid @map("actor_id")
  actorName           String?  @map("actor_name")
  actorType           String   @default("USER") @map("actor_type")
  actionTimestamp     DateTime @default(now()) @map("action_timestamp")
  ipAddress           String?  @db.Inet @map("ip_address")
  userAgent           String?  @map("user_agent")
  sessionId           String?  @db.Uuid @map("session_id")
  correlationId       String?  @db.Uuid @map("correlation_id")
  beforeValues        Json?    @map("before_values")
  afterValues         Json?    @map("after_values")
  changeSummary       String?  @map("change_summary")
  businessContext     Json     @default("{}") @map("business_context")
  riskScore           Float    @default(0) @map("risk_score")
  isFlagged           Boolean  @default(false) @map("is_flagged")
  recordHash          String   @map("record_hash")
  previousHash        String?  @map("previous_hash")
  companyId           String?  @db.Uuid @map("company_id")
  retentionUntil      Date     @map("retention_until")
  status              String   @default("RECORDED")
  createdAt           DateTime @default(now()) @map("created_at")

  @@map("audit_logs")
  @@index([businessModule, entityType, entityId, actionTimestamp], map: "idx_audit_entity_time")
  @@index([actorId, actionTimestamp], map: "idx_audit_actor_time")
}

model SystemSetting {
  id                  String   @id @default(uuid()) @db.Uuid
  configKey           String   @unique @map("config_key")
  configName          String   @map("config_name")
  configCategory      String   @default("COMPANY_SETTINGS") @map("config_category")
  configType          String   @default("SETTING") @map("config_type")
  dataType            String   @default("STRING")
  defaultValue        String   @map("default_value")
  currentValue        String   @map("current_value")
  status              String   @default("ACTIVE")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
  @@index([configKey, status], map: "idx_settings_key_status")
}

// ═══════════════════════════════════════════════════════════════
// ORGANIZATION PLATFORM — Sprint 4
// Epics 1-8: Enterprise, Company, BU, Division, Branch, Plant,
//            Warehouse (Master), Department, Cost Center
// ═══════════════════════════════════════════════════════════════

// ─── Enterprises (Epic 1) ─────────────────────────────────────
model Enterprise {
  id              String   @id @default(uuid()) @db.Uuid
  enterpriseCode  String   @unique @map("enterprise_code")
  name            String
  legalName       String?  @map("legal_name")
  gstNumber       String?  @map("gst_number") @db.VarChar(15)
  panNumber       String?  @map("pan_number") @db.VarChar(10)
  country         String   @default("IN") @db.Char(2)
  currencyCode    String   @default("INR") @map("currency_code") @db.Char(3)
  timezone        String   @default("Asia/Kolkata")
  locale          String   @default("en-IN")
  logoUrl         String?  @map("logo_url")
  website         String?
  status          String   @default("ACTIVE")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  companies       Company[]
  contacts        EnterpriseContact[]
  settings        EnterpriseSetting[]

  @@map("enterprises")
  @@index([status], map: "idx_enterprise_status")
}

model EnterpriseSetting {
  id              String   @id @default(uuid()) @db.Uuid
  enterpriseId    String   @db.Uuid @map("enterprise_id")
  settingKey      String   @map("setting_key")
  settingValue    String   @map("setting_value")
  dataType        String   @default("STRING")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  enterprise      Enterprise @relation(fields: [enterpriseId], references: [id], onDelete: Cascade)

  @@unique([enterpriseId, settingKey], map: "enterprise_setting_unique")
  @@map("enterprise_settings")
}

model EnterpriseContact {
  id              String   @id @default(uuid()) @db.Uuid
  enterpriseId    String   @db.Uuid @map("enterprise_id")
  contactName     String   @map("contact_name")
  contactType     String   @default("PRIMARY") @map("contact_type")
  email           String?
  phone           String?
  mobile          String?
  designation     String?
  isPrimary       Boolean  @default(false) @map("is_primary")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  enterprise      Enterprise @relation(fields: [enterpriseId], references: [id], onDelete: Cascade)

  @@map("enterprise_contacts")
  @@index([enterpriseId, contactType], map: "idx_ec_enterprise_type")
}

// ─── Companies (Epic 2) ───────────────────────────────────────
model Company {
  id              String   @id @default(uuid()) @db.Uuid
  enterpriseId    String   @db.Uuid @map("enterprise_id")
  companyCode     String   @unique @map("company_code")
  companyName     String   @map("company_name")
  legalName       String?  @map("legal_name")
  companyType     String   @default("PRIVATE_LIMITED") @map("company_type")
  gstin           String?  @db.VarChar(15)
  pan             String?  @db.VarChar(10)
  cin             String?
  currencyCode    String   @default("INR") @map("currency_code") @db.Char(3)
  timezone        String   @default("Asia/Kolkata")
  locale          String   @default("en-IN")
  fiscalYearStart Int      @default(4) @map("fiscal_year_start")
  fiscalYearEnd   Int      @default(3) @map("fiscal_year_end")
  website         String?
  logoUrl         String?  @map("logo_url")
  status          String   @default("ACTIVE")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  enterprise      Enterprise     @relation(fields: [enterpriseId], references: [id])
  addresses       CompanyAddress[]
  taxProfiles     CompanyTaxProfile[]
  bankAccounts    CompanyBankAccount[]
  businessUnits   BusinessUnit[]
  branches        Branch[]
  departments     Department[]
  costCenters     CostCenter[]

  @@map("companies")
  @@index([enterpriseId, status], map: "idx_company_enterprise_status")
  @@index([gstin], map: "idx_company_gstin")
}

model CompanyAddress {
  id              String   @id @default(uuid()) @db.Uuid
  companyId       String   @db.Uuid @map("company_id")
  addressType     String   @default("REGISTERED") @map("address_type") // REGISTERED, OPERATIONAL, BRANCH
  addressLine1    String   @map("address_line_1")
  addressLine2    String?  @map("address_line_2")
  city            String
  state           String
  country         String   @default("India")
  postalCode      String   @map("postal_code")
  stateCode       String?  @map("state_code")
  countryCode     String   @default("IN") @map("country_code") @db.Char(2)
  latitude        Decimal? @db.Decimal(10, 7)
  longitude       Decimal? @db.Decimal(10, 7)
  isDefault       Boolean  @default(false) @map("is_default")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  company         Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("company_addresses")
  @@index([companyId, addressType], map: "idx_ca_company_type")
}

model CompanyTaxProfile {
  id              String   @id @default(uuid()) @db.Uuid
  companyId       String   @db.Uuid @map("company_id")
  taxType         String   @map("tax_type") // GST, INCOME_TAX, PROFESSIONAL_TAX, LWF, TDS
  taxNumber       String   @map("tax_number")
  registrationDate DateTime? @map("registration_date")
  jurisdiction    String?
  filingFrequency String?  @map("filing_frequency")
  status          String   @default("ACTIVE")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  company         Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("company_tax_profiles")
  @@index([companyId, taxType], map: "idx_ctp_company_type")
}

model CompanyBankAccount {
  id              String   @id @default(uuid()) @db.Uuid
  companyId       String   @db.Uuid @map("company_id")
  accountName     String   @map("account_name")
  accountNumber   String   @map("account_number")
  bankName        String   @map("bank_name")
  branchName      String?  @map("branch_name")
  ifscCode        String   @map("ifsc_code") @db.VarChar(11)
  accountType     String   @default("CURRENT") @map("account_type") // CURRENT, SAVINGS, ESCROW
  isDefault       Boolean  @default(false) @map("is_default")
  upiId           String?  @map("upi_id")
  status          String   @default("ACTIVE")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  company         Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("company_bank_accounts")
  @@index([companyId, status], map: "idx_cba_company_status")
}

// ─── Business Units & Divisions (Epic 3) ──────────────────────
model BusinessUnit {
  id              String   @id @default(uuid()) @db.Uuid
  companyId       String   @db.Uuid @map("company_id")
  buCode          String   @unique @map("bu_code")
  buName          String   @map("bu_name")
  buType          String   @default("MANUFACTURING") @map("bu_type") // MANUFACTURING, RETAIL, RESTAURANT, DISTRIBUTION, CORPORATE, ECOMMERCE
  description     String?
  headUserId      String?  @db.Uuid @map("head_user_id")
  parentId        String?  @db.Uuid @map("parent_id") // For nested BUs
  status          String   @default("ACTIVE")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  company         Company     @relation(fields: [companyId], references: [id])
  divisions       Division[]
  branches        Branch[]
  parent          BusinessUnit?  @relation("BUHierarchy", fields: [parentId], references: [id])
  children        BusinessUnit[] @relation("BUHierarchy")

  @@map("business_units")
  @@index([companyId, status], map: "idx_bu_company_status")
  @@index([buType, status], map: "idx_bu_type_status")
}

model Division {
  id              String   @id @default(uuid()) @db.Uuid
  buId            String   @db.Uuid @map("bu_id")
  divisionCode    String   @unique @map("division_code")
  divisionName    String   @map("division_name")
  description     String?
  headUserId      String?  @db.Uuid @map("head_user_id")
  status          String   @default("ACTIVE")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  businessUnit    BusinessUnit @relation(fields: [buId], references: [id])
  branches        Branch[]

  @@map("divisions")
  @@index([buId, status], map: "idx_div_bu_status")
}

// ─── Branches (Epic 4) ────────────────────────────────────────
model Branch {
  id              String   @id @default(uuid()) @db.Uuid
  companyId       String   @db.Uuid @map("company_id")
  buId            String?  @db.Uuid @map("bu_id")
  divisionId      String?  @db.Uuid @map("division_id")
  branchCode      String   @unique @map("branch_code")
  branchName      String   @map("branch_name")
  branchType      String   @default("OFFICE") @map("branch_type") // HEAD_OFFICE, PLANT, WAREHOUSE, STORE, RESTAURANT, OFFICE, DISTRIBUTION_CENTER
  branchManagerId String?  @db.Uuid @map("branch_manager_id")
  currencyCode    String   @default("INR") @map("currency_code") @db.Char(3)
  timezone        String   @default("Asia/Kolkata")
  locale          String   @default("en-IN")
  taxRegionCode   String?  @map("tax_region_code")
  gstin           String?  @db.VarChar(15)
  stateCode       String?  @map("state_code")
  countryCode     String   @default("IN") @map("country_code") @db.Char(2)
  latitude        Decimal? @db.Decimal(10, 7)
  longitude       Decimal? @db.Decimal(10, 7)
  isOperational   Boolean  @default(true) @map("is_operational")
  workingHours    Json?    @map("working_hours")
  status          String   @default("ACTIVE")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  company         Company       @relation(fields: [companyId], references: [id])
  businessUnit    BusinessUnit? @relation(fields: [buId], references: [id])
  division        Division?     @relation(fields: [divisionId], references: [id])
  addresses       BranchAddress[]
  contacts        BranchContact[]
  plants          Plant[]
  warehouses      Warehouse[]
  departments     Department[]
  costCenters     CostCenter[]

  @@map("branches")
  @@index([companyId, status], map: "idx_branch_company_status")
  @@index([branchType, status], map: "idx_branch_type_status")
  @@index([buId, status], map: "idx_branch_bu_status")
}

model BranchAddress {
  id              String   @id @default(uuid()) @db.Uuid
  branchId        String   @db.Uuid @map("branch_id")
  addressType     String   @default("OPERATIONAL") @map("address_type")
  addressLine1    String   @map("address_line_1")
  addressLine2    String?  @map("address_line_2")
  city            String
  state           String
  country         String   @default("India")
  postalCode      String   @map("postal_code")
  latitude        Decimal? @db.Decimal(10, 7)
  longitude       Decimal? @db.Decimal(10, 7)
  isDefault       Boolean  @default(false) @map("is_default")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  branch          Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@map("branch_addresses")
  @@index([branchId, addressType], map: "idx_ba_branch_type")
}

model BranchContact {
  id              String   @id @default(uuid()) @db.Uuid
  branchId        String   @db.Uuid @map("branch_id")
  contactName     String   @map("contact_name")
  contactType     String   @default("PRIMARY") @map("contact_type")
  email           String?
  phone           String?
  mobile          String?
  designation     String?
  isPrimary       Boolean  @default(false) @map("is_primary")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  branch          Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@map("branch_contacts")
  @@index([branchId, contactType], map: "idx_bc_branch_type")
}

// ─── Plants (Epic 5) ──────────────────────────────────────────
model Plant {
  id              String   @id @default(uuid()) @db.Uuid
  branchId        String   @db.Uuid @map("branch_id")
  plantCode       String   @unique @map("plant_code")
  plantName       String   @map("plant_name")
  plantType       String   @default("MANUFACTURING") @map("plant_type") // MANUFACTURING, PACKING, COLD_STORAGE, DISTRIBUTION
  capacityPerDay  Decimal? @map("capacity_per_day") @db.Decimal(15, 3)
  capacityUnit    String?  @map("capacity_unit")
  shiftModel      String   @default("SINGLE") @map("shift_model") // SINGLE, DOUBLE, TRIPLE
  workingDays     String[] @default(["MON", "TUE", "WED", "THU", "FRI"]) @map("working_days")
  calendarId      String?  @db.Uuid @map("calendar_id")
  plantManagerId  String?  @db.Uuid @map("plant_manager_id")
  status          String   @default("ACTIVE")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  branch          Branch   @relation(fields: [branchId], references: [id])
  settings        PlantSetting[]
  warehouses      Warehouse[]

  @@map("plants")
  @@index([branchId, status], map: "idx_plant_branch_status")
  @@index([plantType, status], map: "idx_plant_type_status")
}

model PlantSetting {
  id              String   @id @default(uuid()) @db.Uuid
  plantId         String   @db.Uuid @map("plant_id")
  settingKey      String   @map("setting_key")
  settingValue    String   @map("setting_value")
  dataType        String   @default("STRING")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  plant           Plant    @relation(fields: [plantId], references: [id], onDelete: Cascade)

  @@unique([plantId, settingKey], map: "plant_setting_unique")
  @@map("plant_settings")
}

// ─── Warehouses — Master Data Only (Epic 6) ───────────────────
model Warehouse {
  id              String   @id @default(uuid()) @db.Uuid
  branchId        String   @db.Uuid @map("branch_id")
  plantId         String?  @db.Uuid @map("plant_id")
  warehouseCode   String   @unique @map("warehouse_code")
  warehouseName   String   @map("warehouse_name")
  warehouseType   String   @default("FINISHED_GOODS") @map("warehouse_type") // FINISHED_GOODS, RAW_MATERIAL, PACKAGING, RETURN, TRANSIT, COLD_STORAGE, PRODUCTION, RETAIL, RESTAURANT
  capacityVolume  Decimal? @map("capacity_volume") @db.Decimal(15, 3)
  capacityWeight  Decimal? @map("capacity_weight") @db.Decimal(15, 3)
  capacityUnit    String?  @map("capacity_unit")
  temperatureZone String?  @map("temperature_zone") // AMBIENT, CHILLED, FROZEN
  temperatureMin  Decimal? @map("temperature_min") @db.Decimal(5, 2)
  temperatureMax  Decimal? @map("temperature_max") @db.Decimal(5, 2)
  warehouseManagerId String? @db.Uuid @map("warehouse_manager_id")
  status          String   @default("ACTIVE")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  branch          Branch   @relation(fields: [branchId], references: [id])
  plant           Plant?   @relation(fields: [plantId], references: [id])
  settings        WarehouseSetting[]

  @@map("warehouses")
  @@index([branchId, status], map: "idx_wh_branch_status")
  @@index([warehouseType, status], map: "idx_wh_type_status")
  @@index([plantId, status], map: "idx_wh_plant_status")
}

model WarehouseSetting {
  id              String   @id @default(uuid()) @db.Uuid
  warehouseId     String   @db.Uuid @map("warehouse_id")
  settingKey      String   @map("setting_key")
  settingValue    String   @map("setting_value")
  dataType        String   @default("STRING")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  warehouse       Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@unique([warehouseId, settingKey], map: "warehouse_setting_unique")
  @@map("warehouse_settings")
}

// ─── Departments (Epic 7) ─────────────────────────────────────
model Department {
  id              String   @id @default(uuid()) @db.Uuid
  companyId       String   @db.Uuid @map("company_id")
  branchId        String?  @db.Uuid @map("branch_id")
  deptCode        String   @unique @map("dept_code")
  deptName        String   @map("dept_name")
  description     String?
  parentId        String?  @db.Uuid @map("parent_id") // For nested departments
  headUserId      String?  @db.Uuid @map("head_user_id")
  costCenterId    String?  @db.Uuid @map("cost_center_id")
  status          String   @default("ACTIVE")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  company         Company     @relation(fields: [companyId], references: [id])
  branch          Branch?     @relation(fields: [branchId], references: [id])
  costCenter      CostCenter? @relation(fields: [costCenterId], references: [id])
  parent          Department? @relation("DeptHierarchy", fields: [parentId], references: [id])
  children        Department[] @relation("DeptHierarchy")
  heads           DepartmentHead[]

  @@map("departments")
  @@index([companyId, status], map: "idx_dept_company_status")
  @@index([branchId, status], map: "idx_dept_branch_status")
  @@index([parentId], map: "idx_dept_parent")
}

model DepartmentHead {
  id              String   @id @default(uuid()) @db.Uuid
  deptId          String   @db.Uuid @map("dept_id")
  userId          String   @db.Uuid @map("user_id")
  role            String   @default("HEAD") // HEAD, DEPUTY, ACTING
  assignedAt      DateTime @default(now()) @map("assigned_at")
  endDate         DateTime? @map("end_date")
  status          String   @default("ACTIVE")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  department      Department @relation(fields: [deptId], references: [id], onDelete: Cascade)

  @@unique([deptId, userId, role], map: "dept_head_unique")
  @@map("department_heads")
  @@index([deptId, status], map: "idx_dh_dept_status")
}

// ─── Cost Centers (Epic 8) ────────────────────────────────────
model CostCenter {
  id              String   @id @default(uuid()) @db.Uuid
  companyId       String   @db.Uuid @map("company_id")
  branchId        String?  @db.Uuid @map("branch_id")
  costCenterCode  String   @unique @map("cost_center_code")
  costCenterName  String   @map("cost_center_name")
  costCenterType  String   @default("OPERATIONAL") @map("cost_center_type") // OPERATIONAL, ADMINISTRATIVE, SUPPORT, PROFIT_CENTER
  description     String?
  parentId        String?  @db.Uuid @map("parent_id")
  glAccountCode   String?  @map("gl_account_code")
  budgetAnnual    Decimal? @map("budget_annual") @db.Decimal(18, 4)
  currencyCode    String   @default("INR") @map("currency_code") @db.Char(3)
  status          String   @default("ACTIVE")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  company         Company     @relation(fields: [companyId], references: [id])
  branch          Branch?     @relation(fields: [branchId], references: [id])
  departments     Department[]
  parent          CostCenter? @relation("CostCenterHierarchy", fields: [parentId], references: [id])
  children        CostCenter[] @relation("CostCenterHierarchy")

  @@map("cost_centers")
  @@index([companyId, status], map: "idx_cc_company_status")
  @@index([branchId, status], map: "idx_cc_branch_status")
  @@index([costCenterType, status], map: "idx_cc_type_status")
}

// ─── Organization Tree View (Materialized for performance) ────
model OrganizationTreeNode {
  id              String   @id @default(uuid()) @db.Uuid
  entityType      String   @map("entity_type") // ENTERPRISE, COMPANY, BU, DIVISION, BRANCH, PLANT, WAREHOUSE, DEPARTMENT, COST_CENTER
  entityId        String   @db.Uuid @map("entity_id")
  entityCode      String   @map("entity_code")
  entityName      String   @map("entity_name")
  parentId        String?  @db.Uuid @map("parent_id")
  parentType      String?  @map("parent_type")
  hierarchyLevel  Int      @map("hierarchy_level")
  hierarchyPath   String   @map("hierarchy_path")
  childrenCount   Int      @default(0) @map("children_count")
  status          String   @default("ACTIVE")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("organization_tree_nodes")
  @@unique([entityType, entityId], map: "org_tree_entity_unique")
  @@index([parentType, parentId], map: "idx_otn_parent")
  @@index([hierarchyLevel], map: "idx_otn_level")
  @@index([entityType, status], map: "idx_otn_type_status")
}

// ═══════════════════════════════════════════════════════════════
// AUTHORIZATION PLATFORM — Sprint 5
// Epics 1-8: Roles, Permissions, User Groups, Menus,
//            Approval Authority, Security Policies, Feature Flags
// ═══════════════════════════════════════════════════════════════

// ─── Roles (Epic 1) ───────────────────────────────────────────
model Role {
  id              String   @id @default(uuid()) @db.Uuid
  roleCode        String   @unique @map("role_code")
  roleName        String   @map("role_name")
  roleDescription String?  @map("role_description")
  roleType        String   @default("CUSTOM") @map("role_type") // SYSTEM, BUILTIN, CUSTOM, TEMPLATE
  roleCategory    String   @default("OTHER") @map("role_category") // EXECUTIVE, MANAGEMENT, MANAGER, SUPERVISOR, OPERATOR, CLERK, TECHNICIAN, EXTERNAL_USER, SYSTEM, OTHER
  isSystemRole    Boolean  @default(false) @map("is_system_role")
  parentRoleId    String?  @db.Uuid @map("parent_role_id") // Role hierarchy
  companyId       String?  @db.Uuid @map("company_id") // NULL = enterprise-wide
  accessLevel     String   @default("BRANCH") @map("access_level") // ENTERPRISE, COMPANY, BUSINESS_UNIT, BRANCH, DEPARTMENT, SELF
  requiresMfa     Boolean  @default(false) @map("requires_mfa")
  maxSessionMinutes Int    @default(480) @map("max_session_minutes")
  concurrentSessions Int   @default(3) @map("concurrent_sessions")
  priority        Int      @default(100)
  status          String   @default("ACTIVE")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  parent          Role?         @relation("RoleHierarchy", fields: [parentRoleId], references: [id])
  children        Role[]        @relation("RoleHierarchy")
  rolePermissions RolePermission[]
  roleAssignments RoleAssignment[]
  groupRoles      GroupRole[]

  @@map("roles")
  @@index([companyId, status], map: "idx_role_company_status")
  @@index([roleType, isSystemRole], map: "idx_role_type_system")
  @@index([parentRoleId], map: "idx_role_parent")
}

// ─── Permissions (Epic 2) ─────────────────────────────────────
model Permission {
  id                  String   @id @default(uuid()) @db.Uuid
  permissionCode      String   @unique @map("permission_code") // e.g., INVENTORY:PRODUCT:CREATE
  permissionName      String   @map("permission_name")
  permissionDescription String? @map("permission_description")
  module              String   // PLATFORM, ORGANIZATION, INVENTORY, WAREHOUSE, MANUFACTURING, FINANCE, HR, MAINTENANCE, REPORTS, SETTINGS
  resource            String   // PRODUCT, INVOICE, WORK_ORDER, etc.
  action              String   // CREATE, READ, UPDATE, DELETE, APPROVE, REJECT, EXPORT, IMPORT, PRINT, EXECUTE, CANCEL, REVERSE, CLOSE, ARCHIVE
  permissionGroupId   String?  @db.Uuid @map("permission_group_id")
  permissionType      String   @default("ACTION") @map("permission_type") // ACTION, FIELD_LEVEL, RECORD_LEVEL, WILDCARD
  isDangerous         Boolean  @default(false) @map("is_dangerous")
  isSystemPermission  Boolean  @default(false) @map("is_system_permission")
  status              String   @default("ACTIVE")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  permissionGroup     PermissionGroup? @relation(fields: [permissionGroupId], references: [id])
  rolePermissions     RolePermission[]

  @@map("permissions")
  @@index([module, resource, action], map: "idx_perm_module_resource_action")
  @@index([permissionType, status], map: "idx_perm_type_status")
  @@index([permissionGroupId], map: "idx_perm_group")
}

model PermissionGroup {
  id              String   @id @default(uuid()) @db.Uuid
  groupCode       String   @unique @map("group_code")
  groupName       String   @map("group_name")
  module          String   // Same as Permission.module
  description     String?
  displayOrder    Int      @default(100) @map("display_order")
  status          String   @default("ACTIVE")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  permissions     Permission[]

  @@map("permission_groups")
  @@index([module, status], map: "idx_pg_module_status")
}

// ─── Role-Permission Mapping ──────────────────────────────────
model RolePermission {
  id            String   @id @default(uuid()) @db.Uuid
  roleId        String   @db.Uuid @map("role_id")
  permissionId  String   @db.Uuid @map("permission_id")
  grantedBy     String?  @db.Uuid @map("granted_by")
  grantedAt     DateTime @default(now()) @map("granted_at")
  createdAt     DateTime @default(now()) @map("created_at")

  role          Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission    Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId], map: "role_permission_unique")
  @@map("role_permissions")
  @@index([roleId], map: "idx_rp_role")
  @@index([permissionId], map: "idx_rp_permission")
}

// ─── Role Assignments (User-Role mapping) ─────────────────────
model RoleAssignment {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @db.Uuid @map("user_id")
  roleId          String   @db.Uuid @map("role_id")
  companyId       String?  @db.Uuid @map("company_id") // Scope to company
  branchId        String?  @db.Uuid @map("branch_id") // Scope to branch
  assignedBy      String?  @db.Uuid @map("assigned_by")
  assignedAt      DateTime @default(now()) @map("assigned_at")
  expiresAt       DateTime? @map("expires_at")
  status          String   @default("ACTIVE")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  role            Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId, branchId], map: "role_assignment_unique")
  @@map("role_assignments")
  @@index([userId, status], map: "idx_ra_user_status")
  @@index([roleId, status], map: "idx_ra_role_status")
}

// ─── User Groups (Epic 3) ─────────────────────────────────────
model UserGroup {
  id              String   @id @default(uuid()) @db.Uuid
  groupCode       String   @unique @map("group_code")
  groupName       String   @map("group_name")
  groupDescription String? @map("group_description")
  groupType       String   @default("TEAM") @map("group_type") // TEAM, DEPARTMENT, FUNCTIONAL, PROJECT
  companyId       String?  @db.Uuid @map("company_id")
  branchId        String?  @db.Uuid @map("branch_id")
  status          String   @default("ACTIVE")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  members         GroupMember[]
  groupRoles      GroupRole[]

  @@map("user_groups")
  @@index([companyId, status], map: "idx_ug_company_status")
  @@index([groupType, status], map: "idx_ug_type_status")
}

model GroupMember {
  id              String   @id @default(uuid()) @db.Uuid
  groupId         String   @db.Uuid @map("group_id")
  userId          String   @db.Uuid @map("user_id")
  role            String   @default("MEMBER") // MEMBER, ADMIN, OWNER
  addedBy         String?  @db.Uuid @map("added_by")
  addedAt         DateTime @default(now()) @map("added_at")
  status          String   @default("ACTIVE")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  userGroup       UserGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId], map: "group_member_unique")
  @@map("group_members")
  @@index([groupId, status], map: "idx_gm_group_status")
  @@index([userId, status], map: "idx_gm_user_status")
}

model GroupRole {
  id              String   @id @default(uuid()) @db.Uuid
  groupId         String   @db.Uuid @map("group_id")
  roleId          String   @db.Uuid @map("role_id")
  assignedAt      DateTime @default(now()) @map("assigned_at")
  status          String   @default("ACTIVE")
  createdAt       DateTime @default(now()) @map("created_at")

  userGroup       UserGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  role            Role      @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([groupId, roleId], map: "group_role_unique")
  @@map("group_roles")
  @@index([groupId, status], map: "idx_gr_group_status")
}

// ─── Menus (Epic 4 & 9 — Dynamic Navigation) ──────────────────
model Menu {
  id              String   @id @default(uuid()) @db.Uuid
  menuCode        String   @unique @map("menu_code")
  menuLabel       String   @map("menu_label")
  menuIcon        String?  @map("menu_icon") // Lucide icon name
  menuType        String   @default("ITEM") @map("menu_type") // GROUP, ITEM, SEPARATOR, LINK
  moduleId        String?  @map("module_id") // PLT, ORG, INV, WMS, MES, FIN, HR, EAM, RTL, RST, AI
  route           String?  // Frontend route: /inventory/products
  externalUrl     String?  @map("external_url")
  parentMenuId    String?  @db.Uuid @map("parent_menu_id")
  displayOrder    Int      @default(100) @map("display_order")
  isVisible       Boolean  @default(true) @map("is_visible")
  isPinnable      Boolean  @default(true) @map("is_pinnable")
  badgeType       String?  @map("badge_type") // COUNT, ALERT, NEW
  badgeSource     String?  @map("badge_source") // API endpoint for badge count
  status          String   @default("ACTIVE")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  parent          Menu?     @relation("MenuHierarchy", fields: [parentMenuId], references: [id])
  children        Menu[]    @relation("MenuHierarchy")
  menuPermissions MenuPermission[]

  @@map("menus")
  @@index([parentMenuId, displayOrder], map: "idx_menu_parent_order")
  @@index([moduleId, status], map: "idx_menu_module_status")
  @@index([isVisible, status], map: "idx_menu_visible_status")
}

model MenuPermission {
  id              String   @id @default(uuid()) @db.Uuid
  menuId          String   @db.Uuid @map("menu_id")
  permissionId    String   @db.Uuid @map("permission_id")
  required        Boolean  @default(true) // If true, permission is required to see menu; if false, it's optional
  createdAt       DateTime @default(now()) @map("created_at")

  menu            Menu       @relation(fields: [menuId], references: [id], onDelete: Cascade)
  permission      Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([menuId, permissionId], map: "menu_permission_unique")
  @@map("menu_permissions")
  @@index([menuId], map: "idx_mp_menu")
  @@index([permissionId], map: "idx_mp_permission")
}

// ─── Approval Authority (Epic 6) ──────────────────────────────
model ApprovalLevel {
  id              String   @id @default(uuid()) @db.Uuid
  levelCode       String   @unique @map("level_code")
  levelName       String   @map("level_name")
  companyId       String?  @db.Uuid @map("company_id")
  module          String   // PROCUREMENT, FINANCE, HR, MAINTENANCE, MANUFACTURING
  documentType    String   @map("document_type") // PURCHASE_ORDER, EXPENSE, LEAVE, WORK_ORDER, etc.
  levelNumber     Int      @map("level_number") // 1, 2, 3, 4
  roleName        String   @map("role_name") // DEPT_HEAD, FINANCE_MANAGER, DIRECTOR, CEO
  minAmount       Decimal  @default(0) @map("min_amount") @db.Decimal(18, 4)
  maxAmount       Decimal? @map("max_amount") @db.Decimal(18, 4) // NULL = unlimited
  currencyCode    String   @default("INR") @map("currency_code") @db.Char(3)
  requiresDualApproval Boolean @default(false) @map("requires_dual_approval")
  slaHours        Int      @default(48) @map("sla_hours")
  status          String   @default("ACTIVE")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("approval_levels")
  @@index([companyId, module, documentType], map: "idx_al_company_module_doc")
  @@index([levelNumber, status], map: "idx_al_level_status")
}

model ApprovalLimit {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @db.Uuid @map("user_id")
  companyId       String   @db.Uuid @map("company_id")
  module          String   // PROCUREMENT, FINANCE, HR, MAINTENANCE
  documentType    String   @map("document_type")
  maxAmount       Decimal  @map("max_amount") @db.Decimal(18, 4)
  currencyCode    String   @default("INR") @map("currency_code") @db.Char(3)
  dailyLimit      Decimal? @map("daily_limit") @db.Decimal(18, 4)
  monthlyLimit    Decimal? @map("monthly_limit") @db.Decimal(18, 4)
  effectiveFrom   DateTime @default(now()) @map("effective_from")
  effectiveTo     DateTime? @map("effective_to")
  status          String   @default("ACTIVE")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("approval_limits")
  @@index([userId, module, documentType, status], map: "idx_appr_user_module_doc")
  @@index([companyId, status], map: "idx_appr_company_status")
}

// ─── Security Policies (Epic 7) ───────────────────────────────
model SecurityPolicy {
  id              String   @id @default(uuid()) @db.Uuid
  policyCode      String   @unique @map("policy_code")
  policyName      String   @map("policy_name")
  policyDescription String? @map("policy_description")
  policyType      String   @map("policy_type") // WORKING_HOURS, IP_RESTRICTION, COUNTRY_RESTRICTION, DEVICE_RESTRICTION, PASSWORD_POLICY, SESSION_TIMEOUT, CONCURRENT_SESSIONS
  companyId       String?  @db.Uuid @map("company_id") // NULL = enterprise-wide
  branchId        String?  @db.Uuid @map("branch_id") // NULL = all branches
  roleIds         String[] @default([]) @map("role_ids") // Specific roles
  conditions      Json     @default("{}") // Policy conditions (hours, IPs, countries, etc.)
  action          String   @default("DENY") // DENY, ALLOW_WITH_WARNING, REQUIRE_MFA, REQUIRE_APPROVAL
  priority        Int      @default(100)
  status          String   @default("ACTIVE")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("security_policies")
  @@index([policyType, status], map: "idx_sp_type_status")
  @@index([companyId, branchId, status], map: "idx_sp_company_branch_status")
}

// ─── Feature Flags (Epic 8) ───────────────────────────────────
model FeatureFlag {
  id                  String   @id @default(uuid()) @db.Uuid
  flagKey             String   @unique @map("flag_key")
  flagName            String   @map("flag_name")
  flagDescription     String?  @map("flag_description")
  flagType            String   @default("BOOLEAN") @map("flag_type") // BOOLEAN, STRING, INTEGER, JSON
  defaultState        String   @default("DISABLED") @map("default_state") // ENABLED, DISABLED
  currentState        String   @default("DISABLED") @map("current_state") // ENABLED, DISABLED, BETA, PILOT, GRADUAL_ROLLOUT
  rolloutPercentage   Decimal  @default(0) @map("rollout_percentage") @db.Decimal(5, 2)
  killSwitchEnabled   Boolean  @default(false) @map("kill_switch_enabled")
  killSwitchReason    String?  @map("kill_switch_reason")
  ownerUserId         String?  @db.Uuid @map("owner_user_id")
  status              String   @default("ACTIVE")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  assignments         FeatureAssignment[]

  @@map("feature_flags")
  @@index([currentState, status], map: "idx_ff_state_status")
  @@index([killSwitchEnabled], map: "idx_ff_kill_switch")
}

model FeatureAssignment {
  id              String   @id @default(uuid()) @db.Uuid
  flagId          String   @db.Uuid @map("flag_id")
  targetType      String   @map("target_type") // COMPANY, BRANCH, ROLE, USER, ENVIRONMENT
  targetId        String   @db.Uuid @map("target_id") // Company ID, Branch ID, Role ID, User ID
  isEnabled       Boolean  @default(false) @map("is_enabled")
  conditions      Json?    @default("{}") // Additional conditions
  assignedBy      String?  @db.Uuid @map("assigned_by")
  assignedAt      DateTime @default(now()) @map("assigned_at")
  status          String   @default("ACTIVE")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  featureFlag     FeatureFlag @relation(fields: [flagId], references: [id], onDelete: Cascade)

  @@unique([flagId, targetType, targetId], map: "feature_assignment_unique")
  @@map("feature_assignments")
  @@index([flagId, status], map: "idx_fa_flag_status")
  @@index([targetType, targetId, status], map: "idx_fa_target_status")
}

// ═══════════════════════════════════════════════════════════════
// MASTER DATA PLATFORM — Sprint 6
// Epics 1-8: Products, Categories, Brands, UOMs, Attributes,
//            Variants, Images, Documents
// + UPI (Universal Product Identity) per Chief Architect
// ═══════════════════════════════════════════════════════════════

// ─── Product Categories (Epic 2) ──────────────────────────────
model ProductCategory {
  id              String   @id @default(uuid()) @db.Uuid
  categoryCode    String   @unique @map("category_code")
  categoryName    String   @map("category_name")
  parentCategoryId String? @db.Uuid @map("parent_category_id")
  description     String?
  displayOrder    Int      @default(100) @map("display_order")
  level           Int      @default(1)
  path            String   @default("/")
  imageIcon       String?  @map("image_icon")
  isLeaf          Boolean  @default(true) @map("is_leaf") // Can have products assigned
  status          String   @default("ACTIVE")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  parent          ProductCategory?  @relation("CategoryHierarchy", fields: [parentCategoryId], references: [id])
  children        ProductCategory[] @relation("CategoryHierarchy")
  products        Product[]

  @@map("product_categories")
  @@index([parentCategoryId, displayOrder], map: "idx_pc_parent_order")
  @@index([status, isLeaf], map: "idx_pc_status_leaf")
}

// ─── Brands (Epic 3) ──────────────────────────────────────────
model Brand {
  id              String   @id @default(uuid()) @db.Uuid
  brandCode       String   @unique @map("brand_code")
  brandName       String   @map("brand_name")
  description     String?
  logoUrl         String?  @map("logo_url")
  website         String?
  manufacturer    String?
  isOem           Boolean  @default(false) @map("is_oem")
  isPrivateLabel  Boolean  @default(false) @map("is_private_label")
  status          String   @default("ACTIVE")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  products        Product[]

  @@map("brands")
  @@index([status], map: "idx_brand_status")
}

// ─── Units of Measure (Epic 4) ────────────────────────────────
model Uom {
  id              String   @id @default(uuid()) @db.Uuid
  uomCode         String   @unique @map("uom_code") // PCS, KG, G, L, ML, BOX, PKT, TRAY, BTL, BAG
  uomName         String   @map("uom_name")
  uomType         String   @default("COUNT") @map("uom_type") // COUNT, WEIGHT, VOLUME, LENGTH, TIME
  symbol          String?
  description     String?
  isBaseUnit      Boolean  @default(false) @map("is_base_unit")
  decimalPlaces   Int      @default(0) @map("decimal_places")
  status          String   @default("ACTIVE")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Self-referencing for conversions
  conversionsFrom UomConversion[] @relation("UomConversionFrom")
  conversionsTo   UomConversion[] @relation("UomConversionTo")
  products        Product[]

  @@map("uoms")
  @@index([uomType, status], map: "idx_uom_type_status")
}

model UomConversion {
  id              String   @id @default(uuid()) @db.Uuid
  fromUomId       String   @db.Uuid @map("from_uom_id")
  toUomId         String   @db.Uuid @map("to_uom_id")
  factor          Decimal  @db.Decimal(18, 6) // e.g., 1 KG = 1000 G (factor = 1000)
  companyId       String?  @db.Uuid @map("company_id") // NULL = global
  createdAt       DateTime @default(now()) @map("created_at")

  fromUom         Uom      @relation("UomConversionFrom", fields: [fromUomId], references: [id])
  toUom           Uom      @relation("UomConversionTo", fields: [toUomId], references: [id])

  @@unique([fromUomId, toUomId, companyId], map: "uom_conversion_unique")
  @@map("uom_conversions")
  @@index([fromUomId], map: "idx_uc_from")
  @@index([toUomId], map: "idx_uc_to")
}

// ─── Products (Epic 1 + UPI) ──────────────────────────────────
model Product {
  id              String   @id @default(uuid()) @db.Uuid
  // ─── UPI (Universal Product Identity) ───────────────────
  upi             String   @unique @map("upi") // Universal Product Identity — permanent, channel-agnostic
  // ─── Standard codes ─────────────────────────────────────
  productCode     String   @unique @map("product_code") // Internal code
  sku             String   @unique // Stock Keeping Unit
  // ─── Basic info ─────────────────────────────────────────
  name            String
  shortName       String?  @map("short_name")
  description     String?
  // ─── Classification ─────────────────────────────────────
  productType     String   @default("FINISHED_GOODS") @map("product_type") // FINISHED_GOODS, RAW_MATERIAL, PACKAGING, SEMI_FINISHED, CONSUMABLE, INGREDIENT, SERVICE, ASSET, SPARE_PART, KITCHEN_ITEM, GIFT_CARD
  status          String   @default("DRAFT") // DRAFT, ACTIVE, INACTIVE, BLOCKED, DISCONTINUED, ARCHIVED
  // ─── Relationships ──────────────────────────────────────
  brandId         String?  @db.Uuid @map("brand_id")
  categoryId      String?  @db.Uuid @map("category_id")
  defaultUomId    String   @db.Uuid @map("default_uom_id")
  // ─── Tax & Compliance ───────────────────────────────────
  hsnCode         String?  @map("hsn_code") @db.VarChar(10)
  taxGroupId      String?  @db.Uuid @map("tax_group_id") // Reference to future TaxGroup
  // ─── Tracking ───────────────────────────────────────────
  barcodeType     String   @default("EAN_13") @map("barcode_type") // EAN_13, UPC, CODE_128, GS1_128, QR
  trackBatch      Boolean  @default(false) @map("track_batch")
  trackSerial     Boolean  @default(false) @map("track_serial")
  trackExpiry     Boolean  @default(false) @map("track_expiry")
  shelfLifeDays   Int?     @map("shelf_life_days")
  // ─── Business flags (UPI channel mapping) ───────────────
  isManufactured  Boolean  @default(false) @map("is_manufactured")
  isPurchased     Boolean  @default(false) @map("is_purchased")
  isSold          Boolean  @default(true) @map("is_sold")
  isStockManaged  Boolean  @default(true) @map("is_stock_managed")
  isKitchenItem   Boolean  @default(false) @map("is_kitchen_item") // Restaurant ingredient
  // ─── Physical attributes ────────────────────────────────
  netWeight       Decimal? @map("net_weight") @db.Decimal(15, 3)
  grossWeight     Decimal? @map("gross_weight") @db.Decimal(15, 3)
  weightUomId     String?  @db.Uuid @map("weight_uom_id")
  length          Decimal? @db.Decimal(15, 3)
  width           Decimal? @db.Decimal(15, 3)
  height          Decimal? @db.Decimal(15, 3)
  dimensionUom    String?  @default("CM") @map("dimension_uom")
  // ─── Pricing ────────────────────────────────────────────
  defaultCostPrice Decimal? @map("default_cost_price") @db.Decimal(18, 4)
  defaultMrp       Decimal? @map("default_mrp") @db.Decimal(18, 4)
  defaultSellingPrice Decimal? @map("default_selling_price") @db.Decimal(18, 4)
  currencyCode    String   @default("INR") @map("currency_code") @db.Char(3)
  // ─── Audit ──────────────────────────────────────────────
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  // ─── Relations ──────────────────────────────────────────
  brand           Brand?           @relation(fields: [brandId], references: [id])
  category        ProductCategory? @relation(fields: [categoryId], references: [id])
  defaultUom      Uom              @relation(fields: [defaultUomId], references: [id])
  weightUom       Uom?             @relation(fields: [weightUomId], references: [id])
  attributes      ProductAttribute[]
  variants        ProductVariant[]
  images          ProductImage[]
  documents       ProductDocument[]

  @@map("products")
  @@index([productType, status], map: "idx_product_type_status")
  @@index([brandId, status], map: "idx_product_brand_status")
  @@index([categoryId, status], map: "idx_product_category_status")
  @@index([sku, status], map: "idx_product_sku_status")
  @@index([upi], map: "idx_product_upi")
  @@index([isManufactured, isPurchased, isSold], map: "idx_product_channels")
}

// ─── Product Attributes (Epic 5) ──────────────────────────────
model Attribute {
  id              String   @id @default(uuid()) @db.Uuid
  attributeCode   String   @unique @map("attribute_code") // FLAVOR, COLOR, WEIGHT, SIZE, MATERIAL, SHELF_LIFE, STORAGE_TEMP
  attributeName   String   @map("attribute_name")
  attributeType   String   @default("TEXT") @map("attribute_type") // TEXT, NUMBER, BOOLEAN, DATE, SELECT, MULTI_SELECT
  dataType        String   @default("STRING") // STRING, INTEGER, DECIMAL, BOOLEAN, DATE
  unit            String?  // e.g., "days" for shelf life, "°C" for storage temp
  isRequired      Boolean  @default(false) @map("is_required")
  isVariantAttribute Boolean @default(false) @map("is_variant_attribute") // Used for variants
  isSearchable    Boolean  @default(true) @map("is_searchable")
  displayOrder    Int      @default(100) @map("display_order")
  allowedValues   String[] @default([]) @map("allowed_values") // For SELECT type
  status          String   @default("ACTIVE")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  values          AttributeValue[]
  productAttributes ProductAttribute[]

  @@map("attributes")
  @@index([isVariantAttribute, status], map: "idx_attr_variant_status")
}

model AttributeValue {
  id              String   @id @default(uuid()) @db.Uuid
  attributeId     String   @db.Uuid @map("attribute_id")
  value           String
  displayValue    String?  @map("display_value") // For display (e.g., "250g" instead of "250")
  sortOrder       Int      @default(0) @map("sort_order")
  status          String   @default("ACTIVE")
  createdAt       DateTime @default(now()) @map("created_at")

  attribute       Attribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  @@unique([attributeId, value], map: "attr_value_unique")
  @@map("attribute_values")
  @@index([attributeId, status], map: "idx_av_attr_status")
}

model ProductAttribute {
  id              String   @id @default(uuid()) @db.Uuid
  productId       String   @db.Uuid @map("product_id")
  attributeId     String   @db.Uuid @map("attribute_id")
  attributeValueId String? @db.Uuid @map("attribute_value_id") // Reference to predefined value
  valueText       String?  @map("value_text") // For TEXT/SELECT
  valueNumber     Decimal? @map("value_number") @db.Decimal(18, 6) // For NUMBER
  valueBoolean    Boolean? @map("value_boolean") // For BOOLEAN
  valueDate       DateTime? @map("value_date") // For DATE
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  product         Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  attribute       Attribute @relation(fields: [attributeId], references: [id])

  @@unique([productId, attributeId], map: "product_attr_unique")
  @@map("product_attributes")
  @@index([productId], map: "idx_pa_product")
  @@index([attributeId], map: "idx_pa_attribute")
}

// ─── Product Variants (Epic 6) ────────────────────────────────
model ProductVariant {
  id              String   @id @default(uuid()) @db.Uuid
  productId       String   @db.Uuid @map("product_id")
  variantCode     String   @unique @map("variant_code") // e.g., KAJU-KATLI-250G
  variantName     String   @map("variant_name") // e.g., "Kaju Katli 250g"
  variantSku      String   @unique @map("variant_sku")
  variantBarcode  String?  @map("variant_barcode")
  // ─── Variant-specific attributes ────────────────────────
  variantAttributes Json    @default("{}") @map("variant_attributes") // { "WEIGHT": "250g", "PACKAGING": "Box" }
  // ─── Variant-specific pricing ───────────────────────────
  costPrice       Decimal? @map("cost_price") @db.Decimal(18, 4)
  mrp             Decimal? @db.Decimal(18, 4)
  sellingPrice    Decimal? @map("selling_price") @db.Decimal(18, 4)
  currencyCode    String   @default("INR") @map("currency_code") @db.Char(3)
  // ─── Variant-specific physical ──────────────────────────
  netWeight       Decimal? @map("net_weight") @db.Decimal(15, 3)
  grossWeight     Decimal? @map("gross_weight") @db.Decimal(15, 3)
  // ─── Status ─────────────────────────────────────────────
  isDefault       Boolean  @default(false) @map("is_default")
  status          String   @default("ACTIVE")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_variants")
  @@index([productId, status], map: "idx_pv_product_status")
  @@index([variantSku], map: "idx_pv_sku")
}

// ─── Product Images (Epic 7) ──────────────────────────────────
model ProductImage {
  id              String   @id @default(uuid()) @db.Uuid
  productId       String   @db.Uuid @map("product_id")
  variantId       String?  @db.Uuid @map("variant_id") // Optional: variant-specific image
  imageUrl        String   @map("image_url")
  thumbnailUrl    String?  @map("thumbnail_url")
  imageType       String   @default("GALLERY") @map("image_type") // PRIMARY, GALLERY, THUMBNAIL, QR_PREVIEW, BARCODE_PREVIEW
  displayOrder    Int      @default(100) @map("display_order")
  altText         String?  @map("alt_text")
  fileSizeBytes   Int?     @map("file_size_bytes")
  widthPx         Int?     @map("width_px")
  heightPx        Int?     @map("height_px")
  mimeType        String?  @map("mime_type")
  isPrimary       Boolean  @default(false) @map("is_primary")
  uploadedAt      DateTime @default(now()) @map("uploaded_at")
  uploadedBy      String?  @db.Uuid @map("uploaded_by")

  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_images")
  @@index([productId, imageType, displayOrder], map: "idx_pimg_product_type_order")
  @@index([variantId], map: "idx_pimg_variant")
}

// ─── Product Documents (Epic 8) ───────────────────────────────
model ProductDocument {
  id              String   @id @default(uuid()) @db.Uuid
  productId       String   @db.Uuid @map("product_id")
  documentName    String   @map("document_name")
  documentType    String   @default("SPECIFICATION") @map("document_type") // SPECIFICATION, FSSAI, LAB_REPORT, RECIPE, WARRANTY, CERTIFICATE, COA, MSDS
  fileUrl         String   @map("file_url")
  fileSizeBytes   Int?     @map("file_size_bytes")
  mimeType        String?  @map("mime_type")
  version         String   @default("1.0")
  isVerified      Boolean  @default(false) @map("is_verified")
  verifiedBy      String?  @db.Uuid @map("verified_by")
  verifiedAt      DateTime? @map("verified_at")
  expiryDate      DateTime? @map("expiry_date")
  uploadedAt      DateTime @default(now()) @map("uploaded_at")
  uploadedBy      String?  @db.Uuid @map("uploaded_by")

  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_documents")
  @@index([productId, documentType], map: "idx_pdoc_product_type")
  @@index([documentType, status], map: "idx_pdoc_type")
}

// ═══════════════════════════════════════════════════════════════
// PIM (Product Information Management) — Sprint 7
// Epics 1-9: Families, Groups, Collections, Templates,
//            Specifications, Compliance, Translations,
//            Versioning, Approval Workflow
// + Product Usage Matrix (Chief Architect)
// ═══════════════════════════════════════════════════════════════

// ─── Product Families (Epic 1) ────────────────────────────────
model ProductFamily {
  id              String   @id @default(uuid()) @db.Uuid
  familyCode      String   @unique @map("family_code")
  familyName      String   @map("family_name")
  description     String?
  displayOrder    Int      @default(100) @map("display_order")
  status          String   @default("ACTIVE")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  productMappings ProductFamilyMapping[]

  @@map("product_families")
  @@index([status], map: "idx_pf_status")
}

model ProductFamilyMapping {
  id              String   @id @default(uuid()) @db.Uuid
  productId       String   @db.Uuid @map("product_id")
  familyId        String   @db.Uuid @map("family_id")
  isPrimary       Boolean  @default(false) @map("is_primary")
  createdAt       DateTime @default(now()) @map("created_at")

  @@unique([productId, familyId], map: "pfm_unique")
  @@map("product_family_mappings")
  @@index([familyId], map: "idx_pfm_family")
  @@index([productId], map: "idx_pfm_product")
}

// ─── Product Groups (Epic 2 — Unlimited Hierarchy) ────────────
model ProductGroup {
  id              String   @id @default(uuid()) @db.Uuid
  groupCode       String   @unique @map("group_code")
  groupName       String   @map("group_name")
  parentGroupId   String?  @db.Uuid @map("parent_group_id")
  description     String?
  level           Int      @default(1)
  path            String   @default("/")
  displayOrder    Int      @default(100) @map("display_order")
  status          String   @default("ACTIVE")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  parent          ProductGroup?  @relation("GroupHierarchy", fields: [parentGroupId], references: [id])
  children        ProductGroup[] @relation("GroupHierarchy")
  productMappings ProductGroupMapping[]

  @@map("product_groups")
  @@index([parentGroupId, displayOrder], map: "idx_pg_parent_order")
  @@index([status], map: "idx_pg_status")
}

model ProductGroupMapping {
  id              String   @id @default(uuid()) @db.Uuid
  productId       String   @db.Uuid @map("product_id")
  groupId         String   @db.Uuid @map("group_id")
  isPrimary       Boolean  @default(false) @map("is_primary")
  createdAt       DateTime @default(now()) @map("created_at")

  @@unique([productId, groupId], map: "pgm_unique")
  @@map("product_group_mappings")
  @@index([groupId], map: "idx_pgm_group")
  @@index([productId], map: "idx_pgm_product")
}

// ─── Product Collections (Epic 3) ─────────────────────────────
model ProductCollection {
  id              String   @id @default(uuid()) @db.Uuid
  collectionCode  String   @unique @map("collection_code")
  collectionName  String   @map("collection_name")
  description     String?
  collectionType  String   @default("MARKETING") @map("collection_type") // MARKETING, SEASONAL, FESTIVAL, CORPORATE, EXPORT
  startDate       DateTime? @map("start_date")
  endDate         DateTime? @map("end_date")
  imageUrl        String?  @map("image_url")
  status          String   @default("ACTIVE")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  items           ProductCollectionItem[]

  @@map("product_collections")
  @@index([collectionType, status], map: "idx_pcol_type_status")
  @@index([status, startDate, endDate], map: "idx_pcol_dates")
}

model ProductCollectionItem {
  id              String   @id @default(uuid()) @db.Uuid
  collectionId    String   @db.Uuid @map("collection_id")
  productId       String   @db.Uuid @map("product_id")
  displayOrder    Int      @default(100) @map("display_order")
  isFeatured      Boolean  @default(false) @map("is_featured")
  addedAt         DateTime @default(now()) @map("added_at")

  @@unique([collectionId, productId], map: "pci_unique")
  @@map("product_collection_items")
  @@index([collectionId, displayOrder], map: "idx_pci_collection_order")
}

// ─── Product Templates (Epic 4) ───────────────────────────────
model ProductTemplate {
  id              String   @id @default(uuid()) @db.Uuid
  templateCode    String   @unique @map("template_code")
  templateName    String   @map("template_name")
  description     String?
  // ─── Default values applied when creating product from template ───
  defaultProductType  String? @map("default_product_type")
  defaultCategoryId   String?  @db.Uuid @map("default_category_id")
  defaultBrandId      String?  @db.Uuid @map("default_brand_id")
  defaultUomId        String?  @db.Uuid @map("default_uom_id")
  defaultTaxGroupId   String?  @db.Uuid @map("default_tax_group_id")
  defaultHsnCode      String?  @map("default_hsn_code")
  defaultShelfLifeDays Int?   @map("default_shelf_life_days")
  defaultTrackBatch   Boolean? @map("default_track_batch")
  defaultTrackExpiry  Boolean? @map("default_track_expiry")
  defaultBarcodeType  String?  @map("default_barcode_type")
  // ─── Template attributes (JSON of attribute defaults) ───
  defaultAttributes   Json     @default("{}") @map("default_attributes")
  // ─── Usage matrix defaults ───
  defaultIsManufactured Boolean @default(false) @map("default_is_manufactured")
  defaultIsPurchased    Boolean @default(false) @map("default_is_purchased")
  defaultIsSold         Boolean @default(true)  @map("default_is_sold")
  defaultIsStockManaged Boolean @default(true)  @map("default_is_stock_managed")
  defaultIsKitchenItem  Boolean @default(false) @map("default_is_kitchen_item")
  // ─── Specification defaults ───
  defaultSpecs         Json     @default("{}") @map("default_specs")
  // ─── Compliance defaults ───
  defaultCompliance    Json     @default("{}") @map("default_compliance")
  // ─── Status ───
  status              String   @default("ACTIVE")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("product_templates")
  @@index([status], map: "idx_pt_status")
}

// ─── Product Specifications (Epic 5) ──────────────────────────
model ProductSpecification {
  id              String   @id @default(uuid()) @db.Uuid
  productId       String   @db.Uuid @map("product_id")
  // ─── Ingredients ───
  ingredients     Json     @default("[]") // [{ name: "Cashew", percentage: 45 }, { name: "Sugar", percentage: 40 }, ...]
  allergens       String[] @default([]) // CASHEW, MILK, GLUTEN, SOY, PEANUT, TREE_NUT, EGG, FISH, SHELLFISH, SESAME
  // ─── Nutritional values (per 100g) ───
  energyKcal      Decimal? @map("energy_kcal") @db.Decimal(8, 2)
  proteinG        Decimal? @map("protein_g") @db.Decimal(8, 2)
  fatG            Decimal? @map("fat_g") @db.Decimal(8, 2)
  carbsG          Decimal? @map("carbs_g") @db.Decimal(8, 2)
  sugarG          Decimal? @map("sugar_g") @db.Decimal(8, 2)
  sodiumMg        Decimal? @map("sodium_mg") @db.Decimal(8, 2)
  // ─── Storage & shelf life ───
  shelfLifeDays   Int?     @map("shelf_life_days")
  storageConditions String? @map("storage_conditions") // "Cool & Dry Place", "Refrigerate at 2-4°C"
  storageTempMin  Decimal? @map("storage_temp_min") @db.Decimal(5, 2)
  storageTempMax  Decimal? @map("storage_temp_max") @db.Decimal(5, 2)
  // ─── Manufacturing & packaging ───
  manufacturingNotes String? @map("manufacturing_notes")
  packagingInstructions String? @map("packaging_instructions")
  // ─── Additional specs ───
  additionalSpecs Json     @default("{}") @map("additional_specs")
  // ─── Audit ───
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("product_specifications")
  @@index([productId], map: "idx_pspec_product")
}

// ─── Product Compliance (Epic 6) ──────────────────────────────
model ProductCompliance {
  id              String   @id @default(uuid()) @db.Uuid
  productId       String   @db.Uuid @map("product_id")
  complianceType  String   @map("compliance_type") // FSSAI, AGMARK, ISO, HACCP, EXPORT, FDA
  certificateNumber String? @map("certificate_number")
  licenseNumber   String?  @map("license_number")
  issuingAuthority String? @map("issuing_authority")
  issuedDate      DateTime? @map("issued_date")
  expiryDate      DateTime? @map("expiry_date")
  status          String   @default("PENDING") // PENDING, APPROVED, EXPIRED, REJECTED
  documentUrl     String?  @map("document_url")
  verifiedBy      String?  @db.Uuid @map("verified_by")
  verifiedAt      DateTime? @map("verified_at")
  notes           String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("product_compliance")
  @@index([productId, complianceType], map: "idx_pcomp_product_type")
  @@index([complianceType, status], map: "idx_pcomp_type_status")
  @@index([expiryDate], map: "idx_pcomp_expiry")
}

// ─── Multi-Language Product Translations (Epic 7) ─────────────
model ProductTranslation {
  id              String   @id @default(uuid()) @db.Uuid
  productId       String   @db.Uuid @map("product_id")
  languageCode    String   @map("language_code") @db.VarChar(10) // en, hi, mr, gu, ta, kn, te
  name            String
  shortName       String?  @map("short_name")
  description     String?
  ingredients     String?  // Translated ingredients list
  instructions    String?  // Usage/storage instructions
  warnings        String?  // Allergen warnings
  isVerified      Boolean  @default(false) @map("is_verified")
  verifiedBy      String?  @db.Uuid @map("verified_by")
  verifiedAt      DateTime? @map("verified_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([productId, languageCode], map: "pt_unique")
  @@map("product_translations")
  @@index([productId], map: "idx_pt_product")
  @@index([languageCode], map: "idx_pt_lang")
}

// ─── Product Versioning (Epic 8) ──────────────────────────────
model ProductVersion {
  id              String   @id @default(uuid()) @db.Uuid
  productId       String   @db.Uuid @map("product_id")
  versionNumber   Int      @map("version_number")
  changeType      String   @map("change_type") // CREATE, UPDATE, STATUS_CHANGE, PRICE_CHANGE, COMPLIANCE_UPDATE, SPEC_UPDATE
  changeSummary   String   @map("change_summary")
  changeReason    String?  @map("change_reason")
  // ─── Snapshot of product data at this version ───
  snapshot        Json     @default("{}") // Full product JSON snapshot
  // ─── Editor info ───
  editedBy        String   @db.Uuid @map("edited_by")
  editedAt        DateTime @default(now()) @map("edited_at")
  // ─── Approval ───
  approvalStatus  String   @default("PENDING") // PENDING, APPROVED, REJECTED
  approvedBy      String?  @db.Uuid @map("approved_by")
  approvedAt      DateTime? @map("approved_at")
  // ─── Rollback ───
  isCurrent       Boolean  @default(false) @map("is_current")
  rolledBackFrom  Int?     @map("rolled_back_from") // Version number this was rolled back from

  @@map("product_versions")
  @@index([productId, versionNumber], map: "idx_pv_product_version")
  @@index([productId, isCurrent], map: "idx_pv_product_current")
  @@index([approvalStatus], map: "idx_pv_approval")
}

// ─── Product Approval Workflow (Epic 9) ───────────────────────
model ProductApprovalRequest {
  id              String   @id @default(uuid()) @db.Uuid
  productId       String   @db.Uuid @map("product_id")
  requestNumber   String   @unique @map("request_number")
  // ─── Workflow stages ───
  currentStage    String   @default("DRAFT") @map("current_stage") // DRAFT, QA_REVIEW, COMPLIANCE_REVIEW, FINANCE_REVIEW, APPROVED, PUBLISHED, REJECTED
  // ─── Submitter ───
  submittedBy     String   @db.Uuid @map("submitted_by")
  submittedAt     DateTime @default(now()) @map("submitted_at")
  // ─── Reviewers ───
  qaReviewerId    String?  @db.Uuid @map("qa_reviewer_id")
  qaReviewedAt    DateTime? @map("qa_reviewed_at")
  qaDecision      String?  @map("qa_decision") // APPROVED, REJECTED, CHANGES_REQUESTED
  qaNotes         String?  @map("qa_notes")
  complianceReviewerId String? @db.Uuid @map("compliance_reviewer_id")
  complianceReviewedAt DateTime? @map("compliance_reviewed_at")
  complianceDecision String? @map("compliance_decision")
  complianceNotes  String? @map("compliance_notes")
  financeReviewerId String? @db.Uuid @map("finance_reviewer_id")
  financeReviewedAt DateTime? @map("finance_reviewed_at")
  financeDecision  String? @map("finance_decision")
  financeNotes     String? @map("finance_notes")
  // ─── Final approval ───
  approvedBy      String?  @db.Uuid @map("approved_by")
  approvedAt      DateTime? @map("approved_at")
  // ─── Publishing ───
  publishedBy     String?  @db.Uuid @map("published_by")
  publishedAt     DateTime? @map("published_at")
  // ─── Rejection ───
  rejectedBy      String?  @db.Uuid @map("rejected_by")
  rejectedAt      DateTime? @map("rejected_at")
  rejectionReason String?  @map("rejection_reason")
  // ─── SLA ───
  slaDueAt        DateTime @map("sla_due_at")
  slaBreached     Boolean  @default(false) @map("sla_breached")
  // ─── Status ───
  status          String   @default("PENDING") // PENDING, IN_REVIEW, APPROVED, PUBLISHED, REJECTED, CANCELLED
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("product_approval_requests")
  @@index([productId, status], map: "idx_par_product_status")
  @@index([currentStage, status], map: "idx_par_stage_status")
  @@index([submittedBy, status], map: "idx_par_submitter")
  @@index([slaDueAt, slaBreached], map: "idx_par_sla")
}

// ─── Product Usage Matrix (Chief Architect Recommendation) ────
model ProductUsageMatrix {
  id              String   @id @default(uuid()) @db.Uuid
  productId       String   @db.Uuid @map("product_id")
  // ─── Channel flags ───
  useInManufacturing Boolean @default(false) @map("use_in_manufacturing")
  useInWarehouse     Boolean @default(false) @map("use_in_warehouse")
  useInRetailPos     Boolean @default(false) @map("use_in_retail_pos")
  useInRestaurantPos Boolean @default(false) @map("use_in_restaurant_pos")
  useInEcommerce     Boolean @default(false) @map("use_in_ecommerce")
  useInProcurement   Boolean @default(false) @map("use_in_procurement")
  useInFinance       Boolean @default(false) @map("use_in_finance")
  // ─── Additional metadata ───
  manufacturingRole  String? @map("manufacturing_role") // PRODUCTION_ITEM, BOM_COMPONENT
  warehouseRole      String? @map("warehouse_role") // STOCK_ITEM, CONSUMABLE
  retailRole         String? @map("retail_role") // BILLING_ITEM, NON_STOCK
  restaurantRole     String? @map("restaurant_role") // INGREDIENT, MENU_ITEM
  ecommerceRole      String? @map("ecommerce_role") // LISTED, UNLISTED
  // ─── Audit ───
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("product_usage_matrix")
  @@index([productId], map: "idx_pum_product")
  @@index([useInManufacturing], map: "idx_pum_mfg")
  @@index([useInRetailPos], map: "idx_pum_retail")
  @@index([useInRestaurantPos], map: "idx_pum_restaurant")
}
