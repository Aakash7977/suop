// ═══════════════════════════════════════════════════════════
// SPRINT 14 — STOCK ISSUE, MATERIAL CONSUMPTION & OUTBOUND
// Every movement where inventory leaves stock
// ═══════════════════════════════════════════════════════════

// ─── Epic 1: Stock Issue Document ───────────────────────
model StockIssue {
  id              String   @id @default(uuid()) @db.Uuid
  issueNumber     String   @unique @map("issue_number")
  // ─── Dates ───
  issueDate       DateTime @map("issue_date")
  issuedAt        DateTime @default(now()) @map("issued_at")
  // ─── Issue type ───
  issueType       String   @map("issue_type") // PRODUCTION_ISSUE, KITCHEN_ISSUE, SALES_ISSUE, SAMPLE_ISSUE, DAMAGE_ISSUE, SCRAP_ISSUE, INTERNAL_CONSUMPTION, MAINTENANCE_ISSUE, TRANSFER_ISSUE, RETURN_TO_SUPPLIER, ADJUSTMENT_ISSUE
  // ─── Reference ───
  referenceType   String?  @map("reference_type") // PRODUCTION_ORDER, SALES_ORDER, SALES_INVOICE, MATERIAL_REQUISITION, MAINTENANCE_ORDER, PURCHASE_RETURN
  referenceNumber String?  @map("reference_number")
  // ─── Scope ───
  companyId       String?  @db.Uuid @map("company_id")
  branchId        String?  @db.Uuid @map("branch_id")
  warehouseId     String?  @db.Uuid @map("warehouse_id")
  warehouseName   String?  @map("warehouse_name")
  // ─── Requester / Approver ───
  requestedById   String?  @db.Uuid @map("requested_by_id")
  requestedByName String?  @map("requested_by_name")
  approvedById    String?  @db.Uuid @map("approved_by_id")
  approvedByName  String?  @map("approved_by_name")
  approvedAt      DateTime? @map("approved_at")
  // ─── Destination ───
  destinationType String?  @map("destination_type") // PRODUCTION_LINE, KITCHEN, CUSTOMER, SUPPLIER, DEPARTMENT, WAREHOUSE
  destinationName String?  @map("destination_name")
  // ─── Status ───
  status          String   @default("DRAFT") // DRAFT, PENDING_APPROVAL, APPROVED, PICKING_IN_PROGRESS, ISSUED, PARTIALLY_ISSUED, REJECTED, CANCELLED
  rejectionReason String?  @map("rejection_reason")
  // ─── Summary ───
  totalLines      Int      @default(0) @map("total_lines")
  totalRequestedQty Decimal @db.Decimal(18, 4) @default(0) @map("total_requested_qty")
  totalIssuedQty  Decimal  @db.Decimal(18, 4) @default(0) @map("total_issued_qty")
  totalValue      Decimal  @db.Decimal(18, 2) @default(0) @map("total_value")
  // ─── Inventory posting ───
  inventoryPosted Boolean  @default(false) @map("inventory_posted")
  inventoryTransactionId String? @db.Uuid @map("inventory_transaction_id")
  postedAt        DateTime? @map("posted_at")
  // ─── Picking ───
  pickingRequired Boolean  @default(true) @map("picking_required")
  pickingCompleted Boolean @default(false) @map("picking_completed")
  pickingCompletedAt DateTime? @map("picking_completed_at")
  // ─── Remarks ───
  remarks         String?
  // ─── Audit ───
  issuedById      String?  @db.Uuid @map("issued_by_id")
  issuedByName    String?  @map("issued_by_name")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  lines           StockIssueLine[]
  pickingTasks    PickingTask[]

  @@map("stock_issues")
  @@index([issueType, status], map: "idx_si_type_status")
  @@index([warehouseId, issueDate], map: "idx_si_warehouse_date")
  @@index([referenceType, referenceNumber], map: "idx_si_reference")
  @@index([status, issueDate], map: "idx_si_status_date")
  @@index([requestedById], map: "idx_si_requester")
}

model StockIssueLine {
  id              String   @id @default(uuid()) @db.Uuid
  stockIssueId    String   @db.Uuid @map("stock_issue_id")
  lineOrder       Int      @map("line_order")
  // ─── Item ───
  productId       String   @db.Uuid @map("product_id")
  productName     String   @map("product_name")
  productVariantId String? @db.Uuid @map("product_variant_id")
  uomId           String?  @db.Uuid @map("uom_id")
  uomName         String?  @map("uom_name")
  // ─── Batch/Lot/Serial ───
  batchId         String?  @db.Uuid @map("batch_id")
  batchNumber     String?  @map("batch_number")
  lotId           String?  @db.Uuid @map("lot_id")
  serialNumberId  String?  @db.Uuid @map("serial_number_id")
