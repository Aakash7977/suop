  copies              Int      @default(1)
  // ─── Performance ───
  printDurationMs     Int?     @map("print_duration_ms")
  withinTarget        Boolean  @default(true) @map("within_target")
  // ─── Status ───
  status              String   @default("QUEUED") @map("status") // QUEUED, PRINTING, COMPLETED, FAILED, CANCELLED
  printStartedAt      DateTime? @map("print_started_at")
  printCompletedAt    DateTime? @map("print_completed_at")
  errorMessage        String?  @map("error_message")
  // ─── Audit ───
  createdAt           DateTime @default(now()) @map("created_at")

  packagingOrder      PackagingOrder @relation(fields: [packagingOrderId], references: [id], onDelete: Cascade)

  @@map("packaging_label_jobs")
  @@index([packagingOrderId], map: "idx_plj41_order")
  @@index([labelType, status], map: "idx_plj41_type_status")
  @@index([batchNumber], map: "idx_plj41_batch")
}

// ─── Epic 6: Packaging Quality Checks ───────────────────────────────────
model PackagingQualityCheck {
  id                  String   @id @default(uuid()) @db.Uuid
  checkCode           String   @unique @map("check_code") // PKG-QC-000001
  // ─── Links ───
  packagingOrderId    String   @db.Uuid @map("packaging_order_id")
  packagingOrderNumber String   @map("packaging_order_number")
  batchNumber         String   @map("batch_number")
  packageId           String?  @db.Uuid @map("package_id")
  packageNumber       String?  @map("package_number")
  // ─── Check ───
  checkType           String   @map("check_type") // SEAL_QUALITY, WEIGHT, BARCODE_READABILITY, LABEL_ACCURACY, PRINT_QUALITY, PACKAGE_DAMAGE, MRP_ACCURACY, DATE_PRINTING
  // ─── Results ───
  measuredValue       String?  @map("measured_value")
  targetValue         String?  @map("target_value")
  result              String   @default("PASS") @map("result") // PASS, FAIL, REWORK, HOLD
  remarks             String?
  // ─── Actor ───
  checkedById         String?  @db.Uuid @map("checked_by_id")
  checkedByName       String?  @map("checked_by_name")
  // ─── Audit ───
  checkedAt           DateTime @default(now()) @map("checked_at")
  createdAt           DateTime @default(now()) @map("created_at")

  packagingOrder      PackagingOrder @relation(fields: [packagingOrderId], references: [id], onDelete: Cascade)

  @@map("packaging_quality_checks")
  @@index([packagingOrderId], map: "idx_pqc41_order")
  @@index([checkType, result], map: "idx_pqc41_type_result")
  @@index([batchNumber], map: "idx_pqc41_batch")
}

// ─── Epic 5,8: Finished Goods + Warehouse Handover ──────────────────────
model FinishedGoodsConfirmation {
  id                  String   @id @default(uuid()) @db.Uuid
  fgConfirmationCode  String   @unique @map("fg_confirmation_code") // FG-2026-000001
  // ─── Source ───
  packagingOrderId    String?  @db.Uuid @map("packaging_order_id")
  packagingOrderNumber String?  @map("packaging_order_number")
  productionBatchNumber String  @map("production_batch_number")
  // ─── Product ───
  productId           String?  @db.Uuid @map("product_id")
  productSku          String   @map("product_sku")
  productName         String   @map("product_name")
  // ─── Quantity ───
  fgQuantity          Decimal  @db.Decimal(18, 4) @map("fg_quantity")
  uom                 String   @default("PCS") @map("uom")
  // ─── Hierarchy Summary ───
  unitsCount          Int      @default(0) @map("units_count")
  boxesCount          Int      @default(0) @map("boxes_count")
  cartonsCount        Int      @default(0) @map("cartons_count")
  palletsCount        Int      @default(0) @map("pallets_count")
