// ─── Epic 8: Offline Sync Queue & History ──────────────────────────────
model ProductionOfflineQueue {
  id                  String   @id @default(uuid()) @db.Uuid
  transactionCode     String   @unique @map("transaction_code")
  // ─── Device & Operator ───
  deviceId            String   @db.Uuid @map("device_id")
  deviceCode          String   @map("device_code")
  operatorId          String   @db.Uuid @map("operator_id")
  operatorCode        String   @map("operator_code")
  operatorName        String   @map("operator_name")
  // ─── Transaction ───
  transactionType     String   @map("transaction_type") // MATERIAL_ISSUE, WO_START, WO_PAUSE, WO_RESUME, WO_COMPLETE, BATCH_CREATE, LABEL_PRINT, QC_CHECK, WIP_TRANSFER, FG_CONFIRM
  // ─── Payload ───
  payload             String   @map("payload") // JSON encrypted payload
  signature           String   @map("signature") // HMAC signature for integrity
  // ─── References ───
  workOrderId         String?  @db.Uuid @map("work_order_id")
  workOrderNumber     String?  @map("work_order_number")
  batchId             String?  @db.Uuid @map("batch_id")
  batchNumber         String?  @map("batch_number")
  // ─── Sync ───
  status              String   @default("PENDING_SYNC") @map("status") // PENDING_SYNC, SYNCING, SYNCED, CONFLICT, FAILED, EXPIRED
  attemptCount        Int      @default(0) @map("attempt_count")
  maxAttempts         Int      @default(5) @map("max_attempts")
  lastAttemptAt       DateTime? @map("last_attempt_at")
  syncedAt            DateTime? @map("synced_at")
  // ─── Conflict ───
  conflictReason      String?  @map("conflict_reason")
  conflictResolution  String?  @map("conflict_resolution") // SERVER_WINS, CLIENT_WINS, MANUAL, MERGED
  // ─── Time ───
  offlineCreatedAt    DateTime @default(now()) @map("offline_created_at")
  expiresAt           DateTime @map("expires_at") // offline transactions expire after 7 days
  // ─── Audit ───
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("production_offline_queue")
  @@index([deviceId, status], map: "idx_poq_device_status")
  @@index([status, offlineCreatedAt], map: "idx_poq_status_time")
  @@index([operatorId], map: "idx_poq_operator")
  @@index([expiresAt], map: "idx_poq_expires")
}

