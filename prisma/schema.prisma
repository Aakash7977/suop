  pickedQty       Decimal  @db.Decimal(18, 4) @default(0) @map("picked_qty")
  // ─── Reason ───
  reason          String?
  // ─── Remarks ───
  remarks         String?
  createdAt       DateTime @default(now()) @map("created_at")

  stockIssue      StockIssue @relation(fields: [stockIssueId], references: [id], onDelete: Cascade)

  @@map("stock_issue_lines")
  @@index([stockIssueId, lineOrder], map: "idx_sil_si_order")
  @@index([productId, batchId], map: "idx_sil_product_batch")
  @@index([pickingStatus], map: "idx_sil_picking")
}

// ─── Epic 4: Picking Tasks ─────────────────────────────
model PickingTask {
  id              String   @id @default(uuid()) @db.Uuid
  taskNumber      String   @unique @map("task_number")
  stockIssueId    String?  @db.Uuid @map("stock_issue_id")
  issueNumber     String?  @map("issue_number")
  // ─── Strategy ───
  pickingStrategy String   @map("picking_strategy") // FIFO, FEFO, NEAREST_BIN, WAVE, ZONE, PRIORITY
  // ─── Scope ───
  warehouseId     String?  @db.Uuid @map("warehouse_id")
  warehouseName   String?  @map("warehouse_name")
  zone            String?
  // ─── Assignment ───
  assignedToId    String?  @db.Uuid @map("assigned_to_id")
  assignedToName  String?  @map("assigned_to_name")
  assignedAt      DateTime? @map("assigned_at")
  // ─── Status ───
  status          String   @default("PENDING") // PENDING, ASSIGNED, IN_PROGRESS, COMPLETED, PARTIALLY_COMPLETED, CANCELLED
  // ─── Summary ───
  totalLines      Int      @default(0) @map("total_lines")
  pickedLines     Int      @default(0) @map("picked_lines")
  totalQty        Decimal  @db.Decimal(18, 4) @default(0) @map("total_qty")
  pickedQty       Decimal  @db.Decimal(18, 4) @default(0) @map("picked_qty")
  // ─── Timing ───
  startedAt       DateTime? @map("started_at")
  completedAt     DateTime? @map("completed_at")
  durationMinutes Int?     @map("duration_minutes")
  // ─── Audit ───
  createdById     String?  @db.Uuid @map("created_by_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  stockIssue      StockIssue? @relation(fields: [stockIssueId], references: [id], onDelete: SetNull)
  lines           PickingTaskLine[]

  @@map("picking_tasks")
  @@index([stockIssueId], map: "idx_pickts_si")
  @@index([status, assignedToId], map: "idx_pickts_status_assignee")
  @@index([warehouseId, zone], map: "idx_pickts_warehouse_zone")
}

model PickingTaskLine {
  id              String   @id @default(uuid()) @db.Uuid
