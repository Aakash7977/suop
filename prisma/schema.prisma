  @@index([productId, batchId], map: "idx_stl_product_batch")
  @@index([receiptStatus], map: "idx_stl_receipt")
}

// ─── Epic 3: In-Transit Inventory ──────────────────────
model InventoryInTransit {
  id              String   @id @default(uuid()) @db.Uuid
  stockTransferId String?  @db.Uuid @map("stock_transfer_id")
  transferNumber  String?  @map("transfer_number")
