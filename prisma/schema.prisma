  productName     String   @map("product_name")
  batchId         String?  @db.Uuid @map("batch_id")
  batchNumber     String?  @map("batch_number")
  uomId           String?  @db.Uuid @map("uom_id")
  // ─── Quantity ───
  damagedQty      Decimal  @db.Decimal(18, 4) @map("damaged_qty")
  // ─── Cost ───
  unitCost        Decimal? @db.Decimal(18, 4) @map("unit_cost")
  totalDamageValue Decimal @db.Decimal(18, 2) @default(0) @map("total_damage_value")
  // ─── Scope ───
  warehouseId     String?  @db.Uuid @map("warehouse_id")
  warehouseName   String?  @map("warehouse_name")
  // ─── Evidence ───
  photoUrls       String[] @default([]) @map("photo_urls")
  photoCount      Int      @default(0) @map("photo_count")
  // ─── Disposition ───
  disposition     String   @default("PENDING_REVIEW") @map("disposition") // PENDING_REVIEW, SCRAP, REPAIRABLE, DONATE, RETURN_TO_SUPPLIER, WRITE_OFF, REPACK
  // ─── Status ───
  status          String   @default("REPORTED") // REPORTED, UNDER_REVIEW, APPROVED, POSTED, DISPOSED, CANCELLED
  // ─── Approval ───
