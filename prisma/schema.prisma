// ─── Epic 1: Dispatch Order Management ─────────────────
model DispatchOrder {
  id              String   @id @default(uuid()) @db.Uuid
  dispatchNumber  String   @unique @map("dispatch_number")
  dispatchDate    DateTime @map("dispatch_date")
  // ─── Type ───
  dispatchType    String   @map("dispatch_type") // RETAIL_DISPATCH, DISTRIBUTOR_DISPATCH, RESTAURANT_REPLENISHMENT, BRANCH_TRANSFER, EXPORT_SHIPMENT, COURIER_SHIPMENT, DIRECT_DELIVERY, CUSTOMER_PICKUP, VENDOR_RETURN
  // ─── Scope ───
  warehouseId     String   @db.Uuid @map("warehouse_id")
  warehouseName   String   @map("warehouse_name")
  // ─── Partner ───
  partnerId       String?  @db.Uuid @map("partner_id")
  partnerName     String?  @map("partner_name")
  // ─── Reference ───
  referenceType   String?  @map("reference_type") // SALES_ORDER, TRANSFER_ORDER, PICKING_TASK
  referenceNumber String?  @map("reference_number")
  // ─── Vehicle ───
  vehicleId       String?  @db.Uuid @map("vehicle_id")
  vehicleNumber   String?  @map("vehicle_number")
  driverName      String?  @map("driver_name")
  driverPhone     String?  @map("driver_phone")
  carrierName     String?  @map("carrier_name")
  // ─── Route ───
  routeId         String?  @db.Uuid @map("route_id")
  routeName       String?  @map("route_name")
  deliverySequence Int?    @map("delivery_sequence")
  // ─── Priority ───
  priority        String   @default("NORMAL") // EMERGENCY, HIGH, NORMAL, LOW
  // ─── Status ───
  status          String   @default("PLANNED") // PLANNED, VEHICLE_ASSIGNED, LOADING, LOADED, SEALED, GATE_EXIT, DISPATCHED, DELIVERED, CANCELLED, EXCEPTION
  // ─── Summary ───
  totalOrders     Int      @default(0) @map("total_orders")
  totalLines      Int      @default(0) @map("total_lines")
  totalCartons    Int      @default(0) @map("total_cartons")
  totalPallets    Int?     @map("total_pallets")
  totalQty        Decimal  @db.Decimal(18, 4) @default(0) @map("total_qty")
  totalWeightKg   Decimal  @db.Decimal(12, 2) @default(0) @map("total_weight_kg")
  totalVolumeM3   Decimal  @db.Decimal(12, 2) @default(0) @map("total_volume_m3")
  // ─── Timing ───
  plannedDispatchAt DateTime? @map("planned_dispatch_at")
  loadingStartedAt DateTime? @map("loading_started_at")
  loadingCompletedAt DateTime? @map("loading_completed_at")
  sealedAt        DateTime? @map("sealed_at")
  gateExitAt      DateTime? @map("gate_exit_at")
  dispatchedAt    DateTime? @map("dispatched_at")
  loadingDurationMin Int?  @map("loading_duration_min")
  // ─── Audit ───
  createdById     String?  @db.Uuid @map("created_by_id")
  createdByName   String?  @map("created_by_name")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  lines           DispatchOrderLine[]
  loadPlan        LoadPlan?
  shippingDocs    ShippingDocument[]
  vehicleSeal     VehicleSeal?
  gateExitLog     GateExitLog?

  @@map("dispatch_orders")
  @@index([dispatchType, status], map: "idx_do_type_status")
  @@index([warehouseId, status], map: "idx_do_wh_status")
  @@index([vehicleId], map: "idx_do_vehicle")
  @@index([status, dispatchDate], map: "idx_do_status_date")
}

model DispatchOrderLine {
