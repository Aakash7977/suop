// ─── Epic 8: Root Cause Analysis ────────────────────────
model AdjustmentRootCause {
  id              String   @id @default(uuid()) @db.Uuid
  adjustmentId    String?  @db.Uuid @map("adjustment_id")
  adjustmentNumber String?  @map("adjustment_number")
  // ─── Category ───
  rootCauseCategory String  @map("root_cause_category") // RECEIVING, STORAGE, PRODUCTION, PACKING, PICKING, DISPATCH, TRANSPORT, RETAIL, RESTAURANT, SYSTEM_ERROR, HUMAN_ERROR
  // ─── Details ───
  rootCauseDetail String   @map("root_cause_detail")
  // ─── Impact ───
  affectedQty     Decimal  @db.Decimal(18, 4) @map("affected_qty")
  affectedValue   Decimal  @db.Decimal(18, 2) @default(0) @map("affected_value")
  // ─── Corrective action ───
  correctiveAction String?  @map("corrective_action")
  preventiveAction String?  @map("preventive_action")
  actionOwner     String?  @map("action_owner")
  actionDueDate   DateTime? @map("action_due_date")
  actionStatus    String   @default("OPEN") @map("action_status") // OPEN, IN_PROGRESS, COMPLETED, OVERDUE
  // ─── Recurrence ───
  isRecurring     Boolean  @default(false) @map("is_recurring")
  recurrenceCount Int      @default(0) @map("recurrence_count")
  // ─── Audit ───
  analyzedById    String?  @db.Uuid @map("analyzed_by_id")
  analyzedAt      DateTime @default(now()) @map("analyzed_at")
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("adjustment_root_causes")
  @@index([rootCauseCategory], map: "idx_arc_category")
  @@index([adjustmentId], map: "idx_arc_adjustment")
  @@index([actionStatus], map: "idx_arc_action_status")
  @@index([isRecurring], map: "idx_arc_recurring")
}

// ═══════════════════════════════════════════════════════════
// SPRINT 17 — STOCK RESERVATION & ALLOCATION ENGINE
// Lock inventory so departments don't compete for the same stock
// ═══════════════════════════════════════════════════════════

// ─── Epic 1: Reservation Engine ─────────────────────────
model InventoryReservation {
  id              String   @id @default(uuid()) @db.Uuid
  reservationNumber String  @unique @map("reservation_number")
  reservationDate DateTime @map("reservation_date")
  // ─── Type ───
  reservationType String   @map("reservation_type") // SALES_ORDER, PRODUCTION_ORDER, KITCHEN_ORDER, TRANSFER_ORDER, MAINTENANCE_ORDER, PROJECT_RESERVATION, SAMPLE_RESERVATION, QUALITY_RESERVATION, EMERGENCY_RESERVATION
  // ─── Priority ───
  priority        String   @default("NORMAL") // EMERGENCY, CRITICAL, HIGH, NORMAL, LOW
  priorityScore   Int      @default(50) @map("priority_score") // 0-100, higher = more important
  // ─── Scope ───
  warehouseId     String?  @db.Uuid @map("warehouse_id")
  warehouseName   String?  @map("warehouse_name")
  companyId       String?  @db.Uuid @map("company_id")
  branchId        String?  @db.Uuid @map("branch_id")
  // ─── Reference ───
  referenceType   String?  @map("reference_type")
  referenceNumber String?  @map("reference_number")
  // ─── Partner ───
  partnerId       String?  @db.Uuid @map("partner_id")
  partnerName     String?  @map("partner_name")
  // ─── Expiry ───
  expiryDate      DateTime? @map("expiry_date")
  autoReleaseAfter Int?    @map("auto_release_after") // hours
  // ─── Status ───
  status          String   @default("ACTIVE") // ACTIVE, PARTIALLY_ALLOCATED, FULLY_ALLOCATED, PARTIALLY_ISSUED, FULLY_ISSUED, RELEASED, EXPIRED, CANCELLED
  // ─── Summary ───
  totalLines      Int      @default(0) @map("total_lines")
  totalRequestedQty Decimal @db.Decimal(18, 4) @default(0) @map("total_requested_qty")
  totalReservedQty Decimal @db.Decimal(18, 4) @default(0) @map("total_reserved_qty")
  totalAllocatedQty Decimal @db.Decimal(18, 4) @default(0) @map("total_allocated_qty")
  totalIssuedQty  Decimal  @db.Decimal(18, 4) @default(0) @map("total_issued_qty")
  // ─── Workflow ───
  approvedById    String?  @db.Uuid @map("approved_by_id")
  approvedAt      DateTime? @map("approved_at")
  allocatedAt     DateTime? @map("allocated_at")
  releasedAt      DateTime? @map("released_at")
  releasedById    String?  @db.Uuid @map("released_by_id")
  releaseReason   String?  @map("release_reason")
  // ─── Remarks ───
  remarks         String?
  // ─── Audit ───
  requestedById   String?  @db.Uuid @map("requested_by_id")
