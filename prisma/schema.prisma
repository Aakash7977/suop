  // ─── Vehicle ───
  yardVehicleId       String   @db.Uuid @map("yard_vehicle_id")
  vehicleNumber       String   @map("vehicle_number")
  vehicleType         String   @map("vehicle_type")
  driverName          String   @map("driver_name")
  // ─── Queue ───
  queuePosition       Int      @map("queue_position")
  queueType           String   @default("FIFO") @map("queue_type") // FIFO, PRIORITY, COLD_CHAIN, EMERGENCY, VIP_SUPPLIER, MANUAL_OVERRIDE
  priorityScore       Int      @default(50) @map("priority_score") // 0-100
  priorityReason      String?  @map("priority_reason")
  // ─── Purpose ───
  visitPurpose        String   @map("visit_purpose")
  warehouseId         String   @db.Uuid @map("warehouse_id")
