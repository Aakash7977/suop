// ─── Epic 1: OEE Engine ─────────────────────────────────────────────────
model OEEResult {
  id                  String   @id @default(uuid()) @db.Uuid
  oeeCode             String   @unique @map("oee_code") // OEE-2026-000001
  // ─── Scope ───
  scopeType           String   @map("scope_type") // MACHINE, LINE, DEPARTMENT, PLANT, ENTERPRISE
  scopeId             String?  @db.Uuid @map("scope_id")
  scopeCode           String   @map("scope_code") // COOK-01, LINE-KK-01, THN
  scopeName           String   @map("scope_name")
  // ─── Period ───
  periodType          String   @map("period_type") // SHIFT, DAILY, WEEKLY, MONTHLY, QUARTERLY, ANNUAL
  periodStart         DateTime @map("period_start")
  periodEnd           DateTime @map("period_end")
  shiftCode           String?  @map("shift_code")
  // ─── Availability ───
  plannedTimeMin      Int      @map("planned_time_min")
  downtimeMin         Int      @default(0) @map("downtime_min")
  availableTimeMin    Int      @map("available_time_min")
  availabilityPercent Decimal  @db.Decimal(6, 2) @map("availability_percent")
  // ─── Performance ───
  idealCycleTimeSec   Decimal? @db.Decimal(10, 3) @map("ideal_cycle_time_sec")
  totalCycles         Int      @default(0) @map("total_cycles")
  actualOutput        Decimal  @db.Decimal(14, 3) @default(0) @map("actual_output")
  theoreticalOutput   Decimal  @db.Decimal(14, 3) @default(0) @map("theoretical_output")
  performancePercent  Decimal  @db.Decimal(6, 2) @map("performance_percent")
  // ─── Quality ───
  goodPieces          Decimal  @db.Decimal(14, 3) @default(0) @map("good_pieces")
  rejectedPieces      Decimal  @db.Decimal(14, 3) @default(0) @map("rejected_pieces")
  reworkedPieces      Decimal  @db.Decimal(14, 3) @default(0) @map("reworked_pieces")
  qualityPercent      Decimal  @db.Decimal(6, 2) @map("quality_percent")
  // ─── OEE ───
  oeePercent          Decimal  @db.Decimal(6, 2) @map("oee_percent")
  // ─── Comparison ───
  oeeTarget           Decimal  @db.Decimal(6, 2) @default(85.00) @map("oee_target")
  varianceFromTarget  Decimal  @db.Decimal(6, 2) @default(0) @map("variance_from_target")
  oeeStatus           String   @default("WITHIN_TARGET") @map("oee_status") // WITHIN_TARGET, BELOW_TARGET, CRITICAL
  // ─── Audit ───
  calculatedAt        DateTime @default(now()) @map("calculated_at")
  calculationDurationMs Int?   @map("calculation_duration_ms") // target <2000ms
  withinTarget        Boolean  @default(true) @map("within_target")
  createdAt           DateTime @default(now()) @map("created_at")

  @@map("oee_results")
  @@index([scopeType, scopeCode, periodStart], map: "idx_oee44_scope_period")
  @@index([periodType, periodStart], map: "idx_oee44_period")
  @@index([oeeStatus], map: "idx_oee44_status")
}

