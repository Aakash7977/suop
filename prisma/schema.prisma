  // ─── Dock Assignment ───
  assignedDockId      String?  @db.Uuid @map("assigned_dock_id")
  assignedDockCode    String?  @map("assigned_dock_code")
  // ─── Status ───
  status              String   @default("WAITING") // WAITING, PRIORITY_BOOSTED, ASSIGNED, DEQUEUED, SKIPPED, CANCELLED
  delayReason         String?  @map("delay_reason")
  // ─── Audit ───
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("truck_queue")
  @@index([warehouseId, status], map: "idx_tq_wh_status")
  @@index([queuePosition], map: "idx_tq_position")
  @@index([status, queueType], map: "idx_tq_status_type")
}

model TruckQueueHistory {
  id                  String   @id @default(uuid()) @db.Uuid
  yardVehicleId       String   @db.Uuid @map("yard_vehicle_id")
  vehicleNumber       String   @map("vehicle_number")
