  transferDate    DateTime @map("transfer_date")
  // ─── Type ───
  transferType    String   @map("transfer_type") // WAREHOUSE_TO_WAREHOUSE, WAREHOUSE_TO_STORE, WAREHOUSE_TO_RESTAURANT, PLANT_TO_WAREHOUSE, PLANT_TO_STORE, BRANCH_TO_BRANCH, BIN_TO_BIN, LOCATION_TO_LOCATION, COLD_STORAGE_TRANSFER, TRANSIT_VEHICLE_TRANSFER, RETURN_TRANSFER
  // ─── Source ───
  sourceCompanyId    String? @db.Uuid @map("source_company_id")
  sourceBranchId     String? @db.Uuid @map("source_branch_id")
  sourceWarehouseId  String? @db.Uuid @map("source_warehouse_id")
  sourceWarehouseName String? @map("source_warehouse_name")
  // ─── Destination ───
  destCompanyId      String? @db.Uuid @map("dest_company_id")
  destBranchId       String? @db.Uuid @map("dest_branch_id")
  destWarehouseId    String? @db.Uuid @map("dest_warehouse_id")
  destWarehouseName  String? @map("dest_warehouse_name")
  // ─── Logistics ───
  vehicleNumber   String?  @map("vehicle_number")
  driverName      String?  @map("driver_name")
  carrierId       String?  @db.Uuid @map("carrier_id")
  carrierName     String?  @map("carrier_name")
  // ─── Reference ───
  referenceType   String?  @map("reference_type")
  referenceNumber String?  @map("reference_number")
  // ─── Status ───
  status          String   @default("DRAFT") // DRAFT, SUBMITTED, APPROVED, REJECTED, CANCELLED, PARTIALLY_DISPATCHED, DISPATCHED, IN_TRANSIT, PARTIALLY_RECEIVED, COMPLETED
  // ─── Summary ───
  totalLines      Int      @default(0) @map("total_lines")
  totalRequestedQty Decimal @db.Decimal(18, 4) @default(0) @map("total_requested_qty")
  totalDispatchedQty Decimal @db.Decimal(18, 4) @default(0) @map("total_dispatched_qty")
  totalReceivedQty Decimal @db.Decimal(18, 4) @default(0) @map("total_received_qty")
  totalValue      Decimal  @db.Decimal(18, 2) @default(0) @map("total_value")
  // ─── Workflow timestamps ───
  submittedAt     DateTime? @map("submitted_at")
  approvedById    String?  @db.Uuid @map("approved_by_id")
  approvedAt      DateTime? @map("approved_at")
  dispatchedAt    DateTime? @map("dispatched_at")
  dispatchedById  String?  @db.Uuid @map("dispatched_by_id")
  inTransitAt     DateTime? @map("in_transit_at")
  receivedAt      DateTime? @map("received_at")
  receivedById    String?  @db.Uuid @map("received_by_id")
  completedAt     DateTime? @map("completed_at")
  // ─── Transit ───
  estimatedArrival DateTime? @map("estimated_arrival")
  actualArrival    DateTime? @map("actual_arrival")
  // ─── Remarks ───
  remarks         String?
  // ─── Audit ───
  requestedById   String?  @db.Uuid @map("requested_by_id")
  requestedByName String?  @map("requested_by_name")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  lines           StockTransferLine[]
  transitRecords  InventoryInTransit[]

  @@map("stock_transfers")
  @@index([transferType, status], map: "idx_st_type_status")
  @@index([sourceWarehouseId, destWarehouseId], map: "idx_st_route")
  @@index([status, transferDate], map: "idx_st_status_date")
}

model StockTransferLine {
  id              String   @id @default(uuid()) @db.Uuid
  stockTransferId String   @db.Uuid @map("stock_transfer_id")
  lineOrder       Int      @map("line_order")
  // ─── Item ───
