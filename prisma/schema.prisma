  departmentId        String?  @db.Uuid @map("department_id")
  departmentName      String?  @map("department_name")
  productionLineId    String?  @db.Uuid @map("production_line_id")
  productionLineCode  String?  @map("production_line_code")
  // ─── Recipe ───
  recipeId            String   @db.Uuid @map("recipe_id")
  recipeCode          String   @map("recipe_code")
  recipeVersion       String   @map("recipe_version")
  // ─── Product ───
  productId           String?  @db.Uuid @map("product_id")
  productSku          String   @map("product_sku")
  productName         String   @map("product_name")
  // ─── Production ───
  productionType      String   @default("BATCH_PRODUCTION") // BATCH_PRODUCTION, CONTINUOUS_PRODUCTION, SEMI_FINISHED_PRODUCTION, PACKAGING_PRODUCTION, REWORK_PRODUCTION, TRIAL_BATCH, SAMPLE_PRODUCTION, MAKE_TO_STOCK, MAKE_TO_ORDER
  batchNumber         String?  @map("batch_number")
  batchSize           Decimal  @db.Decimal(14, 3) @map("batch_size")
  plannedQuantity     Decimal  @db.Decimal(14, 3) @map("planned_quantity")
  completedQuantity   Decimal  @db.Decimal(14, 3) @default(0) @map("completed_quantity")
  uom                 String   @default("KG")
  // ─── Priority ───
  priority            String   @default("NORMAL") // EMERGENCY, HIGH, NORMAL, LOW
  // ─── Schedule ───
  plannedStart        DateTime @map("planned_start")
  plannedFinish       DateTime @map("planned_finish")
  actualStart         DateTime? @map("actual_start")
  actualFinish        DateTime? @map("actual_finish")
  // ─── Status ───
  status              String   @default("DRAFT") // DRAFT, RELEASED, MATERIALS_RESERVED, IN_PROGRESS, PAUSED, COMPLETED, CANCELLED, CLOSED
