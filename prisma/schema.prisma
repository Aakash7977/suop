// ═══════════════════════════════════════════════════════════
// SPRINT 16 — INVENTORY ADJUSTMENT, RECONCILIATION & WRITE-OFF
// Stock corrections, damage, expiry, write-offs, root cause analysis
// ═══════════════════════════════════════════════════════════

// ─── Epic 1: Inventory Adjustment Document ──────────────
model InventoryAdjustment {
  id              String   @id @default(uuid()) @db.Uuid
  adjustmentNumber String  @unique @map("adjustment_number")
  adjustmentDate  DateTime @map("adjustment_date")
  // ─── Type ───
  adjustmentType  String   @map("adjustment_type") // STOCK_GAIN, STOCK_LOSS, DAMAGE, EXPIRY, SHRINKAGE, THEFT, PRODUCTION_VARIANCE, PACKING_VARIANCE, SUPPLIER_SHORTAGE, CUSTOMER_RETURN_CORRECTION, BARCODE_CORRECTION, OPENING_BALANCE_CORRECTION, FINANCIAL_RECONCILIATION
  // ─── Scope ───
  warehouseId     String?  @db.Uuid @map("warehouse_id")
  warehouseName   String?  @map("warehouse_name")
  companyId       String?  @db.Uuid @map("company_id")
  branchId        String?  @db.Uuid @map("branch_id")
  // ─── Reference ───
  referenceType   String?  @map("reference_type")
  referenceNumber String?  @map("reference_number")
  // ─── Reason ───
  adjustmentReasonId String? @db.Uuid @map("adjustment_reason_id")
  reason          String?
  // ─── Status ───
  status          String   @default("DRAFT") // DRAFT, SUBMITTED, PENDING_APPROVAL, APPROVED, POSTED, REJECTED, CANCELLED
  // ─── Summary ───
  totalLines      Int      @default(0) @map("total_lines")
  totalAdjustmentQty Decimal @db.Decimal(18, 4) @default(0) @map("total_adjustment_qty")
  totalAdjustmentValue Decimal @db.Decimal(18, 2) @default(0) @map("total_adjustment_value")
  // ─── Workflow ───
  submittedAt     DateTime? @map("submitted_at")
  approvedById    String?  @db.Uuid @map("approved_by_id")
  approvedAt      DateTime? @map("approved_at")
  postedAt        DateTime? @map("posted_at")
  // ─── Inventory ───
  inventoryPosted Boolean  @default(false) @map("inventory_posted")
  inventoryTransactionId String? @db.Uuid @map("inventory_transaction_id")
  // ─── Finance ───
  financePosted   Boolean  @default(false) @map("finance_posted")
  glEntryNumber   String?  @map("gl_entry_number")
  // ─── Write-off ───
  isWriteOff      Boolean  @default(false) @map("is_write_off")
  writeOffApprovedById String? @db.Uuid @map("write_off_approved_by_id")
  writeOffApprovedAt DateTime? @map("write_off_approved_at")
  // ─── Evidence ───
  photoRequired   Boolean  @default(false) @map("photo_required")
  photoAttached   Boolean  @default(false) @map("photo_attached")
  // ─── Remarks ───
  remarks         String?
  // ─── Audit ───
  requestedById   String?  @db.Uuid @map("requested_by_id")
  requestedByName String?  @map("requested_by_name")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  lines           InventoryAdjustmentLine[]

  @@map("inventory_adjustments")
  @@index([adjustmentType, status], map: "idx_ia_type_status")
  @@index([warehouseId, adjustmentDate], map: "idx_ia_warehouse_date")
  @@index([status, adjustmentDate], map: "idx_ia_status_date")
  @@index([isWriteOff], map: "idx_ia_writeoff")
}

model InventoryAdjustmentLine {
