  // ─── Timestamp ───
  loggedAt            DateTime @default(now()) @map("logged_at")

  execution           WorkOrderExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)

  @@map("execution_logs")
  @@index([executionId, loggedAt], map: "idx_el_exec_time")
  @@index([logType], map: "idx_el_type")
}

// ─── Epic 3: Material Consumption ───────────────────────
model MaterialConsumption {
