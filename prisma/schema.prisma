  // ─── Link to adjustment ───
  adjustmentId    String?  @db.Uuid @map("adjustment_id")
  // ─── Remarks ───
  damageDescription String? @map("damage_description")
  remarks         String?
  // ─── Audit ───
  reportedById    String?  @db.Uuid @map("reported_by_id")
  reportedByName  String?  @map("reported_by_name")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("damage_reports_s16")
  @@index([damageType, status], map: "idx_dr16_type_status")
  @@index([productId], map: "idx_dr16_product")
  @@index([status], map: "idx_dr16_status")
  @@index([damageSeverity], map: "idx_dr16_severity")
}

// ─── Epic 5: Expiry Adjustments ─────────────────────────
model ExpiryAdjustment {
