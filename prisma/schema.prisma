  totalCounts     Int      @default(0) @map("total_counts")
  totalItemsCounted Int    @default(0) @map("total_items_counted")
  avgAccuracy     Decimal? @db.Decimal(5, 2) @map("avg_accuracy")
  avgCountTime    Int?     @map("avg_count_time") // minutes
  // ─── Status ───
  status          String   @default("ACTIVE") // ACTIVE, BUSY, INACTIVE
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("count_teams")
  @@index([status], map: "idx_ct_status")
  @@index([assignedWarehouseId], map: "idx_ct_warehouse")
}

// ─── Epic 6: Variance Analysis ─────────────────────────
model CountVariance {
  id              String   @id @default(uuid()) @db.Uuid
  physicalInventoryId String? @db.Uuid @map("physical_inventory_id")
  countNumber     String?  @map("count_number")
  // ─── Item ───
  productId       String   @db.Uuid @map("product_id")
  productName     String   @map("product_name")
  batchId         String?  @db.Uuid @map("batch_id")
  batchNumber     String?  @map("batch_number")
  uomId           String?  @db.Uuid @map("uom_id")
  // ─── Quantities ───
  systemQty       Decimal  @db.Decimal(18, 4) @map("system_qty")
  countedQty      Decimal  @db.Decimal(18, 4) @map("counted_qty")
  varianceQty     Decimal  @db.Decimal(18, 4) @map("variance_qty")
  // ─── Value ───
  unitCost        Decimal? @db.Decimal(18, 4) @map("unit_cost")
  varianceValue   Decimal  @db.Decimal(18, 2) @default(0) @map("variance_value")
  // ─── Variance type ───
  varianceType    String   @map("variance_type") // MISSING, EXTRA, WRONG_LOCATION, WRONG_BATCH, WRONG_UOM, WRONG_PRODUCT
  // ─── Root cause ───
  rootCause       String?
  rootCauseCategory String? @map("root_cause_category")
  correctiveAction String? @map("corrective_action")
  // ─── Resolution ───
  resolutionStatus String  @default("PENDING") @map("resolution_status") // PENDING, INVESTIGATING, RESOLVED, ADJUSTED, WRITTEN_OFF
  resolutionNotes String?  @map("resolution_notes")
  resolvedById    String?  @db.Uuid @map("resolved_by_id")
  resolvedAt      DateTime? @map("resolved_at")
  // ─── Recount ───
  recountRequired Boolean  @default(false) @map("recount_required")
  recountCount    Int      @default(0) @map("recount_count")
  // ─── Audit ───
  createdAt       DateTime @default(now()) @map("created_at")

  physicalInventory PhysicalInventory? @relation(fields: [physicalInventoryId], references: [id], onDelete: SetNull)

  @@map("count_variances")
  @@index([physicalInventoryId], map: "idx_cv_pi")
  @@index([varianceType], map: "idx_cv_type")
  @@index([resolutionStatus], map: "idx_cv_resolution")
  @@index([productId], map: "idx_cv_product")
}

// ═══════════════════════════════════════════════════════════
// SPRINT 19 — BATCH, EXPIRY, SHELF-LIFE & FEFO MANAGEMENT
// Food safety, recalls, compliance, and traceability
// ═══════════════════════════════════════════════════════════

// ─── Epic 1: Batch Lifecycle Management ─────────────────
model BatchMaster {
  id              String   @id @default(uuid()) @db.Uuid
  batchNumber     String   @map("batch_number")
  productId       String   @db.Uuid @map("product_id")
  productName     String   @map("product_name")
  // ─── Unique per product ───
  @@unique([batchNumber, productId], map: "bm_unique_batch_product")
  // ─── Type ───
  batchType       String   @map("batch_type") // RAW_MATERIAL, PACKAGING_MATERIAL, SEMI_FINISHED, FINISHED_GOODS, RETURNED_GOODS, QUALITY_HOLD, TRIAL_BATCH, REWORK_BATCH
  // ─── Supplier/Production ───
  supplierBatchNo String?  @map("supplier_batch_no")
  productionBatchNo String? @map("production_batch_no")
  productionOrderId String? @map("production_order_id")
  supplierId      String?  @db.Uuid @map("supplier_id")
  supplierName    String?  @map("supplier_name")
  // ─── Dates ───
  manufacturingDate DateTime? @map("manufacturing_date")
  packingDate     DateTime? @map("packing_date")
  bestBeforeDate  DateTime? @map("best_before_date")
  expiryDate      DateTime? @map("expiry_date")
  // ─── Status ───
  batchStatus     String   @default("CREATED") @map("batch_status") // PLANNED, CREATED, RELEASED, AVAILABLE, RESERVED, BLOCKED, QUARANTINED, EXPIRED, RECALLED, CONSUMED, CLOSED
  statusReason    String?  @map("status_reason")
  // ─── Scope ───
  warehouseId     String?  @db.Uuid @map("warehouse_id")
  warehouseName   String?  @map("warehouse_name")
  // ─── Quantity ───
  originalQty     Decimal  @db.Decimal(18, 4) @default(0) @map("original_qty")
  currentQty      Decimal  @db.Decimal(18, 4) @default(0) @map("current_qty")
  uomId           String?  @db.Uuid @map("uom_id")
  uomName         String?  @map("uom_name")
  // ─── Cost ───
  unitCost        Decimal? @db.Decimal(18, 4) @map("unit_cost")
  totalValue      Decimal  @db.Decimal(18, 2) @default(0) @map("total_value")
  // ─── FEFO ───
  fefoPriority    Int      @default(100) @map("fefo_priority") // lower = picked first
  // ─── Storage ───
  storageConditions String? @map("storage_conditions")
  temperatureRange String?  @map("temperature_range")
  // ─── Quality ───
  qualityGrade    String?  @map("quality_grade") // A, B, C, REJECT
  qualityStatus   String   @default("PENDING") @map("quality_status") // PENDING, PASSED, FAILED, QUARANTINE
  // ─── Audit ───
  createdById     String?  @db.Uuid @map("created_by_id")
  createdByName   String?  @map("created_by_name")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  history         BatchHistory[]
  genealogyFrom   BatchGenealogy[] @relation("GenealogyFrom")
  genealogyTo     BatchGenealogy[] @relation("GenealogyTo")
  recalls         RecallBatch[]
  expiryAlerts    ExpiryAlert[]

  @@map("batch_master")
  @@index([productId, batchStatus], map: "idx_bm_product_status")
  @@index([batchStatus], map: "idx_bm_status")
  @@index([expiryDate], map: "idx_bm_expiry")
  @@index([supplierId], map: "idx_bm_supplier")
  @@index([fefoPriority], map: "idx_bm_fefo")
}

model BatchHistory {
  id              String   @id @default(uuid()) @db.Uuid
  batchId         String   @db.Uuid @map("batch_id")
  batchNumber     String   @map("batch_number")
  // ─── Transition ───
  fromStatus      String   @map("from_status")
  toStatus        String   @map("to_status")
  // ─── Actor ───
  changedById     String?  @db.Uuid @map("changed_by_id")
  changedByName   String?  @map("changed_by_name")
  // ─── Context ───
  reason          String?
  comments        String?
  referenceType   String?  @map("reference_type")
  referenceNumber String?  @map("reference_number")
  // ─── Timestamp ───
  changedAt       DateTime @default(now()) @map("changed_at")

  batch           BatchMaster @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@map("batch_history")
  @@index([batchId, changedAt], map: "idx_bh_batch_time")
  @@index([fromStatus, toStatus], map: "idx_bh_transition")
}

// ─── Epic 2: Shelf-Life Rules ──────────────────────────
model ShelfLifeRule {
  id              String   @id @default(uuid()) @db.Uuid
  ruleCode        String   @unique @map("rule_code")
  ruleName        String   @map("rule_name")
  // ─── Scope ───
  productId       String?  @db.Uuid @map("product_id")
  productName     String?  @map("product_name")
  productCategoryId String? @db.Uuid @map("product_category_id")
  productType     String?  @map("product_type")
  // ─── Shelf life ───
  shelfLifeDays   Int      @map("shelf_life_days")
  bestBeforeDays  Int      @map("best_before_days")
  // ─── Storage ───
  storageConditions String? @map("storage_conditions")
  minTemperature  Decimal? @db.Decimal(5, 2) @map("min_temperature")
  maxTemperature  Decimal? @db.Decimal(5, 2) @map("max_temperature")
  maxHumidity     Decimal? @db.Decimal(5, 2) @map("max_humidity")
  maxTransitDays  Int?     @map("max_transit_days")
  // ─── Alert thresholds ───
  alert30Days     Boolean  @default(true) @map("alert_30_days")
  alert15Days     Boolean  @default(true) @map("alert_15_days")
  alert7Days      Boolean  @default(true) @map("alert_7_days")
  alert3Days      Boolean  @default(true) @map("alert_3_days")
  alertToday      Boolean  @default(true) @map("alert_today")
  // ─── Status ───
  status          String   @default("ACTIVE")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("shelf_life_rules")
  @@index([productId], map: "idx_slr_product")
  @@index([productCategoryId], map: "idx_slr_category")
  @@index([status], map: "idx_slr_status")
}

// ─── Epic 3: Expiry Monitoring ─────────────────────────
model ExpiryAlert {
  id              String   @id @default(uuid()) @db.Uuid
  batchId         String?  @db.Uuid @map("batch_id")
  batchNumber     String   @map("batch_number")
  productId       String   @db.Uuid @map("product_id")
