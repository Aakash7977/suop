// ─── Epic 7: Production Exception Management ────────────
model ProductionException {
  id                  String   @id @default(uuid()) @db.Uuid
  exceptionCode       String   @unique @map("exception_code")
  // ─── Links ───
  productionOrderId   String?  @db.Uuid @map("production_order_id")
  productionOrderNumber String? @map("production_order_number")
  workOrderId         String?  @db.Uuid @map("work_order_id")
  workOrderNumber     String?  @map("work_order_number")
  // ─── Exception ───
  exceptionType       String   @map("exception_type") // MATERIAL_SHORTAGE, MACHINE_FAILURE, RECIPE_DEVIATION, QUALITY_FAILURE, OPERATOR_ABSENCE, POWER_FAILURE, BATCH_REJECTION, TEMPERATURE_DEVIATION
  severity            String   @default("MEDIUM") // LOW, MEDIUM, HIGH, CRITICAL
  title               String
  description         String
  // ─── Reporter ───
  reportedById        String?  @db.Uuid @map("reported_by_id")
  reportedByName      String?  @map("reported_by_name")
  reportedAt          DateTime @default(now()) @map("reported_at")
  // ─── Resolution ───
  status              String   @default("OPEN") // OPEN, ACKNOWLEDGED, INVESTIGATING, RESOLVED, ESCALATED
  resolution          String?  @map("resolution") // CONTINUE, PAUSE, REJECT, REWORK
  resolutionNotes     String?  @map("resolution_notes")
  resolvedById        String?  @db.Uuid @map("resolved_by_id")
  resolvedByName      String?  @map("resolved_by_name")
  resolvedAt          DateTime? @map("resolved_at")
  // ─── Impact ───
  downtimeMinutes     Int      @default(0) @map("downtime_minutes")
  // ─── Audit ───
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("production_exceptions")
  @@index([productionOrderId, status], map: "idx_pex_po_status")
  @@index([exceptionType, severity], map: "idx_pex_type_sev")
  @@index([status, severity], map: "idx_pex_status_sev")
}

