  barcodeType         String?  @map("barcode_type") // INGREDIENT, BATCH, CONTAINER, PALLET, QR, GS1
  // ─── Quantity ───
  plannedQty          Decimal  @db.Decimal(14, 3) @default(0) @map("planned_qty")
  actualQty           Decimal  @db.Decimal(14, 3) @default(0) @map("actual_qty")
