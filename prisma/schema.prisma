// ═══════════════════════════════════════════════════════════
// SPRINT 18 — PHYSICAL INVENTORY, CYCLE COUNT & STOCK AUDIT
// Continuous counting without warehouse shutdown
// ═══════════════════════════════════════════════════════════

// ─── Epic 1: Physical Inventory Document ────────────────
model PhysicalInventory {
  id              String   @id @default(uuid()) @db.Uuid
  countNumber     String   @unique @map("count_number")
  countDate       DateTime @map("count_date")
  // ─── Type ───
  countType       String   @map("count_type") // ANNUAL_COUNT, CYCLE_COUNT, BLIND_COUNT, SPOT_COUNT, ABC_COUNT, RANDOM_COUNT, BIN_COUNT, BATCH_COUNT, EXPIRY_COUNT, INVESTIGATION_COUNT
  countMethod     String   @default("BARCODE") @map("count_method") // BARCODE, MANUAL, BLIND, QR
  // ─── Scope ───
  warehouseId     String?  @db.Uuid @map("warehouse_id")
  warehouseName   String?  @map("warehouse_name")
  branchId        String?  @db.Uuid @map("branch_id")
  zone            String?
  // ─── Status ───
  status          String   @default("DRAFT") // DRAFT, ASSIGNED, IN_PROGRESS, COMPLETED, RECOUNT_REQUIRED, APPROVED, POSTED, CANCELLED
  // ─── Summary ───
  totalLines      Int      @default(0) @map("total_lines")
  countedLines    Int      @default(0) @map("counted_lines")
  varianceLines   Int      @default(0) @map("variance_lines")
  totalSystemQty  Decimal  @db.Decimal(18, 4) @default(0) @map("total_system_qty")
  totalCountedQty Decimal  @db.Decimal(18, 4) @default(0) @map("total_counted_qty")
  totalVarianceQty Decimal @db.Decimal(18, 4) @default(0) @map("total_variance_qty")
  totalVarianceValue Decimal @db.Decimal(18, 2) @default(0) @map("total_variance_value")
  // ─── Accuracy ───
  accuracyPercent Decimal? @db.Decimal(5, 2) @map("accuracy_percent")
  // ─── Team ───
  countTeamId     String?  @db.Uuid @map("count_team_id")
  countTeamName   String?  @map("count_team_name")
  // ─── Workflow ───
  startedAt       DateTime? @map("started_at")
  completedAt     DateTime? @map("completed_at")
  approvedById    String?  @db.Uuid @map("approved_by_id")
  approvedAt      DateTime? @map("approved_at")
  postedAt        DateTime? @map("posted_at")
  adjustmentId    String?  @db.Uuid @map("adjustment_id")
  // ─── Recount ───
  recountRequired Boolean  @default(false) @map("recount_required")
  recountCount    Int      @default(0) @map("recount_count")
  // ─── Remarks ───
  remarks         String?
  // ─── Audit ───
  createdById     String?  @db.Uuid @map("created_by_id")
  createdByName   String?  @map("created_by_name")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  lines           PhysicalInventoryLine[]
  variances       CountVariance[]

  @@map("physical_inventories")
  @@index([countType, status], map: "idx_pi_type_status")
  @@index([warehouseId, countDate], map: "idx_pi_warehouse_date")
  @@index([status], map: "idx_pi_status")
}

