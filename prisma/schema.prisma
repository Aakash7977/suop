// ═══════════════════════════════════════════════════════════════════════════════
// SPRINT 39 — ENTERPRISE BATCH MANUFACTURING, GENEALOGY & END-TO-END TRACEABILITY
// Part 5: MES · 11 new models · Epic 1–8 (production_batches, genealogy, recall,
// shelf-life, compliance, split/merge, traceability audit)
// ═══════════════════════════════════════════════════════════════════════════════

// ─── Epic 1: Production Batch Master (manufacturing context) ─────────
model ProductionBatch {
  id                  String   @id @default(uuid()) @db.Uuid
  batchNumber         String   @unique @map("batch_number") // KAJ-THN-20260709-000145
  // ─── Type ───
  batchType           String   @map("batch_type") // RAW_MATERIAL, INGREDIENT, SEMI_FINISHED, FINISHED_GOODS, PACKAGING, TRIAL, REWORK, SAMPLE
  // ─── Recipe / Order Links ───
  recipeId            String?  @db.Uuid @map("recipe_id")
  recipeCode          String?  @map("recipe_code")
  recipeVersion       String?  @map("recipe_version") // V1.2
  productionOrderId   String?  @db.Uuid @map("production_order_id")
  productionOrderNumber String? @map("production_order_number")
  // ─── Product ───
  productId           String?  @db.Uuid @map("product_id")
  productSku          String   @map("product_sku")
  productName         String   @map("product_name")
  // ─── Manufacturing ───
  plantId             String?  @db.Uuid @map("plant_id")
  plantCode           String?  @map("plant_code")
  plantName           String?  @map("plant_name")
  productionLineId    String?  @db.Uuid @map("production_line_id")
  productionLineCode  String?  @map("production_line_code")
  workCenterId        String?  @db.Uuid @map("work_center_id")
  workCenterCode      String?  @map("work_center_code")
  // ─── Dates ───
  manufacturingDate   DateTime @map("manufacturing_date")
  packingDate         DateTime? @map("packing_date")
  bestBeforeDate      DateTime? @map("best_before_date")
  expiryDate          DateTime? @map("expiry_date")
  // ─── Operator / Shift ───
  operatorId          String?  @db.Uuid @map("operator_id")
  operatorName        String?  @map("operator_name")
  shiftCode           String?  @map("shift_code")
  // ─── Quantity ───
  plannedQty          Decimal  @db.Decimal(18, 4) @default(0) @map("planned_qty")
  actualQty           Decimal  @db.Decimal(18, 4) @default(0) @map("actual_qty")
  scrapQty            Decimal  @db.Decimal(18, 4) @default(0) @map("scrap_qty")
  reworkQty           Decimal  @db.Decimal(18, 4) @default(0) @map("rework_qty")
  uom                 String   @default("KG") @map("uom")
  // ─── Status ───
  status              String   @default("PLANNED") @map("status") // PLANNED, RUNNING, COMPLETED, RELEASED, QUALITY_HOLD, REJECTED, RECALLED, EXPIRED, DISPOSED
  statusReason        String?  @map("status_reason")
  // ─── Genealogy Anchor ───
  parentBatchId       String?  @db.Uuid @map("parent_batch_id") // immediate parent (for simple chains)
  parentBatchNumber   String?  @map("parent_batch_number")
  // ─── Storage ───
  storageConditions   String?  @map("storage_conditions")
  temperatureRange    String?  @map("temperature_range")
  // ─── Quality ───
  qualityGrade        String?  @map("quality_grade") // A, B, C, REJECT
  qualityStatus       String   @default("PENDING") @map("quality_status") // PENDING, PASSED, FAILED, QUARANTINE
  // ─── Recall ───
  isRecalled          Boolean  @default(false) @map("is_recalled")
  recallId            String?  @db.Uuid @map("recall_id")
  // ─── QR/Label ───
  qrCode              String?  @map("qr_code")
  labelPrintedAt      DateTime? @map("label_printed_at")
  // ─── Audit ───
  createdById         String?  @db.Uuid @map("created_by_id")
  createdByName       String?  @map("created_by_name")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  history             ProductionBatchHistory[]
  childRelationships  BatchRelationship[] @relation("ParentBatch")
  parentRelationships BatchRelationship[] @relation("ChildBatch")
  splitMerges         BatchSplitMerge[]
  shelfLife           BatchShelfLife?
  recallActions       RecallAction[]
  traceSearches       TraceabilitySearch[]

  @@map("production_batches")
  @@index([batchType, status], map: "idx_pb_type_status")
  @@index([productionOrderId], map: "idx_pb_po")
  @@index([plantId, manufacturingDate], map: "idx_pb_plant_date")
  @@index([expiryDate], map: "idx_pb_expiry")
  @@index([isRecalled], map: "idx_pb_recalled")
  @@index([productId, status], map: "idx_pb_product_status")
}

model ProductionBatchHistory {
  id                  String   @id @default(uuid()) @db.Uuid
  batchId             String   @db.Uuid @map("batch_id")
  batchNumber         String   @map("batch_number")
  // ─── Transition ───
  fromStatus          String   @map("from_status")
  toStatus            String   @map("to_status")
  // ─── Actor ───
  changedById         String?  @db.Uuid @map("changed_by_id")
  changedByName       String?  @map("changed_by_name")
  // ─── Context ───
  reason              String?
  comments            String?
  referenceType       String?  @map("reference_type") // QUALITY_CHECK, RECALL, EXPIRY, MANUAL, SPLIT, MERGE
  referenceNumber     String?  @map("reference_number")
  // ─── Timestamp ───
  changedAt           DateTime @default(now()) @map("changed_at")

  batch               ProductionBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@map("production_batch_history")
  @@index([batchId, changedAt], map: "idx_pbh_batch_time")
  @@index([fromStatus, toStatus], map: "idx_pbh_transition")
}

// ─── Epic 3: Parent-Child Batch Genealogy (manufacturing context) ──────
// Supports: One-to-One, One-to-Many, Many-to-One, Many-to-Many
model BatchRelationship {
  id                  String   @id @default(uuid()) @db.Uuid
  // ─── Parent (input) ───
  parentBatchId       String   @db.Uuid @map("parent_batch_id")
  parentBatchNumber   String   @map("parent_batch_number")
  parentBatchType     String   @map("parent_batch_type") // RAW_MATERIAL, SEMI_FINISHED, etc.
  parentProductId     String?  @db.Uuid @map("parent_product_id")
  parentProductName   String?  @map("parent_product_name")
  // ─── Child (output) ───
  childBatchId        String   @db.Uuid @map("child_batch_id")
  childBatchNumber    String   @map("child_batch_number")
  childBatchType      String   @map("child_batch_type")
  childProductId      String?  @db.Uuid @map("child_product_id")
  childProductName    String?  @map("child_product_name")
  // ─── Relationship ───
  relationshipType    String   @map("relationship_type") // PRODUCED_FROM, USED_IN, REPACKED_FROM, REWORKED_FROM, BLEND_OF, SPLIT_FROM, MERGED_FROM, PACKAGED_FROM
  // ─── Quantity ───
  quantityUsed        Decimal  @db.Decimal(18, 4) @map("quantity_used")
  quantityRatio       Decimal? @db.Decimal(10, 4) @map("quantity_ratio") // 0.4500 = 45% of parent
  uom                 String   @default("KG") @map("uom")
  // ─── Production Context ───
  productionOrderId   String?  @db.Uuid @map("production_order_id")
  productionOrderNumber String? @map("production_order_number")
  workOrderId         String?  @db.Uuid @map("work_order_id")
  workOrderNumber     String?  @map("work_order_number")
  workCenterCode      String?  @map("work_center_code")
  operatorName        String?  @map("operator_name")
  productionDate      DateTime? @map("production_date")
  // ─── Supplier Trace (for raw materials) ───
  supplierId          String?  @db.Uuid @map("supplier_id")
  supplierName        String?  @map("supplier_name")
  purchaseOrderNumber String?  @map("purchase_order_number")
  goodsReceiptNumber  String?  @map("goods_receipt_number")
  // ─── Audit ───
  createdAt           DateTime @default(now()) @map("created_at")

  parentBatch         ProductionBatch @relation("ParentBatch", fields: [parentBatchId], references: [id], onDelete: Cascade)
  childBatch          ProductionBatch @relation("ChildBatch", fields: [childBatchId], references: [id], onDelete: Cascade)

  @@map("batch_relationships")
  @@index([parentBatchId], map: "idx_br_parent")
  @@index([childBatchId], map: "idx_br_child")
  @@index([relationshipType], map: "idx_br_relation")
  @@index([productionOrderId], map: "idx_br_po")
  @@index([supplierId], map: "idx_br_supplier")
}

// ─── Epic 5: Shelf-Life & Expiry (manufacturing context) ──────────────
model BatchShelfLife {
  id                  String   @id @default(uuid()) @db.Uuid
  batchId             String   @unique @db.Uuid @map("batch_id")
  batchNumber         String   @map("batch_number")
  // ─── Dates ───
  manufacturingDate   DateTime @map("manufacturing_date")
  bestBeforeDate      DateTime? @map("best_before_date")
  expiryDate          DateTime @map("expiry_date")
  // ─── Computed ───
  totalShelfLifeDays  Int      @map("total_shelf_life_days")
  elapsedDays         Int      @map("elapsed_days")
  remainingDays       Int      @map("remaining_days") // negative = expired
  shelfLifePercent    Decimal  @db.Decimal(5, 2) @map("shelf_life_percent") // 100.00 → 0.00
  // ─── Storage Compliance ───
  storageConditions   String?  @map("storage_conditions")
  requiredTempMin     Decimal? @db.Decimal(5, 2) @map("required_temp_min")
  requiredTempMax     Decimal? @db.Decimal(5, 2) @map("required_temp_max")
  actualTempMin       Decimal? @db.Decimal(5, 2) @map("actual_temp_min")
  actualTempMax       Decimal? @db.Decimal(5, 2) @map("actual_temp_max")
  tempCompliant       Boolean  @default(true) @map("temp_compliant")
  coldChainIntact     Boolean  @default(true) @map("cold_chain_intact")
  // ─── Alert ───
  alertLevel          String   @default("HEALTHY") @map("alert_level") // HEALTHY, NEAR_EXPIRY, CRITICAL, EXPIRED, SHORT_LIFE, COLD_CHAIN_BREAK
  // ─── Audit ───
  lastCheckedAt       DateTime @default(now()) @map("last_checked_at")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  batch               ProductionBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@map("batch_shelf_life")
  @@index([expiryDate], map: "idx_bsl_expiry")
  @@index([alertLevel], map: "idx_bsl_alert")
  @@index([tempCompliant], map: "idx_bsl_temp")
}

model ExpiryMonitor {
  id                  String   @id @default(uuid()) @db.Uuid
  monitorCode         String   @unique @map("monitor_code")
  // ─── Scope ───
  plantId             String?  @db.Uuid @map("plant_id")
  plantName           String?  @map("plant_name")
  warehouseId         String?  @db.Uuid @map("warehouse_id")
  warehouseName       String?  @map("warehouse_name")
  // ─── Summary ───
  totalBatches        Int      @default(0) @map("total_batches")
  healthyBatches      Int      @default(0) @map("healthy_batches")
  nearExpiryBatches   Int      @default(0) @map("near_expiry_batches") // ≤30 days
  criticalBatches     Int      @default(0) @map("critical_batches") // ≤7 days
  expiredBatches      Int      @default(0) @map("expired_batches")
  shortLifeBatches    Int      @default(0) @map("short_life_batches")
  coldChainBreaks     Int      @default(0) @map("cold_chain_breaks")
  // ─── Value at Risk ───
  totalValueAtRisk    Decimal  @db.Decimal(18, 2) @default(0) @map("total_value_at_risk")
  // ─── Action ───
  fefoPicks           Int      @default(0) @map("fefo_picks")
  discountedLines     Int      @default(0) @map("discounted_lines")
  donatedLines        Int      @default(0) @map("donated_lines")
  destroyedLines      Int      @default(0) @map("destroyed_lines")
