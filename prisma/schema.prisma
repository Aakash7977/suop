  // ─── Rule type ───
  ruleType        String   @map("rule_type") // MIN_SELLING_PRICE, MAX_DISCOUNT, MIN_MARGIN, CUSTOMER_PRICING, LOCATION_PRICING, HOLIDAY_PRICING, CONTRACT_PRICING
  // ─── Scope ───
