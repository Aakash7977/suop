  destLocationId  String?  @db.Uuid @map("dest_location_id")
  destLocationName String? @map("dest_location_name")
  destBin         String?  @map("dest_bin")
  // ─── Cost ───
  unitCost        Decimal? @db.Decimal(18, 4) @map("unit_cost")
  totalCost       Decimal? @db.Decimal(18, 4) @map("total_cost")
  // ─── Receipt status ───
  receiptStatus   String   @default("PENDING") @map("receipt_status") // PENDING, PARTIALLY_RECEIVED, RECEIVED, SHORT_RECEIPT, OVER_RECEIPT, DAMAGED, REJECTED
