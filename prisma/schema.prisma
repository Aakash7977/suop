  @@index([alertLevel, status], map: "idx_ea_level_status")
  @@index([expiryDate], map: "idx_ea_expiry")
  @@index([productId], map: "idx_ea_product")
  @@index([warehouseId], map: "idx_ea_warehouse")
}

// ─── Epic 5: Product Recall Engine ─────────────────────
model ProductRecall {
  id              String   @id @default(uuid()) @db.Uuid
  recallNumber    String   @unique @map("recall_number")
  recallDate      DateTime @map("recall_date")
  // ─── Type ───
  recallType      String   @map("recall_type") // FULL_RECALL, PARTIAL_RECALL, MARKET_WITHDRAWAL, SUPPLIER_RECALL, INTERNAL_RECALL
  recallReason    String   @map("recall_reason") // QUALITY_ISSUE, CONTAMINATION, MISLABELING, FOREIGN_OBJECT, REGULATORY, CUSTOMER_COMPLAINT
  // ─── Description ───
  description     String?
  // ─── Source ───
  complaintNumber String?  @map("complaint_number")
  reportedBy      String?  @map("reported_by")
  // ─── Scope ───
  productId       String?  @db.Uuid @map("product_id")
  productName     String?  @map("product_name")
  // ─── Status ───
  status          String   @default("INITIATED") @map("status") // INITIATED, INVESTIGATING, RECALL_NOTICE_SENT, RETURNS_IN_PROGRESS, COMPLETED, CANCELLED
  // ─── Summary ───
  totalBatchesAffected Int  @default(0) @map("total_batches_affected")
  totalQuantityRecalled Decimal @db.Decimal(18, 4) @default(0) @map("total_quantity_recalled")
  totalQuantityReturned Decimal @db.Decimal(18, 4) @default(0) @map("total_quantity_returned")
  totalCustomersAffected Int @default(0) @map("total_customers_affected")
  totalValue      Decimal  @db.Decimal(18, 2) @default(0) @map("total_value")
  // ─── Timeline ───
  initiatedAt     DateTime @default(now()) @map("initiated_at")
  noticeSentAt    DateTime? @map("notice_sent_at")
  completedAt     DateTime? @map("completed_at")
  // ─── Approval ───
  approvedById    String?  @db.Uuid @map("approved_by_id")
  approvedAt      DateTime? @map("approved_at")
  // ─── Remarks ───
  remarks         String?
  // ─── Audit ───
  createdById     String?  @db.Uuid @map("created_by_id")
  createdByName   String?  @map("created_by_name")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  batches         RecallBatch[]

  @@map("product_recalls")
  @@index([recallType, status], map: "idx_recl_type_status")
  @@index([status], map: "idx_recl_status")
  @@index([productId], map: "idx_recl_product")
}

model RecallBatch {
  id              String   @id @default(uuid()) @db.Uuid
  recallId        String   @db.Uuid @map("recall_id")
  batchId         String?  @db.Uuid @map("batch_id")
  batchNumber     String   @map("batch_number")
  // ─── Item ───
  productId       String   @db.Uuid @map("product_id")
  productName     String   @map("product_name")
  // ─── Quantity ───
  quantityProduced Decimal  @db.Decimal(18, 4) @map("quantity_produced")
  quantityInStock Decimal  @db.Decimal(18, 4) @default(0) @map("quantity_in_stock")
  quantityDispatched Decimal @db.Decimal(18, 4) @default(0) @map("quantity_dispatched")
  quantityReturned Decimal  @db.Decimal(18, 4) @default(0) @map("quantity_returned")
  // ─── Dates ───
  manufacturingDate DateTime? @map("manufacturing_date")
  expiryDate      DateTime?  @map("expiry_date")
  // ─── Status ───
  status          String   @default("IDENTIFIED") @map("status") // IDENTIFIED, NOTIFIED, RETURNED, DISPOSED, WRITTEN_OFF
  // ─── Audit ───
  createdAt       DateTime @default(now()) @map("created_at")

  recall          ProductRecall @relation(fields: [recallId], references: [id], onDelete: Cascade)
