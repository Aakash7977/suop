  alertLevel      String   @map("alert_level") // HEALTHY, NEAR_EXPIRY, CRITICAL, EXPIRED
  daysToExpiry    Int      @map("days_to_expiry") // negative = already expired
  // ─── Quantity ───
  quantity        Decimal  @db.Decimal(18, 4)
