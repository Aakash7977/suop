  // ─── Hardware ───
  deviceType          String   @default("HANDHELD") @map("device_type") // PHONE, HANDHELD, ZEBRA_TC, HONEYWELL, CHAINWAY, UROVO, TABLET
  manufacturer        String?  @map("manufacturer")
  modelNumber         String?  @map("model_number")
  serialNumber        String?  @map("serial_number") @unique
  androidVersion      String?  @map("android_version")
  // ─── Bound Operator ───
  assignedOperatorId  String?  @db.Uuid @map("assigned_operator_id")
  assignedOperatorName String? @map("assigned_operator_name")
  // ─── Scope ───
  plantId             String?  @db.Uuid @map("plant_id")
  plantCode           String?  @map("plant_code")
  productionLineId    String?  @db.Uuid @map("production_line_id")
  productionLineCode  String?  @map("production_line_code")
  workCenterId        String?  @db.Uuid @map("work_center_id")
  workCenterCode      String?  @map("work_center_code")
  // ─── Status ───
  status              String   @default("ACTIVE") @map("status") // ACTIVE, INACTIVE, LOCKED, WIPED, RETIRED
  batteryPercent      Int      @default(100) @map("battery_percent")
  connectivityStatus  String   @default("ONLINE") @map("connectivity_status") // ONLINE, OFFLINE, SYNCING
  lastKnownLocation   String?  @map("last_known_location")
  // ─── Security ───
  isEncrypted         Boolean  @default(true) @map("is_encrypted")
  remoteLockRequested Boolean  @default(false) @map("remote_lock_requested")
  remoteWipeRequested Boolean  @default(false) @map("remote_wipe_requested")
  // ─── Sync ───
  lastSyncAt          DateTime? @map("last_sync_at")
  pendingTransactions Int      @default(0) @map("pending_transactions")
  // ─── Audit ───
  registeredAt        DateTime @default(now()) @map("registered_at")
  lastSeenAt          DateTime? @map("last_seen_at")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  sessions            ProductionDeviceSession[]

  @@map("production_mobile_devices")
  @@index([plantId, status], map: "idx_pmd_plant_status")
  @@index([assignedOperatorId], map: "idx_pmd_operator")
  @@index([status], map: "idx_pmd_status")
}

