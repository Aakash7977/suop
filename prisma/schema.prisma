  averageCost     Decimal? @db.Decimal(18, 4) @map("average_cost")
  fifoCost        Decimal? @db.Decimal(18, 4) @map("fifo_cost")
  weightedAverageCost Decimal? @db.Decimal(18, 4) @map("weighted_average_cost")
  standardCost    Decimal? @db.Decimal(18, 4) @map("standard_cost")
  lastPurchaseCost Decimal? @db.Decimal(18, 4) @map("last_purchase_cost")
  // ─── Additional costs ───
  landingCost     Decimal? @db.Decimal(18, 4) @map("landing_cost")
  overheadCost    Decimal? @db.Decimal(18, 4) @map("overhead_cost")
  totalCost       Decimal? @db.Decimal(18, 4) @map("total_cost")
  // ─── Scope ───
  companyId       String?  @db.Uuid @map("company_id")
  branchId        String?  @db.Uuid @map("branch_id")
  // ─── Effective ───
