// ─── Epic 7: Variance Analysis ──────────────────────────────────────────
model BatchVariance {
  id                  String   @id @default(uuid()) @db.Uuid
  batchCostId         String   @db.Uuid @map("batch_cost_id")
  productionBatchNumber String  @map("production_batch_number")
  // ─── Variance Type ───
  varianceType        String   @map("variance_type") // MATERIAL, LABOR, MACHINE, YIELD, PURCHASE_PRICE, USAGE, OVERHEAD, TIME
  // ─── Values ───
  standardCost        Decimal  @db.Decimal(14, 2) @map("standard_cost")
  actualCost          Decimal  @db.Decimal(14, 2) @map("actual_cost")
  varianceAmount      Decimal  @db.Decimal(14, 2) @map("variance_amount")
  variancePercent     Decimal  @db.Decimal(6, 2) @map("variance_percent")
  // ─── Direction ───
  varianceDirection   String   @map("variance_direction") // FAVORABLE (cost < standard), UNFAVORABLE (cost > standard)
  // ─── Severity ───
  severity            String   @default("LOW") @map("severity") // LOW, MEDIUM, HIGH, CRITICAL
  // ─── Root Cause ───
  rootCauseCategory   String?  @map("root_cause_category") // RECIPE_DEVIATION, MACHINE_DOWNTIME, OPERATOR_ERROR, MATERIAL_QUALITY, YIELD_LOSS, OVERTIME, UTILITY_SPIKE
  rootCauseDescription String? @map("root_cause_description")
  // ─── Action ───
  correctiveAction    String?  @map("corrective_action")
  actionOwner         String?  @map("action_owner")
  actionStatus        String   @default("OPEN") @map("action_status") // OPEN, IN_PROGRESS, RESOLVED, ACCEPTED
  // ─── Audit ───
  detectedAt          DateTime @default(now()) @map("detected_at")
  createdAt           DateTime @default(now()) @map("created_at")

  batchCost           BatchCost @relation(fields: [batchCostId], references: [id], onDelete: Cascade)

  @@map("batch_variances")
  @@index([batchCostId], map: "idx_bv42_batch_cost")
  @@index([varianceType, severity], map: "idx_bv42_type_sev")
  @@index([varianceDirection], map: "idx_bv42_direction")
  @@index([actionStatus], map: "idx_bv42_action")
}

