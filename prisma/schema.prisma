  // ─── Check ───
  checkType           String   @map("check_type") // TEMPERATURE, WEIGHT, DIMENSIONS, VISUAL, TASTE, PACKAGING, METAL_DETECTOR, SEAL_VERIFICATION
  checkStage          String   @map("check_stage") // MIXING, COOKING, COOLING, CUTTING, PACKING, FINISHED
  // ─── Results ───
  measuredValue       Decimal? @db.Decimal(10, 3) @map("measured_value")
  targetValue         Decimal? @db.Decimal(10, 3) @map("target_value")
  minValue            Decimal? @db.Decimal(10, 3) @map("min_value")
  maxValue            Decimal? @db.Decimal(10, 3) @map("max_value")
  unit                String?  @map("unit") // °C, KG, MM, etc.
  // ─── Status ───
  result              String   @default("PASS") @map("result") // PASS, FAIL, REWORK, HOLD, CONCESSION
  remarks             String?
  // ─── Actor ───
  checkedById         String?  @db.Uuid @map("checked_by_id")
  checkedByName       String?  @map("checked_by_name")
  // ─── Mobile Source ───
  deviceId            String?  @db.Uuid @map("device_id")
  deviceCode          String?  @map("device_code")
  scannedAt           DateTime? @map("scanned_at")
  // ─── Audit ───
  checkedAt           DateTime @default(now()) @map("checked_at")
  createdAt           DateTime @default(now()) @map("created_at")

  @@map("production_quality_checks")
  @@index([workOrderId, checkStage], map: "idx_pqc_wo_stage")
  @@index([batchId], map: "idx_pqc_batch")
  @@index([checkType, result], map: "idx_pqc_type_result")
  @@index([checkedAt], map: "idx_pqc_time")
}

// ═══════════════════════════════════════════════════════════════════════════════
// SPRINT 41 — PACKAGING, LABELING & FINISHED GOODS MANAGEMENT ENGINE
// Part 5: MES · 11 new models · Epic 1-8 (orders, levels, units, cartons, pallets,
// labels, quality checks, finished goods, handover, cost)
// ═══════════════════════════════════════════════════════════════════════════════

// ─── Epic 1: Packaging Orders ───────────────────────────────────────────
model PackagingOrder {
  id                  String   @id @default(uuid()) @db.Uuid
  packagingOrderNumber String  @unique @map("packaging_order_number") // PKG-2026-00001
  // ─── Source ───
  productionBatchId    String?  @db.Uuid @map("production_batch_id")
  productionBatchNumber String? @map("production_batch_number")
  productionOrderNumber String? @map("production_order_number")
  // ─── Product ───
  productId           String?  @db.Uuid @map("product_id")
  productSku          String   @map("product_sku")
  productName         String   @map("product_name")
  // ─── Packaging Type ───
  packagingType       String   @map("packaging_type") // PRIMARY, SECONDARY, TERTIARY, GIFT_BOX, BULK_PACK, RETAIL_PACK, EXPORT_PACK, PROMOTIONAL, COMBO, FAMILY
  // ─── Quantity ───
  plannedQuantity     Decimal  @db.Decimal(18, 4) @map("planned_quantity")
  completedQuantity   Decimal  @db.Decimal(18, 4) @default(0) @map("completed_quantity")
  rejectedQuantity    Decimal  @db.Decimal(18, 4) @default(0) @map("rejected_quantity")
  uom                 String   @default("PCS") @map("uom")
  // ─── Hierarchy Target ───
  unitPerBox          Int      @default(12) @map("unit_per_box")
  boxPerCarton        Int      @default(10) @map("box_per_carton")
  cartonPerPallet     Int      @default(40) @map("carton_per_pallet")
  // ─── Schedule ───
  plannedStart        DateTime? @map("planned_start")
  plannedFinish       DateTime? @map("planned_finish")
  actualStart         DateTime? @map("actual_start")
  actualFinish        DateTime? @map("actual_finish")
  // ─── Priority & Status ───
  priority            String   @default("NORMAL") @map("priority") // EMERGENCY, HIGH, NORMAL, LOW
  status              String   @default("DRAFT") @map("status") // DRAFT, RELEASED, IN_PROGRESS, QUALITY_HOLD, COMPLETED, TRANSFERRED, CANCELLED
  statusReason        String?  @map("status_reason")
  // ─── Operator ───
  operatorId          String?  @db.Uuid @map("operator_id")
  operatorName        String?  @map("operator_name")
  packagingLineCode   String?  @map("packaging_line_code")
  workCenterCode      String?  @map("work_center_code")
  // ─── Quality ───
  qualityStatus       String   @default("PENDING") @map("quality_status") // PENDING, PASSED, FAILED, HOLD, REWORK
  // ─── Handover ───
  warehouseTransferId String?  @db.Uuid @map("warehouse_transfer_id")
  warehouseReceiptNumber String? @map("warehouse_receipt_number")
  transferredAt       DateTime? @map("transferred_at")
  // ─── Audit ───
  createdById         String?  @db.Uuid @map("created_by_id")
  createdByName       String?  @map("created_by_name")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  lines               PackagingOrderLine[]
  packageUnits        PackageUnit[]
  packagingCartons    PackagingCarton[]
  packagingPallets    PackagingPallet[]
  qualityChecks       PackagingQualityCheck[]
  labelJobs           PackagingLabelJob[]
  costSummary         PackagingCostSummary?

  @@map("packaging_orders")
  @@index([status, priority], map: "idx_po41_status_priority")
  @@index([productionBatchId], map: "idx_po41_batch")
  @@index([productSku], map: "idx_po41_sku")
  @@index([packagingType], map: "idx_po41_type")
  @@index([plannedStart], map: "idx_po41_start")
}

model PackagingOrderLine {
  id                  String   @id @default(uuid()) @db.Uuid
  packagingOrderId    String   @db.Uuid @map("packaging_order_id")
  packagingOrderNumber String   @map("packaging_order_number")
  // ─── Material ───
  materialType        String   @map("material_type") // BOX, LABEL, SHRINK_WRAP, TAPE, POUCH, PLASTIC_TRAY, CORRUGATED_CARTON, PALLET_COVER, BARCODE_STICKER
  materialCode        String   @map("material_code")
  materialName        String   @map("material_name")
  // ─── Quantity ───
  plannedQty          Decimal  @db.Decimal(18, 4) @map("planned_qty")
  consumedQty         Decimal  @db.Decimal(18, 4) @default(0) @map("consumed_qty")
  wastageQty          Decimal  @db.Decimal(18, 4) @default(0) @map("wastage_qty")
  uom                 String   @default("PCS") @map("uom")
  // ─── Cost ───
  unitCost            Decimal  @db.Decimal(12, 4) @default(0) @map("unit_cost")
  totalCost           Decimal  @db.Decimal(14, 2) @default(0) @map("total_cost")
  // ─── Batch (for traceability) ───
  materialBatchNumber String?  @map("material_batch_number")
  // ─── Audit ───
  consumed            Boolean  @default(false)
  consumedAt          DateTime? @map("consumed_at")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  packagingOrder      PackagingOrder @relation(fields: [packagingOrderId], references: [id], onDelete: Cascade)

  @@map("packaging_order_lines")
  @@index([packagingOrderId], map: "idx_pol41_order")
  @@index([materialCode], map: "idx_pol41_material")
}

// ─── Epic 2: Multi-Level Packaging Hierarchy ────────────────────────────
// Unit → Inner Pack → Box → Carton → Pallet
model PackagingLevel {
  id                  String   @id @default(uuid()) @db.Uuid
  levelCode           String   @unique @map("level_code") // L1-UNIT, L2-INNER, L3-BOX, L4-CARTON, L5-PALLET
  levelName           String   @map("level_name")
  levelNumber         Int      @map("level_number") // 1=Unit, 2=Inner, 3=Box, 4=Carton, 5=Pallet
  // ─── Capacity ───
  childPerParent      Int      @map("child_per_parent") // how many children fit in one parent (12 units per box, 10 boxes per carton, etc.)
  // ─── Physical ───
  lengthCm            Decimal? @db.Decimal(8, 2) @map("length_cm")
  widthCm             Decimal? @db.Decimal(8, 2) @map("width_cm")
  heightCm            Decimal? @db.Decimal(8, 2) @map("height_cm")
  emptyWeightKg       Decimal? @db.Decimal(8, 3) @map("empty_weight_kg")
  // ─── Barcode ───
  barcodeType         String   @default("CODE_128") @map("barcode_type")
  // ─── Audit ───
  status              String   @default("ACTIVE")
  createdAt           DateTime @default(now()) @map("created_at")

  @@map("packaging_levels")
  @@index([levelNumber], map: "idx_pl41_level_num")
}

model PackageUnit {
  id                  String   @id @default(uuid()) @db.Uuid
  packageId           String   @unique @map("package_id") // PKG-UNIT-2026-000001
  // ─── Hierarchy ───
  levelNumber         Int      @default(1) @map("level_number") // 1=Unit
  parentPackageId     String?  @db.Uuid @map("parent_package_id") // links to PackagingCarton
  parentPackageNumber String?  @map("parent_package_number")
  // ─── Links ───
  packagingOrderId    String   @db.Uuid @map("packaging_order_id")
  packagingOrderNumber String   @map("packaging_order_number")
  // ─── Product ───
  productId           String?  @db.Uuid @map("product_id")
  productSku          String   @map("product_sku")
  productName         String   @map("product_name")
  batchNumber         String   @map("batch_number")
  // ─── Quantity ───
  quantity            Decimal  @db.Decimal(18, 4) @default(1) @map("quantity")
  uom                 String   @default("PCS") @map("uom")
  netWeightKg         Decimal? @db.Decimal(10, 3) @map("net_weight_kg")
  grossWeightKg       Decimal? @db.Decimal(10, 3) @map("gross_weight_kg")
  // ─── Barcode / QR ───
  barcode             String   @unique
  qrCode              String?  @map("qr_code")
  // ─── Label ───
  labelPrinted        Boolean  @default(false) @map("label_printed")
  labelPrintedAt      DateTime? @map("label_printed_at")
  // ─── Status ───
  status              String   @default("PACKED") @map("status") // PACKED, SEALED, LABELED, IN_CARTON, TRANSFERRED, REJECTED
  packedAt            DateTime @default(now()) @map("packed_at")
  // ─── Audit ───
  createdAt           DateTime @default(now()) @map("created_at")

  packagingOrder      PackagingOrder @relation(fields: [packagingOrderId], references: [id], onDelete: Cascade)

  @@map("package_units")
  @@index([packagingOrderId], map: "idx_pu41_order")
  @@index([parentPackageId], map: "idx_pu41_parent")
  @@index([batchNumber], map: "idx_pu41_batch")
  @@index([barcode], map: "idx_pu41_barcode")
}

model PackagingCarton {
  id                  String   @id @default(uuid()) @db.Uuid
  cartonNumber        String   @unique @map("carton_number") // CTN-2026-000001
  // ─── Hierarchy ───
  levelNumber         Int      @default(4) @map("level_number") // 4=Carton
  parentPalletId      String?  @db.Uuid @map("parent_pallet_id")
  parentPalletNumber  String?  @map("parent_pallet_number")
  // ─── Links ───
  packagingOrderId    String   @db.Uuid @map("packaging_order_id")
  packagingOrderNumber String   @map("packaging_order_number")
  // ─── Contents ───
  productSku          String   @map("product_sku")
  productName         String   @map("product_name")
  batchNumber         String   @map("batch_number")
  // ─── Quantity ───
  boxesCount          Int      @default(0) @map("boxes_count")
  unitsCount          Int      @default(0) @map("units_count")
  netWeightKg         Decimal  @db.Decimal(10, 3) @default(0) @map("net_weight_kg")
  grossWeightKg       Decimal  @db.Decimal(10, 3) @default(0) @map("gross_weight_kg")
  // ─── Physical ───
  lengthCm            Decimal? @db.Decimal(8, 2) @map("length_cm")
  widthCm             Decimal? @db.Decimal(8, 2) @map("width_cm")
  heightCm            Decimal? @db.Decimal(8, 2) @map("height_cm")
  // ─── Barcode / QR ───
  barcode             String   @unique
  qrCode              String?  @map("qr_code")
  // ─── Label ───
  labelPrinted        Boolean  @default(false) @map("label_printed")
  labelPrintedAt      DateTime? @map("label_printed_at")
  // ─── Status ───
  status              String   @default("OPEN") @map("status") // OPEN, SEALED, LABELED, ON_PALLET, TRANSFERRED, REJECTED
  sealedAt            DateTime? @map("sealed_at")
  // ─── Audit ───
  packedAt            DateTime @default(now()) @map("packed_at")
  createdAt           DateTime @default(now()) @map("created_at")

  packagingOrder      PackagingOrder @relation(fields: [packagingOrderId], references: [id], onDelete: Cascade)

  @@map("packaging_cartons")
  @@index([packagingOrderId], map: "idx_pc41_order")
  @@index([parentPalletId], map: "idx_pc41_parent")
  @@index([batchNumber], map: "idx_pc41_batch")
  @@index([barcode], map: "idx_pc41_barcode")
}

model PackagingPallet {
  id                  String   @id @default(uuid()) @db.Uuid
  palletNumber        String   @unique @map("pallet_number") // PAL-2026-000001
  // ─── Hierarchy ───
  levelNumber         Int      @default(5) @map("level_number") // 5=Pallet
  // ─── Links ───
  packagingOrderId    String   @db.Uuid @map("packaging_order_id")
  packagingOrderNumber String   @map("packaging_order_number")
  // ─── Contents ───
  productSku          String   @map("product_sku")
  productName         String   @map("product_name")
  batchNumber         String   @map("batch_number")
  // ─── Quantity ───
  cartonsCount        Int      @default(0) @map("cartons_count")
  boxesCount          Int      @default(0) @map("boxes_count")
  unitsCount          Int      @default(0) @map("units_count")
  netWeightKg         Decimal  @db.Decimal(12, 3) @default(0) @map("net_weight_kg")
  grossWeightKg       Decimal  @db.Decimal(12, 3) @default(0) @map("gross_weight_kg")
  // ─── Physical ───
  lengthCm            Decimal? @db.Decimal(8, 2) @map("length_cm")
  widthCm             Decimal? @db.Decimal(8, 2) @map("width_cm")
  heightCm            Decimal? @db.Decimal(8, 2) @map("height_cm")
  // ─── Destination ───
  destinationWarehouseId String?  @db.Uuid @map("destination_warehouse_id")
  destinationWarehouseName String? @map("destination_warehouse_name")
  destinationBinCode  String?  @map("destination_bin_code")
  // ─── Barcode / QR ───
  barcode             String   @unique
  qrCode              String?  @map("qr_code")
  // ─── Label ───
  labelPrinted        Boolean  @default(false) @map("label_printed")
  labelPrintedAt      DateTime? @map("label_printed_at")
  // ─── Status ───
  status              String   @default("BUILDING") @map("status") // BUILDING, COMPLETED, SEALED, TRANSFERRED, REJECTED
  sealedAt            DateTime? @map("sealed_at")
  // ─── Audit ───
  packedAt            DateTime @default(now()) @map("packed_at")
  createdAt           DateTime @default(now()) @map("created_at")

  packagingOrder      PackagingOrder @relation(fields: [packagingOrderId], references: [id], onDelete: Cascade)

  @@map("packaging_pallets")
  @@index([packagingOrderId], map: "idx_pp41_order")
  @@index([batchNumber], map: "idx_pp41_batch")
  @@index([barcode], map: "idx_pp41_barcode")
  @@index([destinationWarehouseId], map: "idx_pp41_dest_wh")
}

// ─── Epic 4: Packaging Labels ───────────────────────────────────────────
model PackagingLabelJob {
  id                  String   @id @default(uuid()) @db.Uuid
  jobCode             String   @unique @map("job_code") // PLJ-2026-000001
  // ─── Links ───
  packagingOrderId    String   @db.Uuid @map("packaging_order_id")
  packagingOrderNumber String   @map("packaging_order_number")
  batchNumber         String   @map("batch_number")
  productName         String   @map("product_name")
  // ─── Target ───
  packageId           String?  @db.Uuid @map("package_id")
  packageNumber       String   @map("package_number")
  packageLevel        String   @map("package_level") // UNIT, BOX, CARTON, PALLET
  // ─── Label Type ───
  labelType           String   @map("label_type") // PRODUCT_LABEL, BATCH_LABEL, CARTON_LABEL, PALLET_LABEL, QR_LABEL, BARCODE_LABEL, SHIPPING_LABEL, INTERNAL_LABEL
  // ─── Label Data ───
  labelData           String   @map("label_data") // JSON: { productName, batch, mfg, expiry, mrp, netWeight, qrCode, barcode }
  qrCode              String   @map("qr_code")
  barcode             String   @map("barcode")
  barcodeType         String   @default("CODE_128") @map("barcode_type")
  // ─── Print ───
  printerType         String   @default("BLUETOOTH") @map("printer_type")
