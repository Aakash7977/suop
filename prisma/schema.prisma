// ═══════════════════════════════════════════════════════════════
// SPRINT 28 — WAVE PLANNING, TASK ORCHESTRATION & WORKFORCE ENGINE
// Epic 1: Wave Planning · Epic 2: Task Engine · Epic 3: Dynamic Assignment
// Epic 4: Workforce · Epic 5: Equipment · Epic 6: SLA · Epic 7: Exceptions
// ═══════════════════════════════════════════════════════════════

// ─── Epic 1: Wave Planning Engine ───────────────────────
model WarehouseWave {
  id              String   @id @default(uuid()) @db.Uuid
  waveNumber      String   @unique @map("wave_number")
  // ─── Type & Strategy ───
  waveType        String   @map("wave_type") // SINGLE_ORDER, MULTI_ORDER, BATCH, ZONE, CARRIER, ROUTE, PRIORITY, EMERGENCY
  strategy        String   @default("FIFO") // FIFO, FEFO, LIFO, PRIORITY, ZONE_SEQUENCE
  // ─── Scope ───
  warehouseId     String   @db.Uuid @map("warehouse_id")
  warehouseName   String   @map("warehouse_name")
  zoneId          String?  @db.Uuid @map("zone_id")
  zoneName        String?  @map("zone_name")
  // ─── Priority ───
  priority        String   @default("NORMAL") // EMERGENCY, HIGH, NORMAL, LOW
  priorityScore   Int      @default(50) @map("priority_score") // 0-100
  // ─── Schedule ───
  plannedStart    DateTime @map("planned_start")
  plannedFinish   DateTime @map("planned_finish")
  actualStart     DateTime? @map("actual_start")
  actualFinish    DateTime? @map("actual_finish")
  // ─── Status ───
  status          String   @default("DRAFT") // DRAFT, RELEASED, IN_PROGRESS, COMPLETED, CANCELLED, ON_HOLD
  releaseReason   String?  @map("release_reason")
  // ─── Capacity ───
  totalOrders     Int      @default(0) @map("total_orders")
  totalLines      Int      @default(0) @map("total_lines")
  totalTasks      Int      @default(0) @map("total_tasks")
  totalQty        Decimal  @db.Decimal(18, 4) @default(0) @map("total_qty")
  totalWeightKg   Decimal  @db.Decimal(12, 2) @default(0) @map("total_weight_kg")
  // ─── Operator & Equipment ───
  assignedOperatorIds String[] @default([]) @map("assigned_operator_ids")
  requiredEquipment   String[] @default([]) @map("required_equipment")
  // ─── Release / Audit ───
  releasedById    String?  @db.Uuid @map("released_by_id")
  releasedByName  String?  @map("released_by_name")
  releasedAt      DateTime? @map("released_at")
  createdById     String?  @db.Uuid @map("created_by_id")
  createdByName   String?  @map("created_by_name")
  // ─── AI Optimization ───
  optimizationScore Int?   @map("optimization_score") // 0-100, AI-calculated
  optimizationNotes String? @map("optimization_notes")
  // ─── Audit ───
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  orders          WaveOrder[]
  statusHistory   WaveStatusHistory[]
  tasks           WarehouseTask[]

  @@map("warehouse_waves")
  @@index([warehouseId, status], map: "idx_ww_wh_status")
  @@index([waveType, status], map: "idx_ww_type_status")
  @@index([plannedStart], map: "idx_ww_planned_start")
  @@index([priority, status], map: "idx_ww_priority_status")
}

model WaveOrder {
  id              String   @id @default(uuid()) @db.Uuid
  waveId          String   @db.Uuid @map("wave_id")
  // ─── Order Reference ───
  orderType       String   @map("order_type") // SALES_ORDER, TRANSFER_ORDER, REPLENISHMENT, RETURN, PRODUCTION_ORDER
  orderNumber     String   @map("order_number")
  orderId         String?  @db.Uuid @map("order_id")
  // ─── Partner ───
  partnerId       String?  @db.Uuid @map("partner_id")
  partnerName     String?  @map("partner_name")
  // ─── Route / Carrier ───
  carrierId       String?  @db.Uuid @map("carrier_id")
  carrierName     String?  @map("carrier_name")
  routeId         String?  @db.Uuid @map("route_id")
  routeName       String?  @map("route_name")
  // ─── Priority ───
  priority        String   @default("NORMAL") @map("priority")
  priorityScore   Int      @default(50) @map("priority_score")
  // ─── Schedule ───
  requiredShipDate DateTime? @map("required_ship_date")
  promisedDate    DateTime? @map("promised_date")
  // ─── Lines & Qty ───
  totalLines      Int      @default(0) @map("total_lines")
  totalQty        Decimal  @db.Decimal(18, 4) @default(0) @map("total_qty")
  // ─── Allocation ───
  fullyAllocated  Boolean  @default(false) @map("fully_allocated")
  partiallyAllocated Boolean @default(false) @map("partially_allocated")
  // ─── Status ───
  status          String   @default("PLANNED") // PLANNED, ALLOCATED, SHORT_PICKED, COMPLETED, CANCELLED
  exceptionFlag   Boolean  @default(false) @map("exception_flag")
  exceptionReason String?  @map("exception_reason")
  // ─── Audit ───
  createdAt       DateTime @default(now()) @map("created_at")

  wave            WarehouseWave @relation(fields: [waveId], references: [id], onDelete: Cascade)

  @@map("wave_orders")
  @@unique([waveId, orderNumber], map: "uq_wo_wave_order")
  @@index([waveId], map: "idx_wo_wave")
  @@index([orderNumber], map: "idx_wo_order")
  @@index([status], map: "idx_wo_status")
}

model WaveStatusHistory {
  id              String   @id @default(uuid()) @db.Uuid
  waveId          String   @db.Uuid @map("wave_id")
  fromStatus      String?  @map("from_status")
  toStatus        String   @map("to_status")
  changedById     String?  @db.Uuid @map("changed_by_id")
  changedByName   String?  @map("changed_by_name")
  changeReason    String?  @map("change_reason")
  changedAt       DateTime @default(now()) @map("changed_at")

  wave            WarehouseWave @relation(fields: [waveId], references: [id], onDelete: Cascade)

  @@map("wave_status_history")
  @@index([waveId, changedAt], map: "idx_wsh_wave_time")
}

// ─── Epic 2: Warehouse Task Engine ──────────────────────
model WarehouseTask {
  id              String   @id @default(uuid()) @db.Uuid
  taskNumber      String   @unique @map("task_number")
  // ─── Type ───
  taskType        String   @map("task_type") // RECEIVE, PUTAWAY, PICK, PACK, TRANSFER, COUNT, INSPECT, LOAD, DISPATCH, REPLENISH
  // ─── Wave Link ───
  waveId          String?  @db.Uuid @map("wave_id")
  waveNumber      String?  @map("wave_number")
  // ─── Source Reference ───
  sourceType      String?  @map("source_type") // WAVE, MANUAL, REPLENISHMENT, CYCLE_COUNT, EXCEPTION, AI_SUGGESTED
  sourceId        String?  @db.Uuid @map("source_id")
  sourceNumber    String?  @map("source_number")
  // ─── Scope ───
  warehouseId     String   @db.Uuid @map("warehouse_id")
  warehouseName   String   @map("warehouse_name")
  zoneId          String?  @db.Uuid @map("zone_id")
